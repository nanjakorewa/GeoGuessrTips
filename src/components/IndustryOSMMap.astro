---
/**
 * OpenStreetMap (Leaflet + Carto Voyager) を使った産業地帯マップ。
 *
 * フロントマターで `mapProvider: osm` を指定すると IndustryLayout から呼ばれる。
 * タイルは Carto の無償ベースマップを利用しており、OSM および CARTO への帰属表示で利用可能。
 * （tile.openstreetmap.org は ToS 上、本番サイトでの利用が制限されているため避ける）
 */
interface Pin {
  lat: number;
  lng: number;
  label: string;
  note?: string;
  type?: string;
  link?: string;
}

interface RegionGroup {
  name: string;
  color: string;
  regions: string[];
  note?: string;
}

interface MapRegions {
  source: string;
  topojsonObject?: string;
  property: string;
  groups: RegionGroup[];
  legendTitle?: string;
}

interface Props {
  pins: Pin[];
  center?: [number, number];
  zoom?: number;
  regions?: MapRegions;
}

const { pins, center, zoom, regions } = Astro.props;
---

<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
  crossorigin=""
/>

<div
  id="ind-osm-map"
  class="ind-osm-map"
  data-pins={JSON.stringify(pins)}
  data-center={center ? JSON.stringify(center) : ""}
  data-zoom={zoom != null ? String(zoom) : ""}
  data-regions={regions ? JSON.stringify(regions) : ""}
>
</div>

<style is:global>
  .ind-osm-map {
    width: 100%;
    height: 480px;
    background: #eef0ec;
    position: relative;
    z-index: 0;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.25);
  }
  /* Positron をサイトの紺色トーンに馴染ませる薄い色味補正 */
  .ind-osm-map .ind-osm-tile {
    filter: hue-rotate(-12deg) saturate(0.85) brightness(0.98);
  }
  /* ダークモード時はタイルを更に落ち着かせる */
  [data-theme="dark"] .ind-osm-map {
    background: #20272e;
  }
  [data-theme="dark"] .ind-osm-map .ind-osm-tile {
    filter: hue-rotate(-12deg) saturate(0.7) brightness(0.78) contrast(0.95);
  }
  .ind-osm-pin {
    background: transparent;
    border: 0;
  }
  .ind-osm-pin__dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #e07b20;
    border: 2px solid #fff;
    box-shadow: 0 0 0 3px rgba(224, 123, 32, 0.25), 0 1px 3px rgba(0, 0, 0, 0.4);
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
  }
  .ind-osm-pin__label {
    position: absolute;
    left: 50%;
    top: calc(50% + 12px);
    transform: translateX(-50%);
    background: rgba(30, 58, 95, 0.92);
    color: #fff;
    padding: 2px 6px;
    border-radius: 3px;
    font-size: 11px;
    font-family: "Hiragino Sans", "Hiragino Kaku Gothic ProN", "Noto Sans JP", system-ui, sans-serif;
    white-space: nowrap;
    pointer-events: none;
    line-height: 1.3;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.25);
  }
  .ind-osm-popup .leaflet-popup-content {
    margin: 10px 14px;
    font-size: 13px;
    line-height: 1.5;
    font-family: "Hiragino Sans", "Hiragino Kaku Gothic ProN", "Noto Sans JP", system-ui, sans-serif;
    max-width: 240px;
  }
  .ind-osm-popup__title {
    font-weight: 700;
    margin-bottom: 4px;
    color: #1e3a5f;
  }
  .ind-osm-popup__note {
    color: #334155;
  }
  .ind-osm-popup__link {
    display: inline-block;
    margin-top: 6px;
    font-size: 12px;
    color: #1e3a5f;
  }
  [data-theme="dark"] .ind-osm-popup .leaflet-popup-content-wrapper,
  [data-theme="dark"] .ind-osm-popup .leaflet-popup-tip {
    background: #22262a;
    color: #d8d5d0;
  }
  [data-theme="dark"] .ind-osm-popup__title {
    color: #5b9bd5;
  }
  [data-theme="dark"] .ind-osm-popup__note {
    color: #d8d5d0;
  }
  [data-theme="dark"] .ind-osm-popup__link {
    color: #5b9bd5;
  }

  /* コロプレス（地域色分け）レイヤ */
  .ind-osm-region {
    fill-opacity: 0.55;
    stroke: #fff;
    stroke-width: 0.8;
    transition: fill-opacity 0.15s ease;
  }
  .ind-osm-region.is-hover {
    fill-opacity: 0.85;
  }
  .ind-osm-legend {
    background: rgba(255, 255, 255, 0.95);
    padding: 8px 10px;
    border-radius: 4px;
    font-size: 11px;
    line-height: 1.5;
    font-family: "Hiragino Sans", "Hiragino Kaku Gothic ProN", "Noto Sans JP", system-ui, sans-serif;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.15);
    max-width: 220px;
  }
  .ind-osm-legend__title {
    font-weight: 700;
    font-size: 12px;
    margin-bottom: 4px;
    color: #1e3a5f;
  }
  .ind-osm-legend__item {
    display: flex;
    align-items: center;
    gap: 6px;
    margin: 2px 0;
  }
  .ind-osm-legend__swatch {
    width: 14px;
    height: 14px;
    border-radius: 3px;
    flex-shrink: 0;
  }
  [data-theme="dark"] .ind-osm-legend {
    background: rgba(34, 38, 42, 0.95);
    color: #d8d5d0;
  }
  [data-theme="dark"] .ind-osm-legend__title {
    color: #5b9bd5;
  }
</style>

<script
  is:inline
  src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
  integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
  crossorigin=""
></script>

<script is:inline>
  (function () {
    function init() {
      var el = document.getElementById("ind-osm-map");
      if (!el) return;
      if (typeof L === "undefined") {
        setTimeout(init, 80);
        return;
      }

      var pins = [];
      try {
        pins = JSON.parse(el.getAttribute("data-pins") || "[]");
      } catch (e) {
        pins = [];
      }
      var centerAttr = el.getAttribute("data-center");
      var zoomAttr = el.getAttribute("data-zoom");

      var map = L.map(el, {
        scrollWheelZoom: false,
        zoomControl: true,
      });

      // Carto Positron（単色のクリーンなベースマップ。OSM 帰属表示で無償利用可）
      L.tileLayer("https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png", {
        attribution:
          '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
        subdomains: "abcd",
        maxZoom: 19,
        className: "ind-osm-tile",
      }).addTo(map);

      // ----- コロプレス（地域色分け）レイヤ -----
      var regionsAttr = el.getAttribute("data-regions");
      var regionsConfig = null;
      try {
        if (regionsAttr) regionsConfig = JSON.parse(regionsAttr);
      } catch (e) {
        regionsConfig = null;
      }
      var regionLayer = null;
      var regionBounds = null;
      if (regionsConfig && regionsConfig.source) {
        loadAndRenderRegions(regionsConfig);
      }

      function loadAndRenderRegions(cfg) {
        // region名 → group の lookup を構築
        var lookup = {};
        cfg.groups.forEach(function (g) {
          (g.regions || []).forEach(function (r) {
            lookup[r] = g;
          });
        });
        fetch(cfg.source)
          .then(function (r) { return r.json(); })
          .then(function (data) {
            var geojson = isTopojson(data, cfg.topojsonObject) ? topojsonToGeojson(data, cfg.topojsonObject) : data;
            regionLayer = L.geoJSON(geojson, {
              style: function (feature) {
                var key = feature && feature.properties ? feature.properties[cfg.property] : null;
                var g = key ? lookup[key] : null;
                return {
                  className: "ind-osm-region",
                  fillColor: g ? g.color : "#cbd5e1",
                  fillOpacity: g ? 0.55 : 0.15,
                  color: "#fff",
                  weight: 0.8,
                };
              },
              onEachFeature: function (feature, layer) {
                var key = feature && feature.properties ? feature.properties[cfg.property] : null;
                var g = key ? lookup[key] : null;
                var label = (feature.properties && (feature.properties.nam_ja || feature.properties.name || feature.properties[cfg.property])) || "";
                var html = '<div class="ind-osm-popup__title">' + label + "</div>";
                if (g) html += '<div class="ind-osm-popup__note"><strong>' + g.name + '</strong>' + (g.note ? "<br>" + g.note : "") + "</div>";
                layer.bindPopup(html, { className: "ind-osm-popup" });
                layer.on("mouseover", function () { layer.setStyle({ fillOpacity: 0.85 }); });
                layer.on("mouseout", function () { layer.setStyle({ fillOpacity: g ? 0.55 : 0.15 }); });
              },
            });
            regionLayer.addTo(map);
            regionBounds = regionLayer.getBounds();
            // ピンが無く、明示的な center/zoom も指定されていない場合だけポリゴンに合わせてフィット
            // pad は負値で内側に縮め、デフォルトのフィットよりやや拡大して表示する
            if (!markers.length && regionBounds.isValid() && !(centerAttr && zoomAttr)) {
              map.fitBounds(regionBounds.pad(-0.08));
            }
            addLegend(cfg);
          })
          .catch(function (err) {
            console.error("[IndustryOSMMap] region layer load failed:", err);
          });
      }

      function isTopojson(data, objKey) {
        return !!(data && data.type === "Topology" && data.objects && (objKey ? data.objects[objKey] : true));
      }

      // 軽量な TopoJSON → GeoJSON デコーダ（topojson-client なしで動作）
      function topojsonToGeojson(topo, objKey) {
        var key = objKey || Object.keys(topo.objects)[0];
        var obj = topo.objects[key];
        var arcs = topo.arcs;
        var tx = topo.transform;
        function decodeArc(arcIdx) {
          var reverse = arcIdx < 0;
          var idx = reverse ? ~arcIdx : arcIdx;
          var arc = arcs[idx];
          var x = 0, y = 0;
          var pts = arc.map(function (d) {
            x += d[0]; y += d[1];
            return tx ? [x * tx.scale[0] + tx.translate[0], y * tx.scale[1] + tx.translate[1]] : [x, y];
          });
          return reverse ? pts.slice().reverse() : pts;
        }
        function ringToCoords(ring) {
          var coords = [];
          for (var i = 0; i < ring.length; i++) {
            var pts = decodeArc(ring[i]);
            if (coords.length) coords.pop();
            for (var j = 0; j < pts.length; j++) coords.push(pts[j]);
          }
          return coords;
        }
        function polygonToCoords(poly) { return poly.map(ringToCoords); }
        var features = obj.geometries.map(function (g) {
          var coords;
          if (g.type === "MultiPolygon") coords = g.arcs.map(polygonToCoords);
          else if (g.type === "Polygon") coords = polygonToCoords(g.arcs);
          else coords = [];
          return { type: "Feature", properties: g.properties, geometry: { type: g.type, coordinates: coords } };
        });
        return { type: "FeatureCollection", features: features };
      }

      function addLegend(cfg) {
        var legend = L.control({ position: "topright" });
        legend.onAdd = function () {
          var div = L.DomUtil.create("div", "ind-osm-legend");
          var html = "";
          if (cfg.legendTitle) html += '<div class="ind-osm-legend__title">' + cfg.legendTitle + "</div>";
          cfg.groups.forEach(function (g) {
            html +=
              '<div class="ind-osm-legend__item">' +
              '<span class="ind-osm-legend__swatch" style="background:' + g.color + '"></span>' +
              '<span>' + g.name + "</span>" +
              "</div>";
          });
          div.innerHTML = html;
          L.DomEvent.disableClickPropagation(div);
          return div;
        };
        legend.addTo(map);
      }

      var markers = [];
      pins.forEach(function (p) {
        var html =
          '<div class="ind-osm-pin__dot"></div>' +
          '<div class="ind-osm-pin__label">' +
          (p.label || "") +
          "</div>";
        var icon = L.divIcon({
          className: "ind-osm-pin",
          html: html,
          iconSize: [0, 0],
          iconAnchor: [0, 0],
        });
        var m = L.marker([p.lat, p.lng], { icon: icon, title: p.label || "" });

        var popup = '<div class="ind-osm-popup__title">' + (p.label || "") + "</div>";
        if (p.note) popup += '<div class="ind-osm-popup__note">' + p.note + "</div>";
        if (p.link) popup += '<a class="ind-osm-popup__link" href="' + p.link + '">詳細を見る →</a>';
        m.bindPopup(popup, { className: "ind-osm-popup" });

        m.addTo(map);
        markers.push(m);
      });

      if (centerAttr && zoomAttr) {
        try {
          map.setView(JSON.parse(centerAttr), parseInt(zoomAttr, 10));
        } catch (e) {
          fitToMarkers();
        }
      } else {
        fitToMarkers();
      }

      function fitToMarkers() {
        if (markers.length) {
          var group = L.featureGroup(markers);
          map.fitBounds(group.getBounds().pad(0.18));
        } else {
          map.setView([36, 138], 5);
        }
      }

      // ピンの座標調整用：URL に ?pick が付いていたらクリック地点の lat/lng を表示
      // 例: /industry/japan-combinat/kashima/?pick → 各施設をクリックして座標をコピー
      if (/[?&]pick(=|&|$)/.test(location.search)) {
        map.scrollWheelZoom.enable();
        map.on("click", function (ev) {
          var lat = ev.latlng.lat.toFixed(4);
          var lng = ev.latlng.lng.toFixed(4);
          var coord = lat + ", " + lng;
          var yaml = "{ lat: " + lat + ", lng: " + lng + ', label: "" }';
          var content =
            '<div style="font-family:monospace;font-size:12px;line-height:1.7">' +
            '<div><strong>' + coord + '</strong></div>' +
            '<div style="color:#64748b;margin:4px 0;word-break:break-all">' + yaml + '</div>' +
            '<button type="button" data-copy="' + yaml.replace(/"/g, "&quot;") + '" ' +
            'style="margin-top:4px;padding:3px 10px;border:1px solid #cbd5e1;background:#fff;border-radius:4px;cursor:pointer;font-size:11px">' +
            'YAML をコピー</button>' +
            '</div>';
          var pop = L.popup({ className: "ind-osm-popup" })
            .setLatLng(ev.latlng)
            .setContent(content)
            .openOn(map);
          setTimeout(function () {
            var btn = pop.getElement() && pop.getElement().querySelector("button[data-copy]");
            if (btn && navigator.clipboard) {
              btn.addEventListener("click", function () {
                navigator.clipboard.writeText(btn.getAttribute("data-copy"));
                btn.textContent = "コピーしました ✓";
              });
            }
          }, 0);
        });
      }

      // IndustryLayout の clamp 開閉時にサイズが変わるので追従させる
      window.addEventListener("resize", function () {
        map.invalidateSize();
      });
      var clamp = document.getElementById("ind-map-clamp");
      if (clamp && typeof MutationObserver !== "undefined") {
        new MutationObserver(function () {
          setTimeout(function () {
            map.invalidateSize();
          }, 520);
        }).observe(clamp, { attributes: true, attributeFilter: ["style", "class"] });
      }
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
  })();
</script>
