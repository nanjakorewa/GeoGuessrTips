---
import type { Language } from "@lib/i18n-utils";
import { getLanguageName } from "@lib/i18n-utils";
import { t } from "@i18n/translations";

interface Props {
  lang: Language;
  title: string;
  permalink: string;
  flag?: string;
  translations?: { lang: Language; url: string }[];
}

const { lang, title, permalink, flag, translations = [] } = Astro.props;

const aboutUrl = lang === "ja" ? "/about/" : `/${lang}/about/`;
const topUrl = lang === "ja" ? "/" : `/${lang}/`;
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      {/* Brand */}
      <div class="footer-col footer-brand-col">
        <a class="footer-brand" href={topUrl}>GeoGuessrの攻略めも</a>
        <p class="footer-brand-desc">GeoGuessr Tips &amp; Notes</p>
      </div>

      {/* Site */}
      <div class="footer-col">
        <h4 class="footer-heading">SITE</h4>
        <ul class="footer-links">
          <li><a href={aboutUrl}>{t("footer_privacy_link", lang)}</a></li>
          <li><a href={topUrl}>Top</a></li>
        </ul>
      </div>

      {/* Connect */}
      <div class="footer-col">
        <h4 class="footer-heading">CONNECT</h4>
        <ul class="footer-links">
          <li><a href="https://www.youtube.com/@nanjakorewa" target="_blank" rel="noopener"><i class="fab fa-youtube"></i> YouTube</a></li>
          <li><a href="https://x.com/nanjakorewa" target="_blank" rel="noopener"><i class="fab fa-twitter"></i> X / Twitter</a></li>
          <li><a href="https://github.com/nanjakorewa/GeoGuessrTips" target="_blank" rel="noopener"><i class="fab fa-github"></i> GitHub</a></li>
        </ul>
      </div>

      {/* Sister Sites */}
      <div class="footer-col">
        <h4 class="footer-heading">SISTER SITES</h4>
        <ul class="footer-links">
          <li><a href="https://nanja-webtools.pages.dev/" target="_blank" rel="noopener">Webtools</a></li>
          <li><a href="https://geopinning.space/">Geogesser's Notes</a></li>
          <li><a href="https://nanja-recipe.pages.dev/" target="_blank" rel="noopener">Nanja Recipe</a></li>
        </ul>
      </div>

      {/* Language */}
      {translations.length > 0 && (
        <div class="footer-col">
          <h4 class="footer-heading">LANGUAGE</h4>
          <ul class="footer-links footer-lang-links">
            {translations.map(({ lang: tLang, url }) => (
              <li>
                <a href={url} class:list={[{ "is-current": tLang === lang }]}>
                  {getLanguageName(tLang)}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>

    <div class="footer-bottom">
      <p>&copy; 2021-2026 nanja.</p>
    </div>
  </div>
</footer>

<script is:inline src="/scripts/script.js"></script>

<script is:inline>
const toggleLink = document.getElementById("toggle-link");
if (toggleLink) {
  toggleLink.addEventListener("click", function (event) {
    event.preventDefault();
    document.querySelectorAll("li.unofficial-area").forEach(function(li) {
      li.classList.toggle("dontshowarea");
    });
  });
}
</script>

{flag && (
  <script is:inline defer>
    d3.csv('https://docs.google.com/spreadsheets/d/1wRzEFe1kQKQl8flRhe0V5gJTRD-XVO_Ux-Nd8rtGAmU/export?format=csv&range=A3:D', function(error, data){
      if (!data || !data[0]) return;
      let media = data[0].StreamSetting;
      if (media==="youtube"){
        var areaTitle = document.getElementById("streaming-status-area");
        if(areaTitle) areaTitle.className = areaTitle.className.replace("streaming-status-area-title", "");
        var ytTitle = document.getElementById("youtube-button-streaming");
        if(ytTitle) ytTitle.className = ytTitle.className.replace("streaming-status-area", "");
        var stTitle = document.getElementById("streaming-title");
        if(stTitle) stTitle.innerHTML = data[0].StreamingTitle;
      }
      else if (media==="twitch"){
        var areaTitle = document.getElementById("streaming-status-area");
        if(areaTitle) areaTitle.className = areaTitle.className.replace("streaming-status-area-title", "");
        var twTitle = document.getElementById("twitch-button-streaming");
        if(twTitle) twTitle.className = twTitle.className.replace("streaming-status-area-img", "");
        var stTitle = document.getElementById("streaming-title");
        if(stTitle) stTitle.innerHTML = data[0].StreamingTitle;
      }
    });
  </script>
)}

<script is:inline async src="https://platform.twitter.com/widgets.js" charset="utf-8"></script>
<script is:inline async src="//cdn.embedly.com/widgets/platform.js" charset="UTF-8"></script>
