---
/**
 * Pin-based map quiz page (Leaflet/OSM).
 *
 * Used by /quiz/states/asia/indonesia-kabupaten/[province]/ to render a
 * pin-on-map quiz where the question is a kabupaten name and the answer is
 * a click on the corresponding pin. Mirrors the SVG-based StateQuizPage in
 * scoring, memorize-mode, and restart behaviour.
 */
import Head from "@components/seo/Head.astro";
import Navbar from "@components/navigation/Navbar.astro";
import Footer from "@components/footer/Footer.astro";
import SearchModal from "@components/search/SearchModal.astro";
import type { Language } from "@lib/i18n-utils";
import { getQuizI18n } from "../data/quiz-states-i18n";

interface Pin {
  /** Unique id within this quiz (we use shortName) */
  code: string;
  /** Displayed name in the question (e.g. "Kabupaten Banda Aceh") */
  name: string;
  /** Short name without prefix, used in feedback / SEO list */
  shortName: string;
  lat: number;
  lng: number;
}
interface Crumb { name: string; url: string; }

interface Props {
  lang: Language;
  pageTitle: string;
  pageDescription: string;
  canonical: string;
  pageH1: string;
  prompt: string;
  storageKey: string;
  breadcrumbs: Crumb[];
  pins: Pin[];
  /** Map view: [minLng, minLat, maxLng, maxLat] used as initial bounds */
  bbox: [number, number, number, number];
  /** Optional supplementary lead text shown under the map */
  lead?: string;
}

const {
  lang,
  pageTitle,
  pageDescription,
  canonical,
  pageH1,
  prompt,
  storageKey,
  breadcrumbs,
  pins,
  bbox,
  lead,
} = Astro.props as Props;

const site = "https://geopinning.space";
const t = getQuizI18n(lang);
const seoNames = pins.map((p) => p.name).join(lang === "ja" ? "、" : ", ");
const seoDescription = t.pinQuiz.contentDescFmt(pageH1, pins.length);
const memorizeHint = t.pinQuiz.promptMemorizeHint;
const contentTitle = t.pinQuiz.contentTitleFmt(pins.length);
// Localized inline JS labels — used inside the page-bound script via define:vars.
const jsLabels = {
  finished: t.question.finished,
  memorizePrompt: t.memorize.prompt,
  emptyName: t.memorize.emptyName,
  clicked: t.feedback.clicked,
  summaryTitleFmt: t.summary.titleFmt(0).replace(/0/, "{n}"),
};
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <Head
    title={pageTitle}
    description={pageDescription}
    lang={lang}
    canonical={canonical}
    ogImage={`${site}/images/icon-512x512.png`}
    ogType="website"
    breadcrumbs={breadcrumbs}
    collection="quiz"
  />
  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""
  />
  <style is:global>
    html, body { min-height: 100vh; }
    body { overflow-x: hidden; display: flex; flex-direction: column; }
    body > header { flex: 0 0 auto; }
    body > main { flex: 1 0 auto; }
    body > .site-footer, body > footer { flex: 0 0 auto; margin-top: 0; }

    .pq-page { max-width: 1320px; margin: 0 auto; padding: 0.8rem 1rem 1.2rem; }
    .pq-layout { display: grid; grid-template-columns: 200px minmax(0, 1fr); gap: 1.1rem; align-items: start; }
    .pq-ad-col { position: sticky; top: 64px; }
    .pq-ad-col__label { font-size: 0.7rem; color: #6c757d; text-align: center; margin-bottom: 0.4rem; letter-spacing: 0.04em; }
    .pq-ad-col ins.adsbygoogle { display: block; min-height: 600px; }
    @media (max-width: 980px) {
      .pq-layout { grid-template-columns: 1fr; }
      .pq-ad-col { position: static; order: 99; min-height: 100px; }
      .pq-ad-col ins.adsbygoogle { min-height: 100px; }
    }

    .pq-breadcrumb { list-style: none; padding: 0; margin: 0 0 0.5rem; display: flex; flex-wrap: wrap; font-size: 0.78rem; color: rgba(60,60,60,0.7); }
    .pq-breadcrumb li::after { content: "›"; margin: 0 0.4em; color: rgba(120,120,120,0.6); }
    .pq-breadcrumb li:last-child::after { content: ""; }
    .pq-breadcrumb a { color: inherit; text-decoration: none; }
    .pq-breadcrumb a:hover { text-decoration: underline; }

    .pq-bar { display: flex; align-items: center; justify-content: space-between; gap: 0.8rem; flex-wrap: wrap; margin-bottom: 0.7rem; padding-bottom: 0.6rem; border-bottom: 1px solid #e1e6ec; }
    .pq-title { font-size: 1.2rem; font-weight: 800; margin: 0; letter-spacing: 0.02em; color: #1f3a5c; }
    .pq-stats { display: flex; gap: 0.45rem; font-size: 0.85rem; flex-wrap: wrap; }
    .pq-stats .pq-stat { padding: 0.18em 0.7em; background: rgba(0,0,0,0.05); font-weight: 700; border-radius: 3px; }
    .pq-stat--correct { background: rgba(74,158,92,0.18); color: #2c6f3c; }
    .pq-stat--wrong   { background: rgba(192,57,43,0.13); color: #9a2d24; }
    .pq-stat--streak  { background: linear-gradient(135deg, rgba(249,115,22,0.22), rgba(234,88,12,0.15)); color: #c2410c; }
    .pq-stat--best    { background: rgba(124,58,237,0.13); color: #6b21a8; }

    .pq-progress { position: relative; display: flex; width: 100%; height: 8px; background: #eaf2fb; border: 1px solid #d6deea; margin: 0 0 0.7rem; overflow: hidden; }
    .pq-progress__fill { height: 100%; width: 0; transition: width 0.35s ease; }
    .pq-progress__fill--correct { background: #4a9e5c; }
    .pq-progress__fill--wrong { background: #d35a4d; }
    .pq-progress__count { position: absolute; top: 50%; right: 0.4em; transform: translateY(-50%); font-size: 0.62rem; font-weight: 700; color: #1f3a5c; background: rgba(255,255,255,0.85); padding: 0 0.4em; line-height: 1.4; pointer-events: none; }

    .pq-question { text-align: center; padding: 0.85rem 1rem; background: linear-gradient(135deg, rgba(31,77,128,0.10), rgba(31,77,128,0.04)); border: 1px solid #d6deea; margin-bottom: 0.8rem; transition: background 0.2s, border-color 0.2s; }
    .pq-prompt { font-size: 0.78rem; color: rgba(70,70,80,0.75); margin: 0 0 0.2rem; letter-spacing: 0.05em; }
    .pq-state-name { font-size: 1.55rem; font-weight: 800; letter-spacing: 0.02em; color: #1f3a5c; line-height: 1.2; }
    .pq-question.is-correct { background: rgba(74,158,92,0.16); border-color: rgba(74,158,92,0.6); }
    .pq-question.is-wrong { background: rgba(192,57,43,0.13); border-color: rgba(192,57,43,0.55); }
    .pq-feedback { margin-top: 0.45rem; font-size: 0.88rem; font-weight: 600; color: #9a2d24; letter-spacing: 0.02em; }
    .pq-feedback[hidden] { display: none; }
    .pq-feedback strong { font-weight: 800; color: #b13427; }

    .pq-map-wrap { position: relative; background: #f6f9fd; border: 1px solid #e1e6ec; padding: 0; height: min(70vh, 640px); overflow: hidden; }
    #pq-map { width: 100%; height: 100%; }
    #pq-map .leaflet-container { background: #eaf2fb; }
    /* Custom pin markers */
    .pq-pin { background: transparent; border: 0; }
    .pq-pin__dot {
      width: 14px;
      height: 14px;
      border-radius: 50%;
      background: #1f4d80;
      border: 2px solid #fff;
      box-shadow: 0 0 0 2px rgba(31, 77, 128, 0.35), 0 1px 3px rgba(0, 0, 0, 0.4);
      position: absolute;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
      cursor: pointer;
      transition: background 0.15s, box-shadow 0.15s, transform 0.15s;
    }
    .pq-pin__dot:hover {
      transform: translate(-50%, -50%) scale(1.18);
      box-shadow: 0 0 0 3px rgba(31, 77, 128, 0.45), 0 1px 4px rgba(0, 0, 0, 0.45);
    }
    .pq-pin.is-correct .pq-pin__dot,
    .pq-pin.is-correct .pq-pin__dot:hover {
      background: #4a9e5c;
      box-shadow: 0 0 0 3px rgba(74, 158, 92, 0.45), 0 1px 4px rgba(0, 0, 0, 0.45);
    }
    .pq-pin.is-wrong .pq-pin__dot,
    .pq-pin.is-wrong .pq-pin__dot:hover {
      background: #d35a4d;
      box-shadow: 0 0 0 3px rgba(192, 57, 43, 0.45), 0 1px 4px rgba(0, 0, 0, 0.45);
    }
    .pq-pin.is-reveal .pq-pin__dot,
    .pq-pin.is-reveal .pq-pin__dot:hover {
      background: #ffba50;
      box-shadow: 0 0 0 4px rgba(217, 119, 6, 0.55), 0 1px 4px rgba(0, 0, 0, 0.45);
      animation: pq-pulse 0.8s ease-in-out;
    }
    @keyframes pq-pulse {
      0%   { transform: translate(-50%, -50%) scale(1.0); }
      50%  { transform: translate(-50%, -50%) scale(1.6); }
      100% { transform: translate(-50%, -50%) scale(1.2); }
    }
    .pq-pin__label {
      position: absolute;
      left: 50%;
      top: calc(50% + 14px);
      transform: translateX(-50%);
      background: rgba(30, 58, 95, 0.92);
      color: #fff;
      padding: 2px 6px;
      border-radius: 3px;
      font-size: 11px;
      font-family: "Hiragino Sans", "Hiragino Kaku Gothic ProN", "Noto Sans JP", system-ui, sans-serif;
      white-space: nowrap;
      pointer-events: none;
      line-height: 1.3;
      box-shadow: 0 1px 2px rgba(0, 0, 0, 0.25);
      display: none;
    }
    /* Labels appear only for the currently revealed/answered pin. Memorize
       mode reveals names via hover (mouse) or tap (touch) in the question
       slot, similar to the SVG-based StateQuizPage. */
    .pq-pin.is-reveal .pq-pin__label,
    .pq-pin.is-correct .pq-pin__label,
    .pq-pin.is-wrong .pq-pin__label { display: block; }
    /* Slightly smaller pins so dense islands (Java has ~110) stay legible */
    .pq-pin__dot { width: 12px; height: 12px; }
    .pq-page.is-finished .pq-pin__dot { cursor: default; }

    .pq-actions { display: flex; gap: 0.5rem; margin-top: 0.7rem; justify-content: center; flex-wrap: wrap; }
    .pq-btn { background: #fff; color: #1f3a5c; border: 1px solid #d6deea; font-size: 0.85rem; font-weight: 700; padding: 0.45em 1.1em; cursor: pointer; transition: background 0.12s, border-color 0.12s; }
    .pq-btn:hover { background: #eef3f9; border-color: #1f4d80; }
    .pq-btn--primary { background: #1f4d80; color: #fff; border-color: #1f4d80; }
    .pq-btn--primary:hover { background: #163a63; }
    .pq-btn--memorize { border-color: #d6b878; color: #92670f; }
    .pq-btn--memorize:hover { background: #fff4dc; border-color: #c89f3d; }
    .pq-btn--memorize.is-active { background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); color: #fff; border-color: #d97706; box-shadow: 0 2px 6px rgba(217, 119, 6, 0.25); }

    .pq-question.is-memorize { background: linear-gradient(135deg, rgba(245,158,11,0.10), rgba(245,158,11,0.04)); border-color: rgba(245,158,11,0.45); }
    .pq-memorize-hint { font-size: 0.72rem; color: #6b7a8d; margin-top: 0.35rem; letter-spacing: 0.02em; display: none; }
    .pq-question.is-memorize .pq-memorize-hint { display: block; }

    .pq-content { margin-top: 1.6rem; padding-top: 1rem; border-top: 1px dashed #e1e6ec; font-size: 0.78rem; color: #4a5568; line-height: 1.75; }
    .pq-content__section + .pq-content__section { margin-top: 0.9rem; }
    .pq-content__title { font-size: 0.78rem; font-weight: 700; color: #1f3a5c; margin: 0 0 0.25rem; }
    .pq-content__names { color: #6b7a8d; word-break: break-word; }
    .pq-content__desc { color: #6b7a8d; margin: 0; }
    .pq-content__note { color: #8a7e62; background: #fff8e6; border-left: 3px solid #d6b878; padding: 0.6em 0.8em; margin-top: 0.6rem; font-size: 0.75rem; line-height: 1.6; }

    .pq-summary { text-align: center; padding: 1rem 1rem 1.2rem; background: #fff8e6; border: 1px solid #ffd082; margin-top: 0.8rem; }
    .pq-summary[hidden] { display: none; }
    .pq-summary__title { font-size: 1.3rem; font-weight: 800; color: #c97a18; margin: 0 0 0.4rem; }
    .pq-summary__line { font-size: 0.95rem; margin: 0.15rem 0; color: #7a4f10; }
    .pq-summary__line strong { color: #1f3a5c; font-size: 1.1em; }

    @media (max-width: 700px) {
      .pq-page { padding: 0.6rem 0.7rem 1rem; }
      .pq-title { font-size: 1.05rem; }
      .pq-state-name { font-size: 1.3rem; }
      .pq-stats { font-size: 0.78rem; gap: 0.3rem; }
      .pq-map-wrap { height: min(60vh, 520px); }
    }
  </style>
</head>
<body>
  <header class="shadow-bottom sticky-top bg-white">
    <Navbar lang={lang} isHome={false} />
  </header>

  <main>
    <div class="pq-page" id="pq-page">
      <ol class="pq-breadcrumb">
        {breadcrumbs.map((c, i) => (
          <li>{i === breadcrumbs.length - 1 ? c.name : <a href={c.url}>{c.name}</a>}</li>
        ))}
      </ol>

      <div class="pq-layout">
        <aside class="pq-ad-col" aria-label={t.ad.label}>
          <div class="pq-ad-col__label">{t.ad.label}</div>
          <ins class="adsbygoogle"
               style="display:block"
               data-ad-client="ca-pub-3422749596492644"
               data-ad-slot="1994726642"
               data-ad-format="auto"
               data-full-width-responsive="true"></ins>
          <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
        </aside>

        <div class="pq-content-col">
          <div class="pq-bar">
            <h1 class="pq-title">{pageH1}</h1>
            <div class="pq-stats">
              <span class="pq-stat pq-stat--streak">🔥 {t.scores.streak}: <span id="pq-streak">0</span></span>
              <span class="pq-stat pq-stat--best">🏆 {t.scores.best}: <span id="pq-best">0</span></span>
              <span class="pq-stat pq-stat--correct">{t.scores.correct} <span id="pq-correct">0</span></span>
              <span class="pq-stat pq-stat--wrong">{t.scores.wrong} <span id="pq-wrong">0</span></span>
              <span class="pq-stat">{t.scores.remaining} <span id="pq-remaining">{pins.length}</span></span>
            </div>
          </div>

          <div class="pq-progress" id="pq-progress" role="progressbar" aria-label={t.progress.ariaLabel} aria-valuemin="0" aria-valuemax={pins.length} aria-valuenow="0">
            <div class="pq-progress__fill pq-progress__fill--correct" id="pq-progress-correct"></div>
            <div class="pq-progress__fill pq-progress__fill--wrong" id="pq-progress-wrong"></div>
            <div class="pq-progress__count" id="pq-progress-count">0 / {pins.length}</div>
          </div>

          <div class="pq-question" id="pq-question">
            <div class="pq-prompt" id="pq-prompt">{prompt}</div>
            <div class="pq-state-name" id="pq-state-name">{t.question.loading}</div>
            <div class="pq-feedback" id="pq-feedback" hidden></div>
            <div class="pq-memorize-hint">{memorizeHint}</div>
          </div>

          <div class="pq-map-wrap">
            <div id="pq-map"
              data-pins={JSON.stringify(pins)}
              data-bbox={JSON.stringify(bbox)}
            ></div>
          </div>

          <div class="pq-actions">
            <button class="pq-btn" id="pq-skip" type="button">{t.buttons.skip}</button>
            <button class="pq-btn pq-btn--primary" id="pq-restart" type="button">{t.buttons.restart}</button>
            <button class="pq-btn pq-btn--memorize" id="pq-memorize" type="button" aria-pressed="false">{t.buttons.memorize}</button>
          </div>

          <div class="pq-summary" id="pq-summary" hidden>
            <div class="pq-summary__title" id="pq-summary-title-text">&nbsp;</div>
            <p class="pq-summary__line">{t.summary.correct}: <strong id="pq-summary-correct">0</strong></p>
            <p class="pq-summary__line">{t.summary.bestThisRound}: <strong id="pq-summary-best-this">0</strong> {t.summary.questionsSuffix}</p>
            <p class="pq-summary__line">{t.summary.bestAll}: <strong id="pq-summary-best-all">0</strong> {t.summary.questionsSuffix}</p>
          </div>

          <div class="pq-content" aria-label={contentTitle}>
            <section class="pq-content__section">
              <h2 class="pq-content__title">{contentTitle}</h2>
              <p class="pq-content__names">{seoNames}</p>
            </section>
            {lead && (
              <section class="pq-content__section">
                <p class="pq-content__desc" set:html={lead}></p>
              </section>
            )}
            <section class="pq-content__section">
              <p class="pq-content__desc">{seoDescription}</p>
            </section>
            <section class="pq-content__section">
              <p class="pq-content__note">{t.pinQuiz.note}</p>
            </section>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer lang={lang} title={pageH1} permalink={canonical} />
  <SearchModal lang={lang} />

  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

  <script is:inline define:vars={{ storageKey, prompt: prompt, jsLabels }}>
    (function () {
      const STORAGE_KEY = storageKey;
      const ADVANCE_OK = 600;
      const ADVANCE_NG = 1800;
      const DEFAULT_PROMPT = prompt;
      const LABELS = jsLabels;

      function $(id) { return document.getElementById(id); }

      function start() {
        if (typeof L === 'undefined') { setTimeout(start, 80); return; }
        const mapEl = $('pq-map');
        if (!mapEl) return;

        let pins = [];
        try { pins = JSON.parse(mapEl.getAttribute('data-pins') || '[]'); } catch (_) {}
        let bbox = [95, -11, 141, 6];
        try { bbox = JSON.parse(mapEl.getAttribute('data-bbox') || '[95,-11,141,6]'); } catch (_) {}

        const map = L.map(mapEl, { zoomControl: true, scrollWheelZoom: true });
        // light_nolabels = Carto Positron without place-name labels. Labels
        // would spoil the quiz by revealing the kabupaten/kota names on the
        // tile itself, so we use the labels-free variant here.
        L.tileLayer('https://{s}.basemaps.cartocdn.com/light_nolabels/{z}/{x}/{y}{r}.png', {
          attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
          subdomains: 'abcd',
          maxZoom: 19,
        }).addTo(map);

        // Set initial view from bbox
        const sw = L.latLng(bbox[1], bbox[0]);
        const ne = L.latLng(bbox[3], bbox[2]);
        map.fitBounds(L.latLngBounds(sw, ne).pad(0.08));

        // Build markers
        const markerByCode = Object.create(null);
        const codeToName = Object.create(null);
        const codeToShort = Object.create(null);
        const markers = [];
        pins.forEach(function (p) {
          codeToName[p.code] = p.name;
          codeToShort[p.code] = p.shortName;
          const html =
            '<div class="pq-pin__dot" data-code="' + p.code.replace(/"/g, '&quot;') + '"></div>' +
            '<div class="pq-pin__label">' + (p.shortName || p.name) + '</div>';
          const icon = L.divIcon({
            className: 'pq-pin',
            html: html,
            iconSize: [0, 0],
            iconAnchor: [0, 0],
          });
          const m = L.marker([p.lat, p.lng], { icon: icon, keyboard: false, riseOnHover: true });
          m.pq_code = p.code;
          m.addTo(map);
          markerByCode[p.code] = m;
          markers.push(m);
        });

        // ============ Quiz state ============
        function shuffle(arr) {
          const a = arr.slice();
          for (let i = a.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [a[i], a[j]] = [a[j], a[i]];
          }
          return a;
        }
        let queue = [];
        let index = 0;
        let correct = 0;
        let wrong = 0;
        let streak = 0;
        let bestThisRound = 0;
        let locked = false;
        let memorizeMode = false;
        let advanceTimer = null;

        const page = $('pq-page');
        const promptEl = $('pq-prompt');
        const stateNameEl = $('pq-state-name');
        const questionEl = $('pq-question');
        const feedbackEl = $('pq-feedback');
        const memorizeBtn = $('pq-memorize');
        const elStreak = $('pq-streak');
        const elBest = $('pq-best');
        const elCorrect = $('pq-correct');
        const elWrong = $('pq-wrong');
        const elRemaining = $('pq-remaining');
        const elProgress = $('pq-progress');
        const elProgressCorrect = $('pq-progress-correct');
        const elProgressWrong = $('pq-progress-wrong');
        const elProgressCount = $('pq-progress-count');
        const elSummary = $('pq-summary');
        const elSummaryTitle = $('pq-summary-title-text');
        const elSummaryCorrect = $('pq-summary-correct');
        const elSummaryBestThis = $('pq-summary-best-this');
        const elSummaryBestAll = $('pq-summary-best-all');

        function getBest() {
          const v = parseInt(localStorage.getItem(STORAGE_KEY) || '0', 10);
          return isNaN(v) ? 0 : v;
        }
        function setBest(v) { localStorage.setItem(STORAGE_KEY, String(v)); }
        let bestAllTime = getBest();
        elBest.textContent = String(bestAllTime);

        function clearPinClasses() {
          for (const m of markers) {
            const el = m.getElement();
            if (el) el.classList.remove('is-correct', 'is-wrong', 'is-reveal');
          }
        }
        function clearFeedback() {
          feedbackEl.hidden = true;
          feedbackEl.innerHTML = '';
        }
        function markPin(code, klass) {
          const m = markerByCode[code];
          if (!m) return;
          const el = m.getElement();
          if (el) el.classList.add(klass);
        }
        function showWrongFeedback(clickedCode) {
          const name = codeToName[clickedCode] || clickedCode;
          const safe = String(name).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
          feedbackEl.innerHTML = '✕ ' + LABELS.clicked + ' <strong>' + safe + '</strong>';
          feedbackEl.hidden = false;
        }
        function updateProgress() {
          const total = queue.length;
          if (!total) return;
          elProgressCorrect.style.width = ((correct / total) * 100) + '%';
          elProgressWrong.style.width = ((wrong / total) * 100) + '%';
          elProgressCount.textContent = (correct + wrong) + ' / ' + total;
          elProgress.setAttribute('aria-valuenow', String(correct + wrong));
        }
        function updateScores() {
          elCorrect.textContent = String(correct);
          elWrong.textContent = String(wrong);
          elStreak.textContent = String(streak);
          elBest.textContent = String(bestAllTime);
          updateProgress();
        }
        function recordAnswer(isCorrect) {
          if (isCorrect) {
            correct++;
            streak++;
            if (streak > bestThisRound) bestThisRound = streak;
            if (streak > bestAllTime) { bestAllTime = streak; setBest(bestAllTime); }
          } else {
            wrong++;
            streak = 0;
          }
          updateScores();
        }
        function showQuestion() {
          if (index >= queue.length) { finish(); return; }
          const q = queue[index];
          stateNameEl.textContent = q.name;
          questionEl.classList.remove('is-correct', 'is-wrong');
          clearPinClasses();
          clearFeedback();
          elRemaining.textContent = String(queue.length - index);
          locked = false;
        }
        function advance() { index++; showQuestion(); }
        function finish() {
          page.classList.add('is-finished');
          elSummaryTitle.textContent = LABELS.summaryTitleFmt.replace('{n}', String(queue.length));
          elSummaryCorrect.textContent = correct + ' / ' + queue.length;
          elSummaryBestThis.textContent = String(bestThisRound);
          elSummaryBestAll.textContent = String(bestAllTime);
          elSummary.hidden = false;
          stateNameEl.textContent = LABELS.finished;
          elRemaining.textContent = '0';
        }
        function skipCurrent() {
          if (locked) return;
          const q = queue[index];
          if (!q) return;
          locked = true;
          markPin(q.code, 'is-reveal');
          questionEl.classList.add('is-wrong');
          recordAnswer(false);
          advanceTimer = setTimeout(advance, ADVANCE_NG);
        }
        function restart() {
          if (advanceTimer) { clearTimeout(advanceTimer); advanceTimer = null; }
          memorizeMode = false;
          page.classList.remove('is-memorize', 'is-finished');
          memorizeBtn.classList.remove('is-active');
          memorizeBtn.setAttribute('aria-pressed', 'false');
          questionEl.classList.remove('is-memorize');
          promptEl.textContent = DEFAULT_PROMPT;
          queue = shuffle(pins);
          index = 0;
          correct = 0;
          wrong = 0;
          streak = 0;
          bestThisRound = 0;
          locked = false;
          elSummary.hidden = true;
          updateScores();
          showQuestion();
        }

        function showHoveredName(code) {
          const name = codeToName[code];
          stateNameEl.textContent = name || '—';
        }

        function handlePinClick(code) {
          if (memorizeMode) {
            // In memorize mode, click reveals the pin's name in the question
            // slot (useful on mobile where there's no hover).
            showHoveredName(code);
            return;
          }
          if (locked) return;
          const q = queue[index];
          if (!q) return;
          locked = true;
          if (code === q.code) {
            markPin(code, 'is-correct');
            questionEl.classList.add('is-correct');
            recordAnswer(true);
            advanceTimer = setTimeout(advance, ADVANCE_OK);
          } else {
            markPin(code, 'is-wrong');
            markPin(q.code, 'is-reveal');
            questionEl.classList.add('is-wrong');
            showWrongFeedback(code);
            recordAnswer(false);
            advanceTimer = setTimeout(advance, ADVANCE_NG);
          }
        }

        function bindPinEvents(m, el) {
          if (el._pqBound) return;
          el._pqBound = true;
          el.addEventListener('click', function (e) {
            e.stopPropagation();
            handlePinClick(m.pq_code);
          });
          el.addEventListener('mouseenter', function () {
            if (memorizeMode) showHoveredName(m.pq_code);
          });
        }
        for (const m of markers) {
          const el0 = m.getElement();
          if (el0) bindPinEvents(m, el0);
          else m.on('add', function () {
            const el = m.getElement();
            if (el) bindPinEvents(m, el);
          });
        }

        // ============ Memorize / study mode ============
        function setMemorize(on) {
          memorizeMode = !!on;
          memorizeBtn.classList.toggle('is-active', memorizeMode);
          memorizeBtn.setAttribute('aria-pressed', memorizeMode ? 'true' : 'false');
          page.classList.toggle('is-memorize', memorizeMode);
          if (memorizeMode) {
            if (advanceTimer) { clearTimeout(advanceTimer); advanceTimer = null; }
            questionEl.classList.add('is-memorize');
            questionEl.classList.remove('is-correct', 'is-wrong');
            clearPinClasses();
            clearFeedback();
            promptEl.textContent = LABELS.memorizePrompt;
            stateNameEl.textContent = LABELS.emptyName;
          } else {
            questionEl.classList.remove('is-memorize');
            promptEl.textContent = DEFAULT_PROMPT;
            if (page.classList.contains('is-finished')) {
              stateNameEl.textContent = LABELS.finished;
            } else {
              showQuestion();
            }
          }
        }

        $('pq-skip').addEventListener('click', skipCurrent);
        $('pq-restart').addEventListener('click', restart);
        memorizeBtn.addEventListener('click', function () { setMemorize(!memorizeMode); });

        restart();
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', start);
      } else {
        start();
      }
    })();
  </script>
</body>
</html>
