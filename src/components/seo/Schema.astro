---
import type { Language } from "@lib/i18n-utils";

interface BreadcrumbItem {
  name: string;
  url: string;
}

interface SectionChild {
  title: string;
  url: string;
  flag?: string;
}

interface Props {
  title: string;
  description: string;
  lang: Language;
  canonical: string;
  ogImage: string;
  ogType: "website" | "article";
  publishedTime?: Date;
  modifiedTime?: Date;
  flag?: string;
  pageData?: Record<string, any>;
  breadcrumbs?: BreadcrumbItem[];
  collection?: string;
  sectionChildren?: SectionChild[];
  autoVideoIds?: string[];
  ruleListItems?: string[];
}

const {
  title,
  description,
  lang,
  canonical,
  ogImage,
  ogType,
  publishedTime,
  modifiedTime,
  flag,
  pageData = {},
  breadcrumbs = [],
  collection = "",
  sectionChildren = [],
  autoVideoIds = [],
  ruleListItems = [],
} = Astro.props;

const site = "https://geopinning.space";
const siteTitle = "GeoGuessrの攻略めも";
const orgName = "nanja";
const orgUrl = site;
const orgLogo = `${site}/images/icon-512x512.png`;

const languageCodeMap: Record<Language, string> = {
  ja: "ja-JP", en: "en-US", id: "id", es: "es", pt: "pt",
};
const languageCode = languageCodeMap[lang] || "en-US";

const socialLinks = [
  "https://www.twitch.tv/nanjakorewa",
  "https://www.youtube.com/@nanjakorewa",
  "https://x.com/nanjakorewa",
  "https://github.com/nanjakorewa/GeoGuessrTips",
  "https://www.geoguessr.com/user/63c2671a563ddfcf1b8cda82",
];

// --- Organization schema ---
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: orgName,
  url: orgUrl,
  logo: { "@type": "ImageObject", url: orgLogo },
  sameAs: socialLinks,
};

// --- WebSite schema with SearchAction (sitelinks search box) ---
const websiteSchema: Record<string, any> = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteTitle,
  url: site,
  inLanguage: languageCode,
  description,
  sameAs: socialLinks,
  potentialAction: {
    "@type": "SearchAction",
    target: {
      "@type": "EntryPoint",
      urlTemplate: `${site}/?q={search_term_string}`,
    },
    "query-input": "required name=search_term_string",
  },
};

// --- Page/Article schema (enhanced) ---
const pageType = ogType === "article" ? "Article" : "WebPage";
const pageSchema: Record<string, any> = {
  "@context": "https://schema.org",
  "@type": pageType,
  name: title,
  headline: title,
  description,
  url: canonical,
  inLanguage: languageCode,
  mainEntityOfPage: { "@type": "WebPage", "@id": canonical },
  isPartOf: { "@type": "WebSite", name: siteTitle, url: site },
  author: { "@type": "Organization", name: orgName, url: orgUrl },
  publisher: {
    "@type": "Organization",
    name: orgName,
    url: orgUrl,
    logo: { "@type": "ImageObject", url: orgLogo },
  },
};
if (ogImage) pageSchema.image = [ogImage];
if (publishedTime && pageType === "Article") {
  pageSchema.datePublished = publishedTime.toISOString();
}
if (modifiedTime && pageType === "Article") {
  pageSchema.dateModified = modifiedTime.toISOString();
}
// articleSection from collection name
if (pageType === "Article" && collection) {
  const sectionNames: Record<string, Record<Language, string>> = {
    rule: { ja: "国と地域の判定", en: "Country & Region Guide", id: "Panduan Negara", es: "Guía de países", pt: "Guia de países" },
    quiz: { ja: "クイズ", en: "Quiz", id: "Kuis", es: "Quiz", pt: "Quiz" },
    about: { ja: "このサイトについて", en: "About", id: "Tentang", es: "Acerca de", pt: "Sobre" },
    web: { ja: "外部リソース", en: "External Resources", id: "Sumber Daya", es: "Recursos", pt: "Recursos" },
  };
  pageSchema.articleSection = sectionNames[collection]?.[lang] || collection;
}
// about: country entity for country pages
if (flag && pageData.title) {
  pageSchema.about = {
    "@type": "Country",
    name: pageData.title,
  };
}

// --- BreadcrumbList schema (using pre-resolved titles from layout) ---
let breadcrumbSchema: Record<string, any> | null = null;
if (breadcrumbs.length > 1) {
  breadcrumbSchema = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: breadcrumbs.map((item, i) => ({
      "@type": "ListItem",
      position: i + 1,
      name: item.name,
      item: `${site}${item.url}`,
    })),
  };
}

// --- FAQ Schema (consolidated: auto-generated + custom frontmatter) ---
let faqSchema: Record<string, any> | null = null;
const faqQuestions: Record<string, any>[] = [];

// Auto-generated FAQ for country pages (using rule-list summary)
if (flag) {
  const countryName = pageData.title || title;
  const questionTemplates: Record<Language, string> = {
    ja: `GeoGuessrで${countryName}を見分けるには？`,
    en: `How to identify ${countryName} in GeoGuessr?`,
    id: `Bagaimana cara mengenali ${countryName} di GeoGuessr?`,
    es: `¿Cómo identificar ${countryName} en GeoGuessr?`,
    pt: `Como identificar ${countryName} no GeoGuessr?`,
  };
  // Prefer rule-list items as answer, fall back to description
  const answerText = ruleListItems.length > 0
    ? ruleListItems.map((item) => `- ${item}`).join("\n")
    : description || "";
  if (answerText) {
    faqQuestions.push({
      "@type": "Question",
      name: questionTemplates[lang],
      acceptedAnswer: { "@type": "Answer", text: answerText },
    });
  }
}

// Custom FAQ from frontmatter (merged into same FAQPage)
if (pageData.faq && Array.isArray(pageData.faq)) {
  for (const f of pageData.faq) {
    if (f.question && f.answer) {
      faqQuestions.push({
        "@type": "Question",
        name: f.question.trim(),
        acceptedAnswer: { "@type": "Answer", text: f.answer.trim() },
      });
    }
  }
}

if (faqQuestions.length > 0) {
  faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqQuestions,
  };
}

// --- HowTo Schema (auto for country pages with flag) ---
let howtoSchema: Record<string, any> | null = null;
if (flag) {
  const countryName = pageData.title || title;
  const howtoNames: Record<Language, string> = {
    ja: `GeoGuessrで${countryName}を見分ける方法`,
    en: `How to identify ${countryName} in GeoGuessr`,
    id: `Cara mengenali ${countryName} di GeoGuessr`,
    es: `Cómo identificar ${countryName} en GeoGuessr`,
    pt: `Como identificar ${countryName} no GeoGuessr`,
  };
  const stepsMap: Record<Language, string[]> = {
    ja: ["ストリートビューの風景を観察する", "看板、標識、言語などの特徴を確認する", "地形や植生から地域を絞り込む"],
    en: ["Observe the Street View landscape", "Check signs, road markers, and language", "Narrow down the region from terrain and vegetation"],
    id: ["Amati pemandangan Street View", "Periksa rambu, penanda jalan, dan bahasa", "Persempit wilayah dari medan dan vegetasi"],
    es: ["Observa el paisaje de Street View", "Comprueba señales, marcadores viales e idioma", "Reduce la región según el terreno y la vegetación"],
    pt: ["Observe a paisagem do Street View", "Verifique placas, sinalizações e idioma", "Restrinja a região pelo terreno e vegetação"],
  };
  const steps = stepsMap[lang] || stepsMap.en;
  howtoSchema = {
    "@context": "https://schema.org",
    "@type": "HowTo",
    name: howtoNames[lang],
    description,
    step: steps.map((text, i) => ({
      "@type": "HowToStep",
      position: i + 1,
      name: text,
      text,
    })),
  };
  if (ogImage) howtoSchema.image = ogImage;
}

// --- VideoObject Schema from frontmatter ---
let videoSchemas: Record<string, any>[] = [];
if (pageData.videos && Array.isArray(pageData.videos)) {
  for (const v of pageData.videos) {
    const vid = v.id || "";
    const isShort = v.short || false;
    const embedUrl = v.embedUrl || (vid ? `https://www.youtube.com/embed/${vid}` : "");
    const contentUrl = v.contentUrl || (vid
      ? (isShort ? `https://www.youtube.com/shorts/${vid}` : `https://www.youtube.com/watch?v=${vid}`)
      : "");
    const thumbnailUrl = v.thumbnailUrl || (vid ? `https://i.ytimg.com/vi/${vid}/hqdefault.jpg` : "");
    if (v.title && v.description && v.uploadDate && thumbnailUrl && embedUrl && contentUrl) {
      videoSchemas.push({
        "@type": "VideoObject",
        name: v.title,
        description: v.description,
        thumbnailUrl: [thumbnailUrl],
        uploadDate: v.uploadDate,
        embedUrl,
        contentUrl,
      });
    }
  }
}

// Auto-generate VideoObject from extracted YouTube IDs (if no manual videos defined)
if (videoSchemas.length === 0 && autoVideoIds.length > 0) {
  const uploadDate = publishedTime
    ? publishedTime.toISOString().split("T")[0]
    : modifiedTime
      ? modifiedTime.toISOString().split("T")[0]
      : "";
  if (uploadDate) {
    for (const vid of autoVideoIds) {
      videoSchemas.push({
        "@type": "VideoObject",
        name: title,
        description,
        thumbnailUrl: [`https://i.ytimg.com/vi/${vid}/hqdefault.jpg`],
        uploadDate,
        embedUrl: `https://www.youtube.com/embed/${vid}`,
        contentUrl: `https://www.youtube.com/watch?v=${vid}`,
      });
    }
  }
}

// --- ItemList Schema for section/index pages (country listings) ---
let itemListSchema: Record<string, any> | null = null;
if (sectionChildren.length > 0) {
  itemListSchema = {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: title,
    numberOfItems: sectionChildren.length,
    itemListElement: sectionChildren.map((child, i) => ({
      "@type": "ListItem",
      position: i + 1,
      name: child.title,
      url: `${site}${child.url}`,
      ...(child.flag ? { image: `${site}/flags/${child.flag}` } : {}),
    })),
  };
}
---

<script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />
{breadcrumbSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
)}
{faqSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
)}
{howtoSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(howtoSchema)} />
)}
{videoSchemas.length === 1 && (
  <script type="application/ld+json" set:html={JSON.stringify({ "@context": "https://schema.org", ...videoSchemas[0] })} />
)}
{videoSchemas.length > 1 && (
  <script type="application/ld+json" set:html={JSON.stringify({ "@context": "https://schema.org", "@graph": videoSchemas })} />
)}
{itemListSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
)}
