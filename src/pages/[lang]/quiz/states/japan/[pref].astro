---
/**
 * Japan prefecture quiz (non-default lang): /[lang]/quiz/states/japan/{pref}/
 */
import { getCollection } from "astro:content";
import StateQuizPage from "@components/StateQuizPage.astro";
import {
  buildPrefectureQuizProps,
  NON_DEFAULT_LANGUAGES,
} from "../../../../../data/quiz-states-page-data";
import type { Language } from "@lib/i18n-utils";

export async function getStaticPaths() {
  const allRules = await getCollection("rule");
  const prefs = allRules.filter(
    (e: any) =>
      /^asia\/japan\/[^/]+\/[^/]+\/_index\.ja$/.test(e.id) &&
      (e.data as any).is_pref === true &&
      !!(e.data as any).municipalities,
  );
  const paths: any[] = [];
  for (const lang of NON_DEFAULT_LANGUAGES) {
    for (const p of prefs) {
      const seg = p.id.split("/");
      paths.push({
        params: { lang, pref: seg[3] },
        props: {
          lang,
          dir: seg[3],
          region: seg[2],
          munis: (p.data as any).municipalities,
        },
      });
    }
  }
  return paths;
}

const { lang, dir, region, munis } = Astro.props as {
  lang: Language;
  dir: string;
  region: string;
  munis: any;
};
const allRules = await getCollection("rule");
const props = buildPrefectureQuizProps(
  lang,
  dir,
  region,
  munis,
  allRules.map((e: any) => ({ id: e.id, data: e.data })),
);
---
<StateQuizPage {...props} />
