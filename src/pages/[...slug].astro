---
import DefaultLayout from "@layouts/DefaultLayout.astro";
import QuizLayout from "@layouts/QuizLayout.astro";
import QuizIndexLayout from "@layouts/QuizIndexLayout.astro";
import QuizHubLayout from "@layouts/QuizHubLayout.astro";
import { getCollection, render } from "astro:content";
import { extractLangFromId, extractSlugFromId, buildUrl } from "@lib/i18n-utils";

export async function getStaticPaths() {
  const allCollections = ["rule", "quiz", "about", "web"] as const;
  const paths = [];

  for (const collectionName of allCollections) {
    const entries = await getCollection(collectionName, (entry) => {
      return extractLangFromId(entry.id) === "ja" && !entry.data.draft;
    });

    for (const entry of entries) {
      const slug = extractSlugFromId(entry.id);
      const fullSlug = slug ? `${collectionName}/${slug}` : collectionName;

      paths.push({
        params: { slug: fullSlug },
        props: { entry, lang: "ja" as const, collection: collectionName },
      });
    }
  }

  return paths;
}

const { entry, lang, collection } = Astro.props;
const rendered = await render(entry);
const Content = rendered.Content;
const bodyText = (entry.body ?? "").trim();
const hasContent = bodyText.length > 0;
const useQuizLayout = entry.data.pagetype === "quiz";
const useQuizIndexLayout = entry.data.pagetype === "quiz-index";
const useQuizHubLayout = entry.data.pagetype === "quiz-hub";
---

{useQuizHubLayout ? (
  <QuizHubLayout entry={entry} lang={lang} collection={collection} hasContent={hasContent}>
    <Content />
  </QuizHubLayout>
) : useQuizIndexLayout ? (
  <QuizIndexLayout entry={entry} lang={lang} collection={collection} hasContent={hasContent}>
    <Content />
  </QuizIndexLayout>
) : useQuizLayout ? (
  <QuizLayout entry={entry} lang={lang} collection={collection} hasContent={hasContent}>
    <Content />
  </QuizLayout>
) : (
  <DefaultLayout entry={entry} lang={lang} collection={collection} hasContent={hasContent}>
    <Content />
  </DefaultLayout>
)}
