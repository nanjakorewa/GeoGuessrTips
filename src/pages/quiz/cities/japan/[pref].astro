---
/**
 * Japan prefecture quiz (default lang): /quiz/cities/japan/{pref}/
 */
import { getCollection } from "astro:content";
import StateQuizPage from "@components/StateQuizPage.astro";
import { buildPrefectureQuizProps } from "../../../../data/quiz-states-page-data";
import type { Language } from "@lib/i18n-utils";

export async function getStaticPaths() {
  const allRules = await getCollection("rule");
  const prefs = allRules.filter(
    (e: any) =>
      /^asia\/japan\/[^/]+\/[^/]+\/_index\.ja$/.test(e.id) &&
      (e.data as any).is_pref === true &&
      !!(e.data as any).municipalities,
  );
  return prefs.map((p: any) => {
    const seg = p.id.split("/");
    return {
      params: { pref: seg[3] },
      props: { dir: seg[3], region: seg[2], munis: (p.data as any).municipalities },
    };
  });
}

const lang: Language = "ja";
const { dir, region, munis } = Astro.props as {
  dir: string;
  region: string;
  munis: any;
};
const allRules = await getCollection("rule");
const props = buildPrefectureQuizProps(
  lang,
  dir,
  region,
  munis,
  allRules.map((e: any) => ({ id: e.id, data: e.data })),
);
---
<StateQuizPage {...props} />
