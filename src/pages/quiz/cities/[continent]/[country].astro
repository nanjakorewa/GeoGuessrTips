---
/**
 * City quiz (default lang JA): /quiz/cities/{continent}/{country}/
 *
 * Thin wrapper around <CityQuizPage>; the shared component handles all
 * rendering and JS. Non-default languages use the parallel route at
 * /[lang]/quiz/cities/{continent}/{country}/.
 */
import fs from "node:fs";
import path from "node:path";
import { getCollection } from "astro:content";
import CityQuizPage from "@components/CityQuizPage.astro";
import { CITY_QUIZ_REGISTRY } from "../../../../data/quiz-cities-registry";
import { buildCityQuizRelatedLinks } from "../../../../data/quiz-states-page-data";

export async function getStaticPaths() {
  return Object.entries(CITY_QUIZ_REGISTRY).map(([slug, data]) => ({
    params: { continent: data.meta.continent, country: slug },
    props: {
      slug,
      cityList: data.cities,
      projection: data.projection,
      meta: data.meta,
    },
  }));
}

const { slug, cityList, projection, meta } = Astro.props as {
  slug: string;
  cityList: any[];
  projection: any;
  meta: any;
};

const svgFsPath = path.join(
  process.cwd(),
  "public",
  meta.svgPath.replace(/^\/+/, ""),
);
const svgRaw = fs.readFileSync(svgFsPath, "utf8");

const allRules = await getCollection("rule");
const relatedLinks = buildCityQuizRelatedLinks(
  "ja",
  { continent: meta.continent, slug: meta.slug },
  allRules.map((e: any) => ({ id: e.id, data: e.data })),
);
---

<CityQuizPage lang="ja" slug={slug} cityList={cityList} projection={projection} meta={meta} svgRaw={svgRaw} relatedLinks={relatedLinks} />
