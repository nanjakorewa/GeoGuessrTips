---
/**
 * Dynamic city quiz: /quiz/cities/{continent}/{country}/
 *
 * Mechanic: map shows pins for the country's major cities. One pin is
 * highlighted in orange (current question); the user picks the matching
 * city name from cards below.
 *
 * Features:
 *  - Pin radius scales with population (sqrt-based, capped 4–11)
 *  - Difficulty toggle (簡単/普通/難しい) filters the city pool by tier
 *  - Hint mode highlights 5 candidate cards (including the correct one)
 *  - Memorize mode: hover/tap on a pin or card cross-highlights its pair
 *  - SEO content table at the bottom grouped by tier
 */
import fs from "node:fs";
import path from "node:path";
import Head from "@components/seo/Head.astro";
import Navbar from "@components/navigation/Navbar.astro";
import Footer from "@components/footer/Footer.astro";
import SearchModal from "@components/search/SearchModal.astro";
import type { Language } from "@lib/i18n-utils";
import {
  CITY_QUIZ_REGISTRY,
  projectCity,
} from "../../../../data/quiz-cities-registry";
import { tierForRank, MAX_CITIES_PER_COUNTRY } from "../../../../data/quiz-cities/_types";

export async function getStaticPaths() {
  return Object.entries(CITY_QUIZ_REGISTRY).map(([slug, data]) => ({
    params: { continent: data.meta.continent, country: slug },
    props: { slug, ...data },
  }));
}

const { slug, cities: cityList, projection, meta } = Astro.props as any;

const lang: Language = "ja";
const site = "https://geopinning.space";
const pageTitle = `${meta.countryJa}の主要都市クイズ｜マップ上のピンに対応する都市を選ぼう`;
const pageDescription = `${meta.countryJa}の主要都市を、地図上でハイライトされたピンに対応する都市名カードを選んで当てるクイズ。位置と名前の暗記学習に。`;
const canonical = `${site}/quiz/cities/${meta.continent}/${meta.slug}/`;

// Rank by population (descending). Largest = rank 0 = tier 1.
// Cap at MAX_CITIES_PER_COUNTRY so the hardest tier has a reasonable size.
const rankedCityList = [...cityList]
  .sort((a: any, b: any) => (b.pop || 0) - (a.pop || 0))
  .slice(0, MAX_CITIES_PER_COUNTRY);
const maxPop = Math.max(...rankedCityList.map((c: any) => c.pop || 1), 1);

// Pin radius: sqrt-scaled in [4, 11].
function pinRadius(pop: number): number {
  if (!pop) return 4;
  const t = Math.sqrt(pop / maxPop);
  return Math.round((4 + t * 7) * 10) / 10;
}

// Project each city onto SVG viewBox coords + assign tier + radius.
const cities = rankedCityList.map((c: any, idx: number) => {
  const { x, y } = projectCity(c.lng, c.lat, projection);
  const tier = tierForRank(idx);
  return { ...c, x, y, tier, r: pinRadius(c.pop || 0) };
});

// Inline SVG and inject pin circles. Radius determined by population.
const svgFsPath = path.join(
  process.cwd(),
  "public",
  meta.svgPath.replace(/^\/+/, ""),
);
const svgRaw = fs.readFileSync(svgFsPath, "utf8");
const inlinedSvg = (() => {
  const body = svgRaw
    .replace(/<\?xml[^?]*\?>\s*/, "")
    .replace(/<svg\b/, '<svg id="cq-map"');
  const pinsMarkup =
    `\n  <g class="cq-pins">\n` +
    cities
      .map(
        (c: any) =>
          `    <circle class="cq-pin" data-id="${c.id}" data-name="${c.nameJa}" data-tier="${c.tier}" data-r="${c.r}" cx="${c.x.toFixed(2)}" cy="${c.y.toFixed(2)}" r="${c.r}"><title>${c.nameJa} (${c.nameEn})</title></circle>`,
      )
      .join("\n") +
    `\n  </g>\n`;
  return body.replace(/<\/svg>\s*$/, pinsMarkup + "</svg>");
})();

const jsCities = cities.map((c: any) => ({
  id: c.id,
  name: c.nameJa,
  sub: c.nameEn,
  tier: c.tier,
  pop: c.pop,
}));
const jsLabels = {
  loading: "読み込み中…",
  finished: "終了！",
  emptyName: "—",
  promptDefault: "オレンジ色のピンに対応する都市は？",
  promptDefaultSub: "下のカードから選んでください",
  promptMemorize: "暗記モード",
  promptMemorizeSub: "ピンまたはカードにカーソルを合わせると（スマホはタップ）対応するものがハイライトされます",
  promptHint: "ヒント有モード",
  promptHintSub: "ハイライトされている5つのカードから選んでください",
  correctPrefix: "正解: ",
  summaryTitleFmt: "🎉 全 {n} 問終了",
};

const breadcrumbs = [
  { name: "トップ", url: "/" },
  { name: "クイズ", url: "/quiz/" },
  { name: "都市当てクイズ", url: "/quiz/cities/" },
  { name: meta.countryJa, url: canonical.replace(site, "") },
];

// Group cities by tier for the SEO table.
const byTier = {
  1: cities.filter((c: any) => c.tier === 1),
  2: cities.filter((c: any) => c.tier === 2),
  3: cities.filter((c: any) => c.tier === 3),
};
const TIER_LABELS: Record<number, string> = {
  1: "簡単（人口上位20）",
  2: "普通（人口20〜50位）",
  3: "難しい（人口50位以下）",
};
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <Head
    title={pageTitle}
    description={pageDescription}
    lang={lang}
    canonical={canonical}
    ogImage={`${site}/images/icon-512x512.png`}
    ogType="website"
    breadcrumbs={breadcrumbs}
    collection="quiz"
  />
  <style is:global>
    html, body { min-height: 100vh; }
    body { overflow-x: hidden; display: flex; flex-direction: column; }
    body > header { flex: 0 0 auto; }
    body > main { flex: 1 0 auto; }
    body > .site-footer, body > footer { flex: 0 0 auto; margin-top: 0; }

    .cq-page { max-width: 1320px; margin: 0 auto; padding: 0.8rem 1rem 1.2rem; }
    .cq-layout {
      display: grid;
      grid-template-columns: 200px minmax(0, 1fr);
      gap: 1.1rem;
      align-items: start;
    }
    .cq-ad-col { position: sticky; top: 64px; }
    .cq-ad-col__label {
      font-size: 0.7rem; color: #6c757d; text-align: center;
      margin-bottom: 0.4rem; letter-spacing: 0.04em;
    }
    .cq-ad-col ins.adsbygoogle { display: block; min-height: 600px; }
    @media (max-width: 980px) {
      .cq-layout { grid-template-columns: 1fr; }
      .cq-ad-col { position: static; order: 99; min-height: 100px; }
      .cq-ad-col ins.adsbygoogle { min-height: 100px; }
    }

    .cq-breadcrumb {
      list-style: none; padding: 0; margin: 0 0 0.5rem 0;
      display: flex; flex-wrap: wrap;
      font-size: 0.78rem; color: rgba(60,60,60,0.7);
    }
    .cq-breadcrumb li::after { content: "›"; margin: 0 0.4em; color: rgba(120,120,120,0.6); }
    .cq-breadcrumb li:last-child::after { content: ""; }
    .cq-breadcrumb a { color: inherit; text-decoration: none; }
    .cq-breadcrumb a:hover { text-decoration: underline; }

    .cq-bar {
      display: flex; align-items: center; justify-content: space-between;
      gap: 0.8rem; flex-wrap: wrap;
      margin-bottom: 0.7rem; padding-bottom: 0.6rem;
      border-bottom: 1px solid #e1e6ec;
    }
    .cq-title { font-size: 1.2rem; font-weight: 800; margin: 0; color: #1f3a5c; }
    .cq-stats { display: flex; gap: 0.45rem; font-size: 0.85rem; flex-wrap: wrap; }
    .cq-stats .cq-stat {
      padding: 0.18em 0.7em; background: rgba(0,0,0,0.05);
      font-weight: 700; border-radius: 3px;
    }
    .cq-stat--correct { background: rgba(74,158,92,0.18); color: #2c6f3c; }
    .cq-stat--wrong   { background: rgba(192,57,43,0.13); color: #9a2d24; }
    .cq-stat--streak  {
      background: linear-gradient(135deg, rgba(249,115,22,0.22), rgba(234,88,12,0.15));
      color: #c2410c;
    }
    .cq-stat--best { background: rgba(124,58,237,0.13); color: #6b21a8; }

    /* Difficulty + hint toolbar (above the prompt) */
    .cq-toolbar {
      display: flex;
      gap: 0.6rem;
      align-items: center;
      flex-wrap: wrap;
      margin-bottom: 0.6rem;
      font-size: 0.82rem;
    }
    .cq-toolbar__label {
      font-weight: 700;
      color: #1f3a5c;
      letter-spacing: 0.02em;
    }
    .cq-diff-group {
      display: inline-flex;
      border: 1px solid #d6deea;
      overflow: hidden;
    }
    .cq-diff-btn {
      background: #fff;
      color: #4a5568;
      border: 0;
      border-right: 1px solid #d6deea;
      padding: 0.3em 0.8em;
      cursor: pointer;
      font-weight: 600;
      transition: background 0.12s, color 0.12s;
    }
    .cq-diff-btn:last-child { border-right: 0; }
    .cq-diff-btn:hover { background: #eef3f9; }
    .cq-diff-btn.is-active {
      background: #1f4d80;
      color: #fff;
    }

    .cq-progress {
      position: relative; display: flex;
      width: 100%; height: 8px;
      background: #eaf2fb; border: 1px solid #d6deea;
      margin: 0 0 0.7rem; overflow: hidden;
    }
    .cq-progress__fill { height: 100%; width: 0; transition: width 0.35s ease; }
    .cq-progress__fill--correct { background: #4a9e5c; }
    .cq-progress__fill--wrong   { background: #d35a4d; }
    .cq-progress__count {
      position: absolute; top: 50%; right: 0.4em;
      transform: translateY(-50%);
      font-size: 0.62rem; font-weight: 700; color: #1f3a5c;
      background: rgba(255,255,255,0.85);
      padding: 0 0.4em; line-height: 1.4;
      pointer-events: none;
    }

    .cq-prompt-row {
      text-align: center;
      padding: 0.7rem 1rem 0.8rem;
      background: linear-gradient(135deg, rgba(31,77,128,0.10), rgba(31,77,128,0.04));
      border: 1px solid #d6deea;
      margin-bottom: 0.8rem;
    }
    .cq-prompt-row.is-memorize {
      background: linear-gradient(135deg, rgba(245,158,11,0.10), rgba(245,158,11,0.04));
      border-color: rgba(245,158,11,0.45);
    }
    .cq-prompt-row.is-hint {
      background: linear-gradient(135deg, rgba(74,158,92,0.10), rgba(74,158,92,0.04));
      border-color: rgba(74,158,92,0.45);
    }
    .cq-prompt {
      font-size: 0.78rem; color: rgba(70,70,80,0.75);
      margin: 0 0 0.15rem; letter-spacing: 0.05em;
    }
    .cq-prompt-sub { font-size: 1rem; color: #1f3a5c; font-weight: 700; }

    .cq-map-wrap {
      position: relative;
      background: #f6f9fd;
      border: 1px solid #e1e6ec;
      padding: 10px;
    }
    #cq-map { display: block; width: 100%; height: auto; max-height: 70vh; }
    #cq-map path {
      fill: #eaf2fb;
      stroke: #5b7fa8;
      stroke-width: 0.6;
    }
    .cq-pin {
      fill: #5b7fa8;
      stroke: #fff;
      stroke-width: 1.2;
      transition: fill 0.18s, stroke 0.18s, r 0.18s;
    }
    .cq-pin.is-hidden { display: none; }
    .cq-pin.is-active {
      fill: #f59e0b;
      stroke: #fff;
      stroke-width: 1.8;
      r: 12 !important;
      animation: cq-pulse 1.1s ease-in-out infinite;
    }
    @keyframes cq-pulse {
      0%   { opacity: 1; }
      50%  { opacity: 0.6; }
      100% { opacity: 1; }
    }
    .cq-pin.is-correct { fill: #4a9e5c; stroke: #fff; stroke-width: 1.5; animation: none; }
    .cq-pin.is-wrong   { fill: #d35a4d; stroke: #fff; stroke-width: 1.5; animation: none; }
    .cq-pin.is-done    { fill: #b6c1cf; stroke: #fff; }
    .cq-pin.is-preview { fill: #f59e0b; stroke: #fff; stroke-width: 1.5; animation: none; }
    .cq-map-wrap.is-memorize .cq-pin { cursor: pointer; }

    .cq-cards {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      gap: 0.4rem;
      margin-top: 0.9rem;
    }
    .cq-card {
      background: #fff;
      border: 1px solid #d6deea;
      color: #1f3a5c;
      font-weight: 600;
      font-size: 0.85rem;
      padding: 0.4rem 0.6rem 0.45rem;
      cursor: pointer;
      text-align: center;
      transition: background 0.12s, border-color 0.12s, transform 0.1s, opacity 0.2s;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.05em;
      line-height: 1.25;
    }
    .cq-card.is-hidden { display: none; }
    .cq-card__name { font-size: 0.88rem; font-weight: 700; }
    .cq-card__sub {
      font-size: 0.62rem; font-weight: 400;
      color: #6b7a8d; letter-spacing: 0.01em;
    }
    .cq-card:hover { background: #eef3f9; border-color: #1f4d80; }
    .cq-card:active { transform: translateY(1px); }
    .cq-card.is-correct { background: #4a9e5c; color: #fff; border-color: #2c6f3c; cursor: default; }
    .cq-card.is-wrong   { background: #d35a4d; color: #fff; border-color: #9a2d24; animation: cq-shake 0.35s ease-in-out; }
    .cq-card.is-done    { background: #f3f5f8; color: #9ca8b8; border-color: #e1e6ec; pointer-events: none; }
    .cq-card.is-reveal  {
      background: #ffd082; color: #7a4f10; border-color: #c97a18;
      animation: cq-reveal-flash 0.7s ease-in-out;
    }
    .cq-card.is-preview {
      background: #fff4dc;
      border-color: #c89f3d;
      color: #92670f;
    }
    /* Hint mode: non-candidate cards dimmed; candidate cards glow green */
    .cq-cards.is-hint .cq-card:not(.is-candidate):not(.is-done) { opacity: 0.4; }
    .cq-card.is-candidate {
      border: 2px solid #4a9e5c;
      box-shadow: 0 0 0 1px rgba(74,158,92,0.25);
    }
    .cq-card.is-correct .cq-card__sub,
    .cq-card.is-wrong .cq-card__sub { color: rgba(255,255,255,0.82); }
    .cq-card.is-reveal .cq-card__sub { color: rgba(122,79,16,0.82); }
    .cq-card.is-done .cq-card__sub { color: #b6c1cf; }
    @keyframes cq-shake {
      0%, 100% { transform: translateX(0); }
      25% { transform: translateX(-4px); }
      75% { transform: translateX(4px); }
    }
    @keyframes cq-reveal-flash {
      0%   { background: #ffd082; }
      50%  { background: #ffba50; }
      100% { background: #ffd082; }
    }

    .cq-actions {
      display: flex; gap: 0.5rem;
      margin-top: 0.7rem;
      justify-content: center;
      flex-wrap: wrap;
    }
    .cq-btn {
      background: #fff;
      color: #1f3a5c;
      border: 1px solid #d6deea;
      font-size: 0.85rem;
      font-weight: 700;
      padding: 0.45em 1.1em;
      cursor: pointer;
      transition: background 0.12s, border-color 0.12s;
    }
    .cq-btn:hover { background: #eef3f9; border-color: #1f4d80; }
    .cq-btn--primary { background: #1f4d80; color: #fff; border-color: #1f4d80; }
    .cq-btn--primary:hover { background: #163a63; }
    .cq-btn--memorize { border-color: #d6b878; color: #92670f; }
    .cq-btn--memorize:hover { background: #fff4dc; border-color: #c89f3d; }
    .cq-btn--memorize.is-active {
      background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
      color: #fff; border-color: #d97706;
    }
    .cq-btn--hint { border-color: #a8d2b1; color: #2c6f3c; }
    .cq-btn--hint:hover { background: #eff7f1; border-color: #4a9e5c; }
    .cq-btn--hint.is-active {
      background: linear-gradient(135deg, #4a9e5c 0%, #2c6f3c 100%);
      color: #fff; border-color: #2c6f3c;
    }

    .cq-summary {
      text-align: center;
      padding: 1rem 1rem 1.2rem;
      background: #fff8e6;
      border: 1px solid #ffd082;
      margin-top: 0.8rem;
    }
    .cq-summary[hidden] { display: none; }
    .cq-summary__title { font-size: 1.3rem; font-weight: 800; color: #c97a18; margin: 0 0 0.4rem; }
    .cq-summary__line { font-size: 0.95rem; margin: 0.15rem 0; color: #7a4f10; }
    .cq-summary__line strong { color: #1f3a5c; font-size: 1.1em; }

    /* SEO content table */
    .cq-content {
      margin-top: 1.6rem;
      padding-top: 1rem;
      border-top: 1px dashed #e1e6ec;
      font-size: 0.82rem;
      color: #4a5568;
      line-height: 1.55;
    }
    .cq-content__title {
      font-size: 0.95rem; font-weight: 700; color: #1f3a5c;
      margin: 0 0 0.5rem;
    }
    .cq-content__desc { color: #6b7a8d; margin: 0 0 1rem; font-size: 0.78rem; line-height: 1.7; }
    .cq-tier-group { margin-bottom: 1rem; }
    .cq-tier-group__label {
      display: inline-block;
      font-weight: 700;
      color: #1f4d80;
      font-size: 0.78rem;
      margin: 0 0 0.35rem;
      padding: 0.15em 0.5em;
      background: rgba(31, 77, 128, 0.08);
      border-radius: 3px;
    }
    .cq-tier-group__label--easy   { color: #2c6f3c; background: rgba(74,158,92,0.10); }
    .cq-tier-group__label--normal { color: #c2410c; background: rgba(234,88,12,0.10); }
    .cq-tier-group__label--hard   { color: #9a2d24; background: rgba(192,57,43,0.10); }
    .cq-city-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.78rem;
    }
    .cq-city-table th,
    .cq-city-table td {
      padding: 0.3em 0.55em;
      text-align: left;
      border-bottom: 1px solid #eaf0f6;
    }
    .cq-city-table th {
      font-weight: 700;
      color: #1f3a5c;
      background: #f6f9fd;
      font-size: 0.72rem;
    }
    .cq-city-table td:first-child { font-weight: 600; color: #1f3a5c; }
    .cq-city-table td:nth-child(2) { color: #4a5568; font-size: 0.72rem; }
    .cq-city-table td.cq-pop { text-align: right; color: #6b7a8d; font-variant-numeric: tabular-nums; }

    @media (max-width: 700px) {
      .cq-page { padding: 0.6rem 0.7rem 1rem; }
      .cq-title { font-size: 1.05rem; }
      .cq-stats { font-size: 0.78rem; gap: 0.3rem; }
      .cq-city-table { font-size: 0.72rem; }
    }
  </style>
</head>
<body>
  <header class="shadow-bottom sticky-top bg-white">
    <Navbar lang={lang} isHome={false} />
  </header>

  <main>
    <div class="cq-page" id="cq-page">
      <ol class="cq-breadcrumb">
        {breadcrumbs.map((c, i) => (
          <li>{i === breadcrumbs.length - 1 ? c.name : <a href={c.url}>{c.name}</a>}</li>
        ))}
      </ol>

      <div class="cq-layout">
        <aside class="cq-ad-col" aria-label="広告">
          <div class="cq-ad-col__label">広告</div>
          <ins class="adsbygoogle"
               style="display:block"
               data-ad-client="ca-pub-3422749596492644"
               data-ad-slot="1994726642"
               data-ad-format="auto"
               data-full-width-responsive="true"></ins>
          <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
        </aside>

        <div class="cq-content-col">
          <div class="cq-bar">
            <h1 class="cq-title">{meta.countryJa}の主要都市クイズ</h1>
            <div class="cq-stats">
              <span class="cq-stat cq-stat--streak">🔥 連続: <span id="cq-streak">0</span></span>
              <span class="cq-stat cq-stat--best">🏆 最高: <span id="cq-best">0</span></span>
              <span class="cq-stat cq-stat--correct">○ <span id="cq-correct">0</span></span>
              <span class="cq-stat cq-stat--wrong">✕ <span id="cq-wrong">0</span></span>
              <span class="cq-stat">残り <span id="cq-remaining">{cities.length}</span></span>
            </div>
          </div>

          <div class="cq-toolbar">
            <span class="cq-toolbar__label">難易度</span>
            <div class="cq-diff-group" role="group" aria-label="難易度">
              <button class="cq-diff-btn" type="button" data-diff="easy">簡単 ({byTier[1].length})</button>
              <button class="cq-diff-btn is-active" type="button" data-diff="normal">普通 ({byTier[1].length + byTier[2].length})</button>
              <button class="cq-diff-btn" type="button" data-diff="hard">難しい ({cities.length})</button>
            </div>
          </div>

          <div class="cq-progress" id="cq-progress" role="progressbar" aria-label="進捗" aria-valuemin="0" aria-valuemax={cities.length} aria-valuenow="0">
            <div class="cq-progress__fill cq-progress__fill--correct" id="cq-progress-correct"></div>
            <div class="cq-progress__fill cq-progress__fill--wrong" id="cq-progress-wrong"></div>
            <div class="cq-progress__count" id="cq-progress-count">0 / {cities.length}</div>
          </div>

          <div class="cq-prompt-row is-hint" id="cq-prompt-row">
            <div class="cq-prompt" id="cq-prompt">ヒント有モード</div>
            <div class="cq-prompt-sub" id="cq-prompt-sub">ハイライトされている5つのカードから選んでください</div>
          </div>

          <div class="cq-map-wrap" id="cq-map-wrap">
            <Fragment set:html={inlinedSvg} />
          </div>

          <div class="cq-cards is-hint" id="cq-cards">
            {cities.map((c: any) => (
              <button class="cq-card" type="button" data-id={c.id} data-tier={c.tier}>
                <span class="cq-card__name">{c.nameJa}</span>
                <span class="cq-card__sub" lang="en">{c.nameEn}</span>
              </button>
            ))}
          </div>

          <div class="cq-actions">
            <button class="cq-btn" id="cq-skip" type="button">スキップ</button>
            <button class="cq-btn cq-btn--primary" id="cq-restart" type="button">最初から</button>
            <button class="cq-btn cq-btn--memorize" id="cq-memorize" type="button" aria-pressed="false">暗記モード</button>
            <button class="cq-btn cq-btn--hint is-active" id="cq-hint" type="button" aria-pressed="true">ヒント有</button>
          </div>

          <div class="cq-summary" id="cq-summary" hidden>
            <div class="cq-summary__title" id="cq-summary-title-text">&nbsp;</div>
            <p class="cq-summary__line">正解: <strong id="cq-summary-correct">0</strong></p>
            <p class="cq-summary__line">最高連続正解: <strong id="cq-summary-best-this">0</strong> 問</p>
            <p class="cq-summary__line">通算ベスト: <strong id="cq-summary-best-all">0</strong> 問</p>
          </div>

          <div class="cq-content">
            <h2 class="cq-content__title">このクイズで出題される{meta.countryJa}の都市 ({cities.length})</h2>
            <p class="cq-content__desc">
              都市は人口によって難易度別にグループ分けされています。難易度「簡単」では人口上位 {byTier[1].length} 都市、「普通」では上位 {byTier[1].length + byTier[2].length} 都市、「難しい」では全 {cities.length} 都市（最大100）から出題されます。地図上のピンの大きさは人口に比例しています。
            </p>
            {[1, 2, 3].map((tier) => byTier[tier as 1 | 2 | 3].length > 0 && (
              <div class="cq-tier-group">
                <div class:list={["cq-tier-group__label", {
                  "cq-tier-group__label--easy": tier === 1,
                  "cq-tier-group__label--normal": tier === 2,
                  "cq-tier-group__label--hard": tier === 3,
                }]}>{TIER_LABELS[tier]}</div>
                <table class="cq-city-table">
                  <thead>
                    <tr>
                      <th>都市名</th>
                      <th>英語表記</th>
                      <th class="cq-pop">人口 (千人)</th>
                    </tr>
                  </thead>
                  <tbody>
                    {byTier[tier as 1 | 2 | 3].map((c: any) => (
                      <tr>
                        <td>{c.nameJa}</td>
                        <td lang="en">{c.nameEn}</td>
                        <td class="cq-pop">{(c.pop || 0).toLocaleString()}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer lang={lang} title={`${meta.countryJa}の主要都市クイズ`} permalink={canonical} />
  <SearchModal lang={lang} />

  <script is:inline define:vars={{ cities: jsCities, jsLabels, storageKey: `cq-best:${slug}` }}>
    (function () {
      const STORAGE_KEY = storageKey;
      const ADVANCE_OK = 550;
      const ADVANCE_NG = 1700;
      const LABELS = jsLabels;
      const HINT_CANDIDATE_COUNT = 5;

      const $ = (id) => document.getElementById(id);
      const page = $("cq-page");
      const cardsEl = $("cq-cards");
      const promptRow = $("cq-prompt-row");
      const promptEl = $("cq-prompt");
      const promptSubEl = $("cq-prompt-sub");
      const elStreak = $("cq-streak");
      const elBest = $("cq-best");
      const elCorrect = $("cq-correct");
      const elWrong = $("cq-wrong");
      const elRemaining = $("cq-remaining");
      const elProgress = $("cq-progress");
      const elProgressCorrect = $("cq-progress-correct");
      const elProgressWrong = $("cq-progress-wrong");
      const elProgressCount = $("cq-progress-count");
      const elSummary = $("cq-summary");
      const elSummaryTitle = $("cq-summary-title-text");
      const elSummaryCorrect = $("cq-summary-correct");
      const elSummaryBestThis = $("cq-summary-best-this");
      const elSummaryBestAll = $("cq-summary-best-all");
      const map = $("cq-map");
      const mapWrap = $("cq-map-wrap");
      const memorizeBtn = $("cq-memorize");
      const hintBtn = $("cq-hint");

      const pinByCode = {};
      map.querySelectorAll(".cq-pin").forEach((p) => {
        pinByCode[p.getAttribute("data-id")] = p;
      });
      const cardByCode = {};
      cardsEl.querySelectorAll(".cq-card").forEach((c) => {
        cardByCode[c.getAttribute("data-id")] = c;
      });
      const idToName = Object.create(null);
      const idToSub = Object.create(null);
      const idToTier = Object.create(null);
      cities.forEach((c) => {
        idToName[c.id] = c.name;
        idToTier[c.id] = c.tier;
        if (c.sub) idToSub[c.id] = c.sub;
      });
      function fullName(id) {
        const j = idToName[id] || id;
        const s = idToSub[id];
        return s ? j + " (" + s + ")" : j;
      }

      function shuffle(arr) {
        const a = arr.slice();
        for (let i = a.length - 1; i > 0; i--) {
          const j = Math.floor(Math.random() * (i + 1));
          [a[i], a[j]] = [a[j], a[i]];
        }
        return a;
      }

      // ===== State =====
      let queue = [];
      let index = 0;
      let correct = 0;
      let wrong = 0;
      let streak = 0;
      let bestThisRound = 0;
      let lastAdvanceTimer = null;
      let locked = false;
      let memorizeMode = false;
      let hintMode = true; // default-on
      let difficulty = "normal"; // "easy" | "normal" | "hard"

      function getBest() {
        const v = parseInt(localStorage.getItem(STORAGE_KEY) || "0", 10);
        return isNaN(v) ? 0 : v;
      }
      function setBest(v) { localStorage.setItem(STORAGE_KEY, String(v)); }
      let bestAllTime = getBest();
      elBest.textContent = String(bestAllTime);

      // ===== Difficulty filter =====
      function maxTier() {
        return difficulty === "easy" ? 1 : difficulty === "normal" ? 2 : 3;
      }
      function isInPool(id) { return idToTier[id] <= maxTier(); }
      function activePoolIds() {
        return cities.filter((c) => c.tier <= maxTier()).map((c) => c.id);
      }
      function applyDifficultyVisibility() {
        const limit = maxTier();
        Object.values(pinByCode).forEach((p) => {
          const tier = parseInt(p.getAttribute("data-tier") || "3", 10);
          p.classList.toggle("is-hidden", tier > limit);
        });
        Object.values(cardByCode).forEach((c) => {
          const tier = parseInt(c.getAttribute("data-tier") || "3", 10);
          c.classList.toggle("is-hidden", tier > limit);
        });
      }

      // ===== Progress / score =====
      function updateProgress() {
        const total = queue.length;
        if (!total) return;
        const correctPct = (correct / total) * 100;
        const wrongPct = (wrong / total) * 100;
        if (elProgressCorrect) elProgressCorrect.style.width = correctPct + "%";
        if (elProgressWrong) elProgressWrong.style.width = wrongPct + "%";
        if (elProgressCount) elProgressCount.textContent = (correct + wrong) + " / " + total;
        if (elProgress) elProgress.setAttribute("aria-valuenow", String(correct + wrong));
      }
      function updateScores() {
        elCorrect.textContent = String(correct);
        elWrong.textContent = String(wrong);
        elStreak.textContent = String(streak);
        elBest.textContent = String(bestAllTime);
        updateProgress();
      }
      function recordAnswer(isCorrect) {
        if (isCorrect) {
          correct++;
          streak++;
          if (streak > bestThisRound) bestThisRound = streak;
          if (streak > bestAllTime) { bestAllTime = streak; setBest(bestAllTime); }
        } else {
          wrong++;
          streak = 0;
        }
        updateScores();
      }

      function clearActivePin() {
        Object.values(pinByCode).forEach((p) => p.classList.remove("is-active"));
      }
      function clearAllPreviews() {
        Object.values(pinByCode).forEach((p) => p.classList.remove("is-preview"));
        Object.values(cardByCode).forEach((c) => c.classList.remove("is-preview"));
      }
      function clearCardFeedback() {
        cardsEl.querySelectorAll(".cq-card.is-wrong, .cq-card.is-reveal").forEach((c) => {
          c.classList.remove("is-wrong", "is-reveal");
        });
      }
      function clearHintHighlight() {
        cardsEl.querySelectorAll(".cq-card.is-candidate").forEach((c) => c.classList.remove("is-candidate"));
      }
      function applyHintForCurrent() {
        clearHintHighlight();
        if (!hintMode) return;
        const q = queue[index];
        if (!q) return;
        const pool = activePoolIds().filter((id) => id !== q && !cardByCode[id].classList.contains("is-done"));
        const distractors = shuffle(pool).slice(0, HINT_CANDIDATE_COUNT - 1);
        const candidates = shuffle([q, ...distractors]);
        candidates.forEach((id) => {
          if (cardByCode[id]) cardByCode[id].classList.add("is-candidate");
        });
      }

      function showQuestion() {
        if (index >= queue.length) { finish(); return; }
        const q = queue[index];
        clearActivePin();
        clearCardFeedback();
        clearHintHighlight();
        const pin = pinByCode[q];
        if (pin) {
          pin.classList.remove("is-correct", "is-wrong");
          pin.classList.add("is-active");
        }
        elRemaining.textContent = String(queue.length - index);
        if (hintMode) {
          if (promptEl) promptEl.textContent = LABELS.promptHint;
          if (promptSubEl) promptSubEl.textContent = LABELS.promptHintSub;
          applyHintForCurrent();
        } else {
          if (promptEl) promptEl.textContent = LABELS.promptDefault;
          if (promptSubEl) promptSubEl.textContent = LABELS.promptDefaultSub;
        }
        locked = false;
      }
      function markDone(id, isCorrect) {
        const pin = pinByCode[id];
        const card = cardByCode[id];
        if (pin) {
          pin.classList.remove("is-active");
          pin.classList.add(isCorrect ? "is-correct" : "is-wrong");
          setTimeout(() => {
            pin.classList.remove("is-correct", "is-wrong");
            pin.classList.add("is-done");
          }, isCorrect ? ADVANCE_OK : ADVANCE_NG);
        }
        if (card) {
          if (isCorrect) {
            card.classList.add("is-correct");
            setTimeout(() => {
              card.classList.remove("is-correct", "is-candidate");
              card.classList.add("is-done");
            }, ADVANCE_OK);
          } else {
            setTimeout(() => {
              card.classList.add("is-done");
              card.classList.remove("is-candidate");
            }, ADVANCE_NG);
          }
        }
      }
      function advance() { index++; showQuestion(); }

      // ===== Memorize mode =====
      function setMemorizeMode(on) {
        memorizeMode = !!on;
        if (memorizeBtn) {
          memorizeBtn.classList.toggle("is-active", memorizeMode);
          memorizeBtn.setAttribute("aria-pressed", memorizeMode ? "true" : "false");
        }
        if (mapWrap) mapWrap.classList.toggle("is-memorize", memorizeMode);
        promptRow.classList.toggle("is-memorize", memorizeMode);
        promptRow.classList.toggle("is-hint", hintMode && !memorizeMode);
        if (memorizeMode) {
          if (lastAdvanceTimer) { clearTimeout(lastAdvanceTimer); lastAdvanceTimer = null; }
          clearActivePin();
          clearAllPreviews();
          clearCardFeedback();
          clearHintHighlight();
          if (promptEl) promptEl.textContent = LABELS.promptMemorize;
          if (promptSubEl) promptSubEl.textContent = LABELS.promptMemorizeSub;
        } else {
          clearAllPreviews();
          if (page.classList.contains("is-finished")) {
            if (promptSubEl) promptSubEl.textContent = LABELS.finished;
          } else {
            const q = queue[index];
            if (q && pinByCode[q] && !cardByCode[q].classList.contains("is-done")) {
              pinByCode[q].classList.add("is-active");
            }
            if (hintMode) {
              if (promptEl) promptEl.textContent = LABELS.promptHint;
              if (promptSubEl) promptSubEl.textContent = LABELS.promptHintSub;
              applyHintForCurrent();
            } else {
              if (promptEl) promptEl.textContent = LABELS.promptDefault;
              if (promptSubEl) promptSubEl.textContent = LABELS.promptDefaultSub;
            }
          }
        }
      }
      function toggleMemorize() { setMemorizeMode(!memorizeMode); }

      // ===== Hint mode =====
      function setHintMode(on) {
        hintMode = !!on;
        if (hintBtn) {
          hintBtn.classList.toggle("is-active", hintMode);
          hintBtn.setAttribute("aria-pressed", hintMode ? "true" : "false");
        }
        cardsEl.classList.toggle("is-hint", hintMode);
        promptRow.classList.toggle("is-hint", hintMode && !memorizeMode);
        if (memorizeMode) return; // memorize already overrides prompt
        if (hintMode) {
          if (promptEl) promptEl.textContent = LABELS.promptHint;
          if (promptSubEl) promptSubEl.textContent = LABELS.promptHintSub;
          applyHintForCurrent();
        } else {
          clearHintHighlight();
          if (promptEl) promptEl.textContent = LABELS.promptDefault;
          if (promptSubEl) promptSubEl.textContent = LABELS.promptDefaultSub;
        }
      }
      function toggleHint() { setHintMode(!hintMode); }

      // ===== Memorize hover/tap =====
      function previewByCode(code) {
        clearAllPreviews();
        const pin = pinByCode[code];
        const card = cardByCode[code];
        if (pin) pin.classList.add("is-preview");
        if (card) card.classList.add("is-preview");
      }
      map.addEventListener("mouseover", (e) => {
        if (!memorizeMode) return;
        const pin = e.target.closest && e.target.closest(".cq-pin");
        if (pin) previewByCode(pin.getAttribute("data-id"));
      });
      map.addEventListener("mouseout", (e) => {
        if (!memorizeMode) return;
        const related = e.relatedTarget;
        if (!related || !related.closest || !related.closest(".cq-pin")) {
          clearAllPreviews();
        }
      });
      map.addEventListener("click", (e) => {
        if (!memorizeMode) return;
        const pin = e.target.closest && e.target.closest(".cq-pin");
        if (pin) previewByCode(pin.getAttribute("data-id"));
      });
      cardsEl.addEventListener("mouseover", (e) => {
        if (!memorizeMode) return;
        const card = e.target.closest && e.target.closest(".cq-card");
        if (card) previewByCode(card.getAttribute("data-id"));
      });
      cardsEl.addEventListener("mouseout", (e) => {
        if (!memorizeMode) return;
        const related = e.relatedTarget;
        if (!related || !related.closest || !related.closest(".cq-card")) {
          clearAllPreviews();
        }
      });

      // ===== Card click =====
      function handleCardClick(e) {
        const card = e.target.closest(".cq-card");
        if (!card) return;
        if (memorizeMode) {
          previewByCode(card.getAttribute("data-id"));
          return;
        }
        if (locked) return;
        if (card.classList.contains("is-done") || card.classList.contains("is-hidden")) return;
        const clicked = card.getAttribute("data-id");
        const q = queue[index];
        if (!q) return;

        locked = true;
        if (clicked === q) {
          card.classList.add("is-correct");
          recordAnswer(true);
          markDone(q, true);
          lastAdvanceTimer = setTimeout(advance, ADVANCE_OK);
        } else {
          card.classList.add("is-wrong");
          const correctCard = cardByCode[q];
          if (correctCard) correctCard.classList.add("is-reveal");
          if (promptSubEl) promptSubEl.textContent = LABELS.correctPrefix + fullName(q);
          recordAnswer(false);
          markDone(q, false);
          lastAdvanceTimer = setTimeout(advance, ADVANCE_NG);
        }
      }

      function skipCurrent() {
        if (memorizeMode) return;
        if (locked) return;
        const q = queue[index];
        if (!q) return;
        locked = true;
        const correctCard = cardByCode[q];
        if (correctCard) correctCard.classList.add("is-reveal");
        if (promptSubEl) promptSubEl.textContent = LABELS.correctPrefix + fullName(q);
        recordAnswer(false);
        markDone(q, false);
        lastAdvanceTimer = setTimeout(advance, ADVANCE_NG);
      }

      function finish() {
        page.classList.add("is-finished");
        if (elSummaryTitle) {
          elSummaryTitle.textContent = LABELS.summaryTitleFmt.replace("{n}", String(queue.length));
        }
        elSummaryCorrect.textContent = correct + " / " + queue.length;
        elSummaryBestThis.textContent = String(bestThisRound);
        elSummaryBestAll.textContent = String(bestAllTime);
        elSummary.hidden = false;
        if (promptSubEl) promptSubEl.textContent = LABELS.finished;
        elRemaining.textContent = "0";
        clearActivePin();
        clearHintHighlight();
      }

      function restart() {
        if (lastAdvanceTimer) { clearTimeout(lastAdvanceTimer); lastAdvanceTimer = null; }
        if (memorizeMode) setMemorizeMode(false);
        const pool = activePoolIds();
        queue = shuffle(pool);
        // Update aria-valuemax based on the active pool
        if (elProgress) elProgress.setAttribute("aria-valuemax", String(queue.length));
        index = 0;
        correct = 0;
        wrong = 0;
        streak = 0;
        bestThisRound = 0;
        locked = false;
        page.classList.remove("is-finished");
        elSummary.hidden = true;
        Object.values(pinByCode).forEach((p) => {
          p.classList.remove("is-active", "is-correct", "is-wrong", "is-done", "is-preview");
        });
        Object.values(cardByCode).forEach((c) => {
          c.classList.remove("is-correct", "is-wrong", "is-reveal", "is-done", "is-preview", "is-candidate");
        });
        applyDifficultyVisibility();
        updateScores();
        showQuestion();
      }

      // ===== Difficulty button =====
      document.querySelectorAll(".cq-diff-btn").forEach((btn) => {
        btn.addEventListener("click", () => {
          const d = btn.getAttribute("data-diff");
          if (!d || d === difficulty) return;
          difficulty = d;
          document.querySelectorAll(".cq-diff-btn").forEach((b) => {
            b.classList.toggle("is-active", b === btn);
          });
          restart();
        });
      });

      cardsEl.addEventListener("click", handleCardClick);
      $("cq-skip").addEventListener("click", skipCurrent);
      $("cq-restart").addEventListener("click", restart);
      if (memorizeBtn) memorizeBtn.addEventListener("click", toggleMemorize);
      if (hintBtn) hintBtn.addEventListener("click", toggleHint);
      restart();
    })();
  </script>
</body>
</html>
