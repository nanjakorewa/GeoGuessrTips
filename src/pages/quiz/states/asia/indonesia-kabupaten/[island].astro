---
/**
 * Per-island kabupaten / kota quiz (default JA).
 *
 * Generates one page per major Indonesian island group (7 total). Loads the
 * kabupaten list from src/data/quiz-indonesia-kabupaten.* and renders a
 * Leaflet pin-quiz via <PinQuizPage>. The label under each pin includes the
 * province so users learn the kabupaten ↔ province association as well.
 */
import PinQuizPage from "@components/PinQuizPage.astro";
import { ISLANDS, buildKabupatenIslandProps, type IslandData } from "../../../../../data/quiz-indonesia-kabupaten";

export async function getStaticPaths() {
  return ISLANDS
    .filter((p) => p.kabs.length > 0 && p.bbox)
    .map((p) => ({ params: { island: p.slug }, props: { isle: p } }));
}

const { isle } = Astro.props as { isle: IslandData };
const props = buildKabupatenIslandProps("ja", isle);
---

<PinQuizPage {...props} />
