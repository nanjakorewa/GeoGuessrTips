---
/**
 * Country quiz (default lang): /quiz/states/{continent}/{country}/
 */
import { getCollection } from "astro:content";
import StateQuizPage from "@components/StateQuizPage.astro";
import { COUNTRIES } from "../../../../data/quiz-states-countries";
import { buildCountryQuizProps } from "../../../../data/quiz-states-page-data";
import type { Language } from "@lib/i18n-utils";

export async function getStaticPaths() {
  const allRules = await getCollection("rule");
  const ruleById = new Map(allRules.map((e: any) => [e.id, e]));

  return COUNTRIES.map((c) => {
    const ruleId = `${c.pageDir}/_index.ja`;
    const entry: any = ruleById.get(ruleId);
    if (!entry) {
      throw new Error(`Quiz country ${c.slug}: missing rule entry ${ruleId}`);
    }
    const munis = entry.data.municipalities;
    if (!munis) {
      throw new Error(`Quiz country ${c.slug}: rule entry has no municipalities`);
    }
    return {
      params: { continent: c.continent, country: c.slug },
      props: { slug: c.slug, continent: c.continent, pageDir: c.pageDir, munis },
    };
  });
}

const lang: Language = "ja";
const { slug, continent, pageDir, munis } = Astro.props as {
  slug: string;
  continent: string;
  pageDir: string;
  munis: any;
};
const allRules = await getCollection("rule");
const props = buildCountryQuizProps(
  lang,
  { slug, continent, pageDir },
  munis,
  allRules.map((e: any) => ({ id: e.id, data: e.data })),
);
---
<StateQuizPage {...props} />
