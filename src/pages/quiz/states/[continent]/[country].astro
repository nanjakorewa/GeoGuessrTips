---
/**
 * Dynamic country quiz: /quiz/states/{continent}/{country}/
 *
 * One page per entry in COUNTRIES (~37 pages). Quiz data comes from the
 * country's rule entry frontmatter (`municipalities` block) and the SVG
 * generated by scripts/build-country-maps.cjs.
 */
import fs from "node:fs";
import path from "node:path";
import { getCollection } from "astro:content";
import StateQuizPage from "@components/StateQuizPage.astro";
import { COUNTRIES, CONTINENT_BY_SLUG } from "../../../../data/quiz-states-countries";

export async function getStaticPaths() {
  const allRules = await getCollection("rule");
  const ruleById = new Map(allRules.map((e: any) => [e.id, e]));

  return COUNTRIES.map((c) => {
    const ruleId = `${c.pageDir}/_index.ja`;
    const entry: any = ruleById.get(ruleId);
    if (!entry) {
      throw new Error(`Quiz country ${c.slug}: missing rule entry ${ruleId}`);
    }
    const munis = entry.data.municipalities;
    if (!munis) {
      throw new Error(`Quiz country ${c.slug}: rule entry has no municipalities block`);
    }
    return {
      params: { continent: c.continent, country: c.slug },
      props: {
        slug: c.slug,
        continent: c.continent,
        ja: c.ja,
        munis,
      },
    };
  });
}

const { slug, continent, ja, munis } = Astro.props as {
  slug: string;
  continent: string;
  ja: string;
  munis: { svg: string; list: { code: string; name: string }[] };
};

// Read the SVG file and inline it (with the id="sq-map" the quiz JS expects).
const svgFsPath = path.join(process.cwd(), "public", munis.svg.replace(/^\/+/, ""));
const svgRaw = fs.readFileSync(svgFsPath, "utf8");
const codesInSvg = new Set(
  Array.from(svgRaw.matchAll(/data-code="([^"]+)"/g), (m) => m[1])
);
const inlinedSvg = svgRaw
  .replace(/<\?xml[^?]*\?>\s*/, "")
  .replace(/<svg\b/, '<svg id="sq-map"');

// Quiz pool: only items whose code appears in the SVG (handles excluded
// outlying territories such as USA's Alaska/Hawaii).
const quizStates = munis.list
  .filter((s) => codesInSvg.has(s.code))
  .map((s) => ({ code: s.code, name: s.name }));

const continentMeta = CONTINENT_BY_SLUG[continent];
const continentJa = continentMeta?.ja ?? continent;

const site = "https://geopinning.space";
const canonical = `${site}/quiz/states/${continent}/${slug}/`;

const breadcrumbs = [
  { name: "トップ", url: "/" },
  { name: "クイズ", url: "/quiz/" },
  { name: "州当てクイズ", url: "/quiz/states/" },
  { name: continentJa, url: `/quiz/states/${continent}/` },
  { name: ja, url: `/quiz/states/${continent}/${slug}/` },
];
---
<StateQuizPage
  pageTitle={`${ja}の州当てクイズ｜地図で正しい場所をクリック`}
  pageDescription={`${ja}の州・地域・行政区分を地図上で当てるクイズ。連続正解の最高記録に挑戦しよう。`}
  canonical={canonical}
  pageH1={`${ja}の州当てクイズ`}
  prompt="この州・地域はどこ？"
  storageKey={`sq-best:${slug}`}
  breadcrumbs={breadcrumbs}
  quizStates={quizStates}
  inlinedSvg={inlinedSvg}
/>
