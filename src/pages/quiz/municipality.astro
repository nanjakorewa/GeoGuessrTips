---
import Head from "@components/seo/Head.astro";
import Navbar from "@components/navigation/Navbar.astro";
import Footer from "@components/footer/Footer.astro";
import SearchModal from "@components/search/SearchModal.astro";
import municipalitiesData from "../../data/municipalities.json";

const lang = "ja" as const;
const site = "https://geopinning.space";
const pageTitle = "自治体クイズ｜都道府県を当てよう";
const pageDescription =
  "ランダムに出題される市町村・特別区がどの都道府県にあるかを当てるクイズ。同名の自治体が複数県にある場合は、すべて選べると正解、一部のみだと△になります。";
const canonical = `${site}/quiz/municipality/`;

const PREFECTURES: { name: string; region: string }[] = [
  { name: "北海道", region: "北海道" },
  { name: "青森県", region: "東北" },
  { name: "岩手県", region: "東北" },
  { name: "宮城県", region: "東北" },
  { name: "秋田県", region: "東北" },
  { name: "山形県", region: "東北" },
  { name: "福島県", region: "東北" },
  { name: "茨城県", region: "関東" },
  { name: "栃木県", region: "関東" },
  { name: "群馬県", region: "関東" },
  { name: "埼玉県", region: "関東" },
  { name: "千葉県", region: "関東" },
  { name: "東京都", region: "関東" },
  { name: "神奈川県", region: "関東" },
  { name: "新潟県", region: "中部" },
  { name: "富山県", region: "中部" },
  { name: "石川県", region: "中部" },
  { name: "福井県", region: "中部" },
  { name: "山梨県", region: "中部" },
  { name: "長野県", region: "中部" },
  { name: "岐阜県", region: "中部" },
  { name: "静岡県", region: "中部" },
  { name: "愛知県", region: "中部" },
  { name: "三重県", region: "近畿" },
  { name: "滋賀県", region: "近畿" },
  { name: "京都府", region: "近畿" },
  { name: "大阪府", region: "近畿" },
  { name: "兵庫県", region: "近畿" },
  { name: "奈良県", region: "近畿" },
  { name: "和歌山県", region: "近畿" },
  { name: "鳥取県", region: "中国" },
  { name: "島根県", region: "中国" },
  { name: "岡山県", region: "中国" },
  { name: "広島県", region: "中国" },
  { name: "山口県", region: "中国" },
  { name: "徳島県", region: "四国" },
  { name: "香川県", region: "四国" },
  { name: "愛媛県", region: "四国" },
  { name: "高知県", region: "四国" },
  { name: "福岡県", region: "九州" },
  { name: "佐賀県", region: "九州" },
  { name: "長崎県", region: "九州" },
  { name: "熊本県", region: "九州" },
  { name: "大分県", region: "九州" },
  { name: "宮崎県", region: "九州" },
  { name: "鹿児島県", region: "九州" },
  { name: "沖縄県", region: "九州" },
];

const totalEntries = Object.values(municipalitiesData).reduce(
  (acc, prs: string[]) => acc + prs.length,
  0,
);

const REGIONS = ["北海道", "東北", "関東", "中部", "近畿", "中国", "四国", "九州"];

const crumbs = [
  { name: "トップ", url: "/" },
  { name: "クイズ", url: "/quiz/" },
  { name: "自治体クイズ", url: "/quiz/municipality/" },
];
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <Head
    title={pageTitle}
    description={pageDescription}
    lang={lang}
    canonical={canonical}
    ogImage={`${site}/images/icon-512x512.png`}
    ogType="website"
    breadcrumbs={crumbs}
    collection="quiz"
  />
  <style is:global>
    /* `is:global` because the history list items are created via
       document.createElement at runtime — Astro's default scoping applies
       a hash attribute to template-rendered elements only, so JS-created
       elements would otherwise miss every rule below. All class names are
       prefixed `mq-` to avoid collisions with the rest of the site. */
    /* Page chrome adjustments: keep the quiz in one viewport. */
    /* Sticky-footer flex layout so the footer always sits at the bottom of
       the viewport when content is shorter than the screen — otherwise the
       body background shows below the footer as empty space. */
    html, body { min-height: 100vh; }
    body {
      overflow-x: hidden;
      display: flex;
      flex-direction: column;
    }
    body > header { flex: 0 0 auto; }
    body > main { flex: 1 0 auto; }
    body > .site-footer,
    body > footer { flex: 0 0 auto; margin-top: 0; }

    .mq-page {
      max-width: 980px;
      margin: 0 auto;
      padding: 0.6rem 0.9rem 0.8rem;
    }

    /* Header row: title + stats on a single line */
    .mq-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.8rem;
      flex-wrap: wrap;
      margin-bottom: 0.6rem;
    }
    .mq-title {
      font-size: 1.15rem;
      font-weight: 800;
      margin: 0;
      letter-spacing: 0.02em;
    }
    .mq-title-sub {
      font-size: 0.78rem;
      color: rgba(100,100,100,0.7);
      margin-left: 0.5rem;
      font-weight: 500;
    }
    .mq-stats {
      display: flex;
      gap: 0.4rem;
      font-size: 0.82rem;
      flex-wrap: wrap;
    }
    .mq-stats span {
      padding: 0.18em 0.65em;
      background: rgba(0,0,0,0.05);
      font-weight: 600;
    }
    .mq-stats .mq-correct { background: rgba(74,158,92,0.15); color: #2c6f3c; }
    .mq-stats .mq-partial { background: rgba(196,154,42,0.18); color: #8a6614; }
    .mq-stats .mq-wrong   { background: rgba(192,57,43,0.13); color: #9a2d24; }
    .mq-stats .mq-streak  {
      background: linear-gradient(135deg, rgba(249,115,22,0.22) 0%, rgba(234,88,12,0.15) 100%);
      color: #c2410c;
    }
    .mq-stats .mq-streak[hidden] { display: none; }
    .mq-share {
      background: var(--primary-color, #446e72);
      color: #fff;
      border: none;
      font-size: 0.78rem;
      font-weight: 700;
      padding: 0.18em 0.7em;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 0.3em;
      transition: filter 0.12s;
    }
    .mq-share:hover:not(:disabled) { filter: brightness(1.12); }
    .mq-share:disabled { background: #b9c9ca; cursor: not-allowed; }

    /* Achievement toast */
    .mq-toast {
      position: fixed;
      top: 70px;
      left: 50%;
      transform: translateX(-50%) translateY(-200%);
      background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
      color: #fff;
      padding: 0.75rem 1.4rem;
      font-weight: 800;
      font-size: 1.05rem;
      letter-spacing: 0.04em;
      box-shadow: 0 8px 28px rgba(0,0,0,0.22);
      z-index: 9999;
      display: flex;
      align-items: center;
      gap: 0.5em;
      pointer-events: none;
      opacity: 0;
      transition:
        transform 0.45s cubic-bezier(0.34, 1.56, 0.64, 1),
        opacity 0.25s ease;
      max-width: 90vw;
      text-align: center;
    }
    .mq-toast.shown {
      transform: translateX(-50%) translateY(0);
      opacity: 1;
    }
    .mq-toast-icon { font-size: 1.4rem; line-height: 1; }

    /* Question + result merged into one card to avoid layout shift */
    .mq-question {
      position: relative;
      text-align: center;
      padding: 0.7rem 1rem 0.8rem;
      background: linear-gradient(135deg, rgba(68,110,114,0.10) 0%, rgba(68,110,114,0.04) 100%);
      border: 1px solid var(--border-soft, #e0e0e0);
      margin-bottom: 0.6rem;
      transition: border-color 0.2s, background 0.2s;
    }
    .mq-prompt {
      font-size: 0.78rem;
      color: rgba(100,100,100,0.8);
      margin: 0 0 0.15rem;
    }
    .mq-name {
      font-size: 1.85rem;
      font-weight: 800;
      letter-spacing: 0.04em;
      margin: 0;
      line-height: 1.15;
    }
    /* Always rendered (visibility-toggled) so the question card height stays
       constant whether the result is shown or not. min-height covers the
       2-line worst case (e.g. answer list with many prefectures wraps). */
    .mq-result-inline {
      margin-top: 0.4rem;
      min-height: 2.9rem;
      font-size: 0.85rem;
      font-weight: 600;
      line-height: 1.4;
      visibility: hidden;
    }
    .mq-result-inline.shown { visibility: visible; }
    .mq-result-mark {
      display: inline-block;
      font-size: 1.2rem;
      vertical-align: middle;
      margin-right: 0.3em;
    }
    .mq-question[data-r="correct"] {
      border-color: rgba(74,158,92,0.5);
      background: linear-gradient(135deg, rgba(74,158,92,0.16) 0%, rgba(74,158,92,0.05) 100%);
    }
    .mq-question[data-r="partial"] {
      border-color: rgba(196,154,42,0.5);
      background: linear-gradient(135deg, rgba(196,154,42,0.18) 0%, rgba(196,154,42,0.06) 100%);
    }
    .mq-question[data-r="wrong"] {
      border-color: rgba(192,57,43,0.45);
      background: linear-gradient(135deg, rgba(192,57,43,0.14) 0%, rgba(192,57,43,0.04) 100%);
    }
    .mq-question[data-r="revealed"] {
      border-color: rgba(108,122,137,0.5);
      background: linear-gradient(135deg, rgba(108,122,137,0.14) 0%, rgba(108,122,137,0.04) 100%);
    }
    .mq-question[data-r="correct"] .mq-result-inline { color: #2c6f3c; }
    .mq-question[data-r="partial"] .mq-result-inline { color: #8a6614; }
    .mq-question[data-r="wrong"]   .mq-result-inline { color: #9a2d24; }
    .mq-question[data-r="revealed"] .mq-result-inline { color: #4d5a68; }

    /* Prefecture grid: each region is a single flex row with a small label on the left */
    .mq-region {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      margin-bottom: 0.32rem;
    }
    .mq-region-label {
      flex: 0 0 auto;
      width: 2.6em;
      font-size: 0.7rem;
      color: rgba(100,100,100,0.7);
      letter-spacing: 0.04em;
      text-align: center;
      font-weight: 700;
    }
    .mq-prefs {
      flex: 1 1 auto;
      display: flex;
      flex-wrap: wrap;
      gap: 0.3rem;
    }
    .mq-pref {
      flex: 1 1 70px;
      min-width: 64px;
      max-width: 110px;
      padding: 0.4rem 0.2rem;
      border: 1.5px solid var(--border-soft, #d8d8d8);
      background: #fff;
      color: #333;
      font-size: 0.82rem;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.12s, border-color 0.12s, color 0.12s, transform 0.08s;
      user-select: none;
      text-align: center;
      line-height: 1.1;
    }
    .mq-pref:hover:not(:disabled) {
      border-color: var(--primary-color, #446e72);
      transform: translateY(-1px);
    }
    .mq-pref.selected {
      background: var(--primary-color, #446e72);
      color: #fff;
      border-color: var(--primary-color, #446e72);
    }
    .mq-pref:disabled { cursor: not-allowed; }
    .mq-pref.reveal-correct {
      background: rgba(74,158,92,0.85) !important;
      color: #fff !important;
      border-color: #3d8b50 !important;
    }
    .mq-pref.reveal-missed {
      background: #fff !important;
      color: #2c6f3c !important;
      border-color: #3d8b50 !important;
      border-style: dashed !important;
    }
    .mq-pref.reveal-wrong {
      background: rgba(192,57,43,0.18) !important;
      color: #9a2d24 !important;
      border-color: #c0392b !important;
      text-decoration: line-through;
    }

    /* Action bar */
    .mq-actions {
      display: flex;
      gap: 0.5rem;
      justify-content: center;
      align-items: center;
      margin-top: 0.7rem;
      flex-wrap: wrap;
    }
    .mq-btn {
      padding: 0.5rem 1.2rem;
      border: none;
      font-weight: 700;
      font-size: 0.92rem;
      cursor: pointer;
      transition: all 0.12s;
    }
    .mq-btn-primary { background: var(--primary-color, #446e72); color: #fff; }
    .mq-btn-primary:hover:not(:disabled) { filter: brightness(1.08); }
    .mq-btn-primary:disabled { background: #b9c9ca; cursor: not-allowed; }
    .mq-btn-secondary { background: #efeae1; color: #333; }
    .mq-btn-secondary:hover { background: #e3dccd; }
    .mq-skip {
      font-size: 0.78rem;
      color: rgba(100,100,100,0.7);
      text-decoration: none;
      cursor: pointer;
      padding: 0.4rem 0.6rem;
    }
    .mq-skip:hover { color: var(--primary-color); text-decoration: underline; }
    .mq-btn-secondary:disabled {
      background: #efeae1;
      color: #b5b0a7;
      cursor: not-allowed;
      opacity: 0.6;
    }
    .mq-shortcuts {
      text-align: center;
      font-size: 0.72rem;
      color: rgba(100,100,100,0.55);
      margin: 0.4rem 0 0;
      line-height: 1.6;
    }
    .mq-shortcuts kbd {
      display: inline-block;
      padding: 0.05em 0.45em;
      margin: 0 0.15em;
      font-size: 0.72rem;
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      background: rgba(0,0,0,0.06);
      border: 1px solid rgba(0,0,0,0.1);
      color: rgba(80,80,80,0.85);
    }

    /* Dark mode */
    [data-theme="dark"] .mq-pref { background: #2a2f33; color: #ddd; border-color: #444; }
    [data-theme="dark"] .mq-pref:hover:not(:disabled) { border-color: #6fa7ac; }
    [data-theme="dark"] .mq-question { background: linear-gradient(135deg, rgba(110,160,165,0.18) 0%, rgba(110,160,165,0.06) 100%); border-color: #3a4045; }
    [data-theme="dark"] .mq-stats span { background: rgba(255,255,255,0.06); }

    /* Responsive: shrink further on small screens */
    @media (max-width: 760px) {
      .mq-page { padding: 0.5rem 0.6rem; }
      .mq-name { font-size: 1.55rem; }
      .mq-pref { font-size: 0.74rem; padding: 0.34rem 0.15rem; min-width: 54px; }
      .mq-region-label { width: 2.4em; font-size: 0.65rem; }
      .mq-title-sub { display: none; }
    }
    @media (max-width: 460px) {
      .mq-region { flex-direction: column; align-items: stretch; gap: 0.15rem; margin-bottom: 0.28rem; }
      .mq-region-label { width: auto; text-align: left; padding-left: 0.2rem; }
    }

    /* Scale up on roomier viewports so the quiz fills the visible area
       instead of leaving a large gap above the footer. */
    @media (min-height: 800px) {
      .mq-page { padding: 1rem 1.2rem 1.2rem; }
      .mq-bar { margin-bottom: 1rem; }
      .mq-title { font-size: 1.3rem; }
      .mq-stats { font-size: 0.92rem; }
      .mq-question { padding: 1.1rem 1.4rem 1.3rem; margin-bottom: 1rem; }
      .mq-prompt { font-size: 0.88rem; margin: 0 0 0.4rem; }
      .mq-name { font-size: 2.4rem; }
      .mq-result-inline { font-size: 0.95rem; min-height: 3.2rem; margin-top: 0.5rem; }
      .mq-result-mark { font-size: 1.4rem; }
      .mq-region { margin-bottom: 0.5rem; gap: 0.5rem; }
      .mq-region-label { font-size: 0.85rem; width: 3em; }
      .mq-prefs { gap: 0.4rem; }
      .mq-pref {
        font-size: 0.95rem;
        padding: 0.65rem 0.3rem;
        flex: 1 1 90px;
        min-width: 78px;
        max-width: 130px;
      }
      .mq-actions { margin-top: 1.2rem; gap: 0.7rem; }
      .mq-btn { font-size: 1rem; padding: 0.7rem 1.5rem; }
      .mq-skip { font-size: 0.85rem; }
    }
    @media (min-height: 1000px) {
      .mq-question { padding: 1.4rem 1.6rem 1.6rem; margin-bottom: 1.2rem; }
      .mq-name { font-size: 2.9rem; }
      .mq-result-inline { font-size: 1rem; min-height: 3.4rem; }
      .mq-region { margin-bottom: 0.7rem; }
      .mq-pref { font-size: 1.05rem; padding: 0.85rem 0.4rem; }
      .mq-actions { margin-top: 1.6rem; }
      .mq-btn { padding: 0.85rem 1.8rem; font-size: 1.1rem; }
    }
    /* Wider viewport: let the prefecture grid have more room to breathe. */
    @media (min-width: 1200px) {
      .mq-page { max-width: 1100px; }
    }
    @media (min-width: 1500px) {
      .mq-page { max-width: 1240px; }
      .mq-pref { max-width: 150px; }
    }

    /* Side rails. The ad rail is desktop-only (Auto Ads handles mobile via
       the global loader); the history rail is shown on every screen but
       collapses to a small floating tab on mobile. */
    .mq-ad-rail { display: none; }
    .mq-history-rail { display: block; }
    .mq-history-toggle, .mq-history-close { display: none; }

    .mq-ad-inner {
      position: sticky;
      top: 80px;
      width: 100%;
      max-width: 200px;
      margin: 0 auto;
      min-height: 600px;
    }
    .mq-ad-inner .adsbygoogle { display: block; min-height: 600px; }

    /* History panel (right rail) */
    .mq-history-inner {
      position: sticky;
      top: 80px;
      max-height: calc(100vh - 100px);
      overflow: hidden;
      display: flex;
      flex-direction: column;
      background: var(--surface-color, #fff);
      border: 1px solid var(--border-soft, #d8d4ca);
    }
    .mq-history-header {
      flex-shrink: 0;
      padding: 0.6rem 0.85rem;
      background: rgba(0,0,0,0.025);
      border-bottom: 1px solid var(--border-soft, #d8d4ca);
    }
    .mq-history-title {
      display: flex;
      align-items: baseline;
      gap: 0.4rem;
      margin: 0;
      font-size: 0.8rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      color: var(--primary-color, #446e72);
      text-transform: uppercase;
    }
    .mq-history-count {
      font-size: 0.72rem;
      font-weight: 600;
      color: rgba(100,100,100,0.75);
      letter-spacing: 0;
      text-transform: none;
    }
    .mq-history-hint {
      font-size: 0.66rem;
      color: rgba(100,100,100,0.65);
      margin: 0.2rem 0 0;
      line-height: 1.4;
    }

    .mq-history-list {
      list-style: none;
      padding: 0;
      margin: 0;
      overflow-y: auto;
      flex: 1 1 auto;
      min-height: 0;
    }
    .mq-history-empty {
      color: rgba(100,100,100,0.6);
      font-size: 0.78rem;
      padding: 1.2rem 0.8rem;
      text-align: center;
    }

    .mq-history-item {
      display: grid;
      grid-template-columns: 30px 1fr;
      align-items: stretch;
      cursor: pointer;
      border-bottom: 1px solid var(--border-soft, #efece6);
      position: relative;
      transition: background 0.12s;
    }
    .mq-history-item:last-child { border-bottom: none; }

    /* Left colour band — solid grade indicator */
    .mq-history-grade {
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 800;
      font-size: 1rem;
      color: #fff;
      line-height: 1;
    }
    .mq-history-grade-correct  { background: #4a9e5c; }
    .mq-history-grade-partial  { background: #c49a2a; }
    .mq-history-grade-wrong    { background: #c0392b; }
    .mq-history-grade-revealed { background: #6c7a89; }
    .mq-history-grade-fresh    { background: #d8d4ca; color: #888; }

    /* Subtle row tint matching the grade */
    .mq-history-item-correct   { background: rgba(74,158,92,0.06); }
    .mq-history-item-partial   { background: rgba(196,154,42,0.07); }
    .mq-history-item-wrong     { background: rgba(192,57,43,0.05); }
    .mq-history-item-revealed  { background: rgba(108,122,137,0.06); }
    .mq-history-item-fresh     { background: transparent; }

    .mq-history-item:hover                  { background: rgba(0,0,0,0.05); }
    .mq-history-item-correct:hover          { background: rgba(74,158,92,0.16); }
    .mq-history-item-partial:hover          { background: rgba(196,154,42,0.18); }
    .mq-history-item-wrong:hover            { background: rgba(192,57,43,0.13); }
    .mq-history-item-revealed:hover         { background: rgba(108,122,137,0.14); }

    .mq-history-item.is-current {
      outline: 2px solid var(--primary-color, #446e72);
      outline-offset: -2px;
      z-index: 1;
    }
    .mq-history-item.is-current::after {
      content: "";
      position: absolute;
      right: 0;
      top: 50%;
      transform: translateY(-50%);
      border-style: solid;
      border-width: 5px 0 5px 6px;
      border-color: transparent transparent transparent var(--primary-color, #446e72);
    }

    .mq-history-body {
      padding: 0.5rem 0.7rem;
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 0.1rem;
    }
    .mq-history-name {
      font-weight: 700;
      font-size: 0.82rem;
      color: var(--text-color);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .mq-history-prefs {
      font-size: 0.7rem;
      color: rgba(100,100,100,0.78);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    /* Dark mode tweaks */
    [data-theme="dark"] .mq-history-inner { background: #2a2f33; border-color: #3a4045; }
    [data-theme="dark"] .mq-history-header { background: rgba(255,255,255,0.04); border-color: #3a4045; }
    [data-theme="dark"] .mq-history-name { color: #e3e3e3; }
    [data-theme="dark"] .mq-history-item { border-color: #3a4045; }
    [data-theme="dark"] .mq-history-grade-fresh { background: #444; color: #aaa; }
    [data-theme="dark"] .mq-history-item-correct  { background: rgba(74,158,92,0.16); }
    [data-theme="dark"] .mq-history-item-partial  { background: rgba(196,154,42,0.18); }
    [data-theme="dark"] .mq-history-item-wrong    { background: rgba(192,57,43,0.16); }
    [data-theme="dark"] .mq-history-item-revealed { background: rgba(108,122,137,0.18); }

    @media (min-width: 1280px) {
      main.mq-shell {
        display: grid;
        grid-template-columns: minmax(170px, 1fr) minmax(0, 1100px) minmax(220px, 1fr);
        gap: 1.2rem;
        max-width: 1640px;
        margin: 0 auto;
        align-items: start;
        width: 100%;
      }
      .mq-shell > .mq-page { max-width: none; margin: 0; }
      .mq-ad-rail { display: block; min-width: 0; }
    }

    /* Mobile / narrow desktops: history rail floats to the right edge as a
       collapsed tab. Tapping the tab reveals the full panel as an overlay. */
    @media (max-width: 1279px) {
      .mq-history-rail .mq-history-inner { display: none; }
      .mq-history-toggle {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.25rem;
        position: fixed;
        right: 0;
        top: 35%;
        z-index: 200;
        background: var(--primary-color, #446e72);
        color: #fff;
        border: none;
        padding: 0.7rem 0.45rem;
        font-weight: 700;
        font-size: 0.78rem;
        cursor: pointer;
        letter-spacing: 0.06em;
        box-shadow: -2px 2px 8px rgba(0,0,0,0.18);
      }
      .mq-history-toggle:hover { filter: brightness(1.1); }
      .mq-history-toggle-icon { font-size: 1.1rem; line-height: 1; }
      .mq-history-toggle-letters {
        display: flex;
        flex-direction: column;
        line-height: 1.05;
      }
      .mq-history-toggle-count {
        font-size: 0.72rem;
        background: rgba(255,255,255,0.18);
        padding: 0.05em 0.35em;
        font-weight: 800;
      }
      .mq-history-rail.is-expanded .mq-history-inner {
        display: flex;
        position: fixed;
        top: 60px;
        right: 0;
        bottom: 16px;
        width: 320px;
        max-width: 92vw;
        max-height: none;
        z-index: 201;
        box-shadow: -10px 0 28px rgba(0,0,0,0.25);
      }
      .mq-history-rail.is-expanded .mq-history-toggle { display: none; }
      .mq-history-rail.is-expanded .mq-history-close {
        display: block;
        position: absolute;
        top: 6px;
        right: 6px;
        background: none;
        border: none;
        color: rgba(80,80,80,0.85);
        font-size: 1.5rem;
        line-height: 1;
        cursor: pointer;
        padding: 0.2rem 0.5rem;
        z-index: 1;
        font-weight: 700;
      }
      .mq-history-rail.is-expanded .mq-history-close:hover { color: #c0392b; }
      .mq-history-rail.is-expanded::before {
        content: "";
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.32);
        z-index: 200;
      }
    }
    @media (min-width: 1500px) {
      main.mq-shell {
        grid-template-columns: minmax(220px, 1fr) minmax(0, 1240px) minmax(260px, 1fr);
        gap: 1.5rem;
      }
      .mq-ad-inner { max-width: 220px; }
    }

  </style>
</head>
<body>
  <header class="shadow-bottom sticky-top bg-white">
    <Navbar lang={lang} isHome={false} />
  </header>

  <main class="mq-shell">
    <aside class="mq-ad-rail mq-ad-left" aria-hidden="true">
      <div class="mq-ad-inner">
        <ins class="adsbygoogle"
             style="display:block"
             data-ad-client="ca-pub-3422749596492644"
             data-ad-slot="1305270005"
             data-ad-format="auto"
             data-full-width-responsive="true"></ins>
      </div>
    </aside>

    <div class="mq-page">
    <div class="mq-bar">
      <h1 class="mq-title">
        自治体クイズ
        <span class="mq-title-sub">市・町・村・特別区 {totalEntries} 件からランダム出題</span>
      </h1>
      <div class="mq-stats" aria-live="polite">
        <span class="mq-correct">◯ <span id="mq-cnt-correct">0</span></span>
        <span class="mq-partial">△ <span id="mq-cnt-partial">0</span></span>
        <span class="mq-wrong">× <span id="mq-cnt-wrong">0</span></span>
        <span class="mq-streak" id="mq-streak" hidden>🔥 <span id="mq-streak-num">0</span> 連続</span>
        <button class="mq-share" id="mq-share" type="button" title="結果をXでシェア">📣 シェア</button>
      </div>
    </div>

    <section class="mq-question" id="mq-question" aria-live="polite">
      <p class="mq-prompt">この自治体は、どの都道府県にある？（該当する都道府県をすべて選択）</p>
      <p class="mq-name" id="mq-name">―</p>
      <div class="mq-result-inline" id="mq-result">
        <span class="mq-result-mark" id="mq-result-mark">◯</span>
        <span id="mq-result-text">正解！</span>
        <span id="mq-result-detail"></span>
      </div>
    </section>

    <section id="mq-prefs-area">
      {REGIONS.map((region) => (
        <div class="mq-region">
          <div class="mq-region-label">{region}</div>
          <div class="mq-prefs">
            {PREFECTURES.filter((p) => p.region === region).map((p) => (
              <button class="mq-pref" type="button" data-pref={p.name}>{p.name}</button>
            ))}
          </div>
        </div>
      ))}
    </section>

    <div class="mq-actions">
      <button class="mq-btn mq-btn-secondary" id="mq-prev" type="button" title="←キーでも戻れます">前の問題</button>
      <button class="mq-btn mq-btn-primary" id="mq-submit" type="button" disabled>回答する</button>
      <button class="mq-btn mq-btn-secondary" id="mq-next" type="button" title="→キーでも進めます">次の問題</button>
      <a class="mq-skip" id="mq-skip">スキップ</a>
    </div>
    <p class="mq-shortcuts">
      <kbd>Enter</kbd> 回答 / <kbd>Space</kbd> 答えを表示 / <kbd>←</kbd><kbd>→</kbd> 前後の問題
    </p>
    </div>

    <div class="mq-toast" id="mq-toast" role="status" aria-live="polite">
      <span class="mq-toast-icon" id="mq-toast-icon">🎉</span>
      <span class="mq-toast-text" id="mq-toast-text">―</span>
    </div>

    <aside class="mq-history-rail" id="mq-history-rail" aria-label="解答履歴">
      <button class="mq-history-toggle" id="mq-history-toggle" type="button"
              aria-controls="mq-history-panel" aria-expanded="false" aria-label="解答履歴を開く">
        <span class="mq-history-toggle-icon" aria-hidden="true">📋</span>
        <span class="mq-history-toggle-letters" aria-hidden="true"><span>履</span><span>歴</span></span>
        <span class="mq-history-toggle-count" id="mq-history-toggle-count">0</span>
      </button>
      <div class="mq-history-inner" id="mq-history-panel">
        <button class="mq-history-close" id="mq-history-close" type="button" aria-label="閉じる">×</button>
        <div class="mq-history-header">
          <h2 class="mq-history-title">
            <span>解答履歴</span>
            <span class="mq-history-count" id="mq-history-count"></span>
          </h2>
          <p class="mq-history-hint">クリックでその問題に戻れます</p>
        </div>
        <ol class="mq-history-list" id="mq-history-list"></ol>
        <div class="mq-history-empty" id="mq-history-empty">まだ履歴はありません</div>
      </div>
    </aside>
  </main>

  <script is:inline>
    // Initialise the (single, left-side) AdSense slot only when the rail is
    // visible (>= 1280px). Pushing while the container is display:none would
    // trigger "No slot size for availableWidth=0" warnings.
    if (window.matchMedia && window.matchMedia("(min-width: 1280px)").matches) {
      (window.adsbygoogle = window.adsbygoogle || []).push({});
    }
  </script>

  <script id="mq-data" type="application/json" set:html={JSON.stringify(municipalitiesData)}></script>

  <script is:inline>
  (function () {
    const dataEl = document.getElementById("mq-data");
    /** @type {Record<string, string[]>} */
    const data = JSON.parse(dataEl.textContent || "{}");
    if (Object.keys(data).length === 0) return;

    const HISTORY_KEY = "mq-history-v2";
    const CURSOR_KEY  = "mq-cursor-v1";
    const SCORE_KEY   = "mq-score-v1";
    const MAX_HISTORY = 100;

    // Each (name, prefecture) pair counts as one entry — names with multiple
    // prefectures appear proportionally more often.
    const flat = [];
    for (const [n, prs] of Object.entries(data)) {
      for (let i = 0; i < prs.length; i++) flat.push(n);
    }

    function loadJSON(key, fallback) {
      try {
        const v = localStorage.getItem(key);
        if (v == null) return fallback;
        return JSON.parse(v);
      } catch { return fallback; }
    }
    function saveJSON(key, val) {
      try { localStorage.setItem(key, JSON.stringify(val)); } catch {}
    }

    /** @typedef {{ name: string, prefs: string[], state: "fresh"|"answered"|"revealed", selected: string[], grade: ("correct"|"partial"|"wrong"|null), ts: number }} HE */
    let history = loadJSON(HISTORY_KEY, []);
    if (!Array.isArray(history)) history = [];
    history = history.filter((h) => h && typeof h.name === "string" && data[h.name]);
    let cursor = parseInt(localStorage.getItem(CURSOR_KEY) || "0", 10);
    if (!Number.isFinite(cursor) || cursor < 0) cursor = 0;
    if (cursor > history.length) cursor = history.length;

    function pickName() {
      const recent = new Set(history.slice(-30).map((e) => e.name));
      let pick;
      let safety = 200;
      do {
        pick = flat[Math.floor(Math.random() * flat.length)];
        safety--;
      } while (recent.has(pick) && safety > 0);
      return pick;
    }

    // Ensure history[cursor] exists. If we landed past the end, generate.
    if (cursor >= history.length) {
      const name = pickName();
      history.push({
        name,
        prefs: data[name].slice(),
        state: "fresh",
        selected: [],
        grade: null,
        ts: Date.now(),
      });
      cursor = history.length - 1;
    }
    // Trim oldest entries if we exceed the cap.
    if (history.length > MAX_HISTORY) {
      const drop = history.length - MAX_HISTORY;
      history = history.slice(drop);
      cursor = Math.max(0, cursor - drop);
    }
    saveJSON(HISTORY_KEY, history);
    localStorage.setItem(CURSOR_KEY, String(cursor));

    /** @type {HE} */
    const current = history[cursor];
    const currentAnswer = new Set(current.prefs);
    const selected = new Set(current.selected || []);

    // DOM refs
    const questionEl   = document.getElementById("mq-question");
    const nameEl       = document.getElementById("mq-name");
    const resultEl     = document.getElementById("mq-result");
    const resultMark   = document.getElementById("mq-result-mark");
    const resultText   = document.getElementById("mq-result-text");
    const resultDetail = document.getElementById("mq-result-detail");
    const submitBtn    = document.getElementById("mq-submit");
    const nextBtn      = document.getElementById("mq-next");
    const prevBtn      = document.getElementById("mq-prev");
    const skipBtn      = document.getElementById("mq-skip");
    const cntCorrect   = document.getElementById("mq-cnt-correct");
    const cntPartial   = document.getElementById("mq-cnt-partial");
    const cntWrong     = document.getElementById("mq-cnt-wrong");
    const streakEl     = document.getElementById("mq-streak");
    const streakNumEl  = document.getElementById("mq-streak-num");
    const shareBtn     = document.getElementById("mq-share");
    const toastEl      = document.getElementById("mq-toast");
    const toastIconEl  = document.getElementById("mq-toast-icon");
    const toastTextEl  = document.getElementById("mq-toast-text");
    const buttons      = Array.from(document.querySelectorAll(".mq-pref"));
    const historyListEl = document.getElementById("mq-history-list");
    const historyEmptyEl = document.getElementById("mq-history-empty");
    const historyCountEl = document.getElementById("mq-history-count");
    const historyToggleCountEl = document.getElementById("mq-history-toggle-count");
    const historyRail   = document.getElementById("mq-history-rail");
    const historyToggle = document.getElementById("mq-history-toggle");
    const historyClose  = document.getElementById("mq-history-close");

    const STREAK_MILESTONES = [3, 5, 10, 15, 20, 30, 50, 100];
    const TOTAL_MILESTONES  = [10, 25, 50, 100, 200, 500, 1000];
    let toastTimer = null;
    function showAchievement(text, icon) {
      if (!toastEl || !toastTextEl) return;
      toastTextEl.textContent = text;
      if (toastIconEl && icon) toastIconEl.textContent = icon;
      toastEl.classList.add("shown");
      if (toastTimer) clearTimeout(toastTimer);
      toastTimer = setTimeout(() => toastEl.classList.remove("shown"), 2800);
    }

    function persistCurrent() {
      history[cursor] = current;
      saveJSON(HISTORY_KEY, history);
    }

    function gradeOf() {
      let anyWrong = false;
      for (const s of selected) if (!currentAnswer.has(s)) { anyWrong = true; break; }
      if (anyWrong) return "wrong";
      if (selected.size === currentAnswer.size) return "correct";
      return "partial";
    }

    function setSelected(btn, on) {
      if (on) { btn.classList.add("selected"); selected.add(btn.dataset.pref); }
      else { btn.classList.remove("selected"); selected.delete(btn.dataset.pref); }
      submitBtn.disabled = selected.size === 0 || current.state !== "fresh";
    }

    function renderQuestion() {
      nameEl.textContent = current.name;
      const list = [...currentAnswer].join("、");

      // Reset all classes first
      buttons.forEach((b) => {
        b.classList.remove("selected", "reveal-correct", "reveal-missed", "reveal-wrong");
        b.disabled = false;
      });
      resultEl.classList.remove("shown");
      questionEl.removeAttribute("data-r");
      submitBtn.disabled = true;
      submitBtn.textContent = "回答する";

      if (current.state === "fresh") {
        // Allow input
        return;
      }

      if (current.state === "answered") {
        const sel = new Set(current.selected || []);
        buttons.forEach((b) => {
          const pref = b.dataset.pref;
          const isAnswer = currentAnswer.has(pref);
          const isSelected = sel.has(pref);
          b.disabled = true;
          if (isAnswer && isSelected) b.classList.add("reveal-correct");
          else if (isAnswer && !isSelected) b.classList.add("reveal-missed");
          else if (!isAnswer && isSelected) b.classList.add("reveal-wrong");
        });
        questionEl.dataset.r = current.grade;
        resultEl.classList.add("shown");
        if (current.grade === "correct") {
          resultMark.textContent = "◯";
          resultText.textContent = "正解！";
          resultDetail.textContent = "";
        } else if (current.grade === "partial") {
          resultMark.textContent = "△";
          resultText.textContent = "惜しい！";
          resultDetail.textContent = "（正解は " + list + "）";
        } else {
          resultMark.textContent = "×";
          resultText.textContent = "不正解";
          resultDetail.textContent = "（正解は " + list + "）";
        }
        submitBtn.textContent = "判定済み";
      } else if (current.state === "revealed") {
        const sel = new Set(current.selected || []);
        buttons.forEach((b) => {
          const pref = b.dataset.pref;
          const isAnswer = currentAnswer.has(pref);
          const isSelected = sel.has(pref);
          b.disabled = true;
          if (isAnswer) b.classList.add("reveal-correct");
          else if (isSelected) b.classList.add("reveal-wrong");
        });
        questionEl.dataset.r = "revealed";
        resultEl.classList.add("shown");
        resultMark.textContent = "答";
        resultText.textContent = "答えを表示";
        resultDetail.textContent = "（正解は " + list + "）";
        submitBtn.textContent = "答え表示済み";
      }
    }

    function bumpScore(grade) {
      const s = loadJSON(SCORE_KEY, {});
      s.correct = (s.correct || 0) + (grade === "correct" ? 1 : 0);
      s.partial = (s.partial || 0) + (grade === "partial" ? 1 : 0);
      s.wrong   = (s.wrong   || 0) + (grade === "wrong"   ? 1 : 0);
      s.total   = (s.total   || 0) + 1;
      // Streak: only fully-correct answers extend the streak; partial/wrong reset it.
      if (grade === "correct") {
        s.streak = (s.streak || 0) + 1;
        s.bestStreak = Math.max(s.bestStreak || 0, s.streak);
      } else {
        s.streak = 0;
      }
      saveJSON(SCORE_KEY, s);
      renderScore(s);
      // Achievement bursts
      if (grade === "correct" && STREAK_MILESTONES.includes(s.streak)) {
        showAchievement(s.streak + " 問連続正解！", "🔥");
      } else if (TOTAL_MILESTONES.includes(s.total)) {
        showAchievement(s.total + " 問挑戦達成！", "🎯");
      }
    }
    function renderScore(s) {
      cntCorrect.textContent = String(s.correct || 0);
      cntPartial.textContent = String(s.partial || 0);
      cntWrong.textContent   = String(s.wrong   || 0);
      const streak = s.streak || 0;
      if (streakEl && streakNumEl) {
        if (streak >= 2) {
          streakEl.hidden = false;
          streakNumEl.textContent = String(streak);
        } else {
          streakEl.hidden = true;
        }
      }
      // Share unlocks once user has at least one correct answer to brag about.
      if (shareBtn) shareBtn.disabled = !((s.bestStreak || 0) >= 1);
    }

    const SHARE_TITLE = "自治体クイズ";
    function share() {
      const s = loadJSON(SCORE_KEY, {});
      const best = s.bestStreak || 0;
      if (best < 1) return;
      const url = location.origin + location.pathname;
      const text = best + " 問連続正解しました！\n" + SHARE_TITLE;
      const tw = "https://twitter.com/intent/tweet?text=" + encodeURIComponent(text)
               + "&url=" + encodeURIComponent(url);
      window.open(tw, "_blank", "noopener,noreferrer");
    }
    if (shareBtn) shareBtn.addEventListener("click", share);

    // Floating history drawer toggle (mobile / narrow desktop).
    function setHistoryExpanded(expanded) {
      if (!historyRail) return;
      historyRail.classList.toggle("is-expanded", expanded);
      if (historyToggle) historyToggle.setAttribute("aria-expanded", String(expanded));
    }
    if (historyToggle) historyToggle.addEventListener("click", (e) => {
      e.stopPropagation();
      setHistoryExpanded(!historyRail.classList.contains("is-expanded"));
    });
    if (historyClose) historyClose.addEventListener("click", (e) => {
      e.stopPropagation();
      setHistoryExpanded(false);
    });
    document.addEventListener("click", (e) => {
      if (!historyRail || !historyRail.classList.contains("is-expanded")) return;
      if (historyRail.contains(e.target)) return;
      setHistoryExpanded(false);
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && historyRail && historyRail.classList.contains("is-expanded")) {
        setHistoryExpanded(false);
      }
    });

    function submit() {
      if (current.state !== "fresh" || selected.size === 0) return;
      current.state = "answered";
      current.selected = [...selected];
      current.grade = gradeOf();
      persistCurrent();
      bumpScore(current.grade);
      renderQuestion();
      renderHistoryList();
    }

    function revealAnswer() {
      if (current.state !== "fresh") return;
      current.state = "revealed";
      current.selected = [...selected];
      persistCurrent();
      renderQuestion();
      renderHistoryList();
    }

    function go(newCursor) {
      if (newCursor < 0) return;
      // For prev clicks, refuse if already at 0.
      if (newCursor === cursor) return;
      localStorage.setItem(CURSOR_KEY, String(newCursor));
      location.reload();
    }
    function next() { go(cursor + 1); }
    function prev() { if (cursor > 0) go(cursor - 1); }

    // Buttons
    buttons.forEach((b) => {
      b.addEventListener("click", () => {
        if (current.state !== "fresh") return;
        setSelected(b, !b.classList.contains("selected"));
      });
    });
    submitBtn.addEventListener("click", submit);
    nextBtn.addEventListener("click", next);
    if (skipBtn) skipBtn.addEventListener("click", next);
    if (prevBtn) {
      prevBtn.disabled = (cursor === 0);
      prevBtn.addEventListener("click", prev);
    }

    // Keyboard
    document.addEventListener("keydown", (e) => {
      const tag = (e.target && e.target.tagName) || "";
      if (tag === "INPUT" || tag === "TEXTAREA") return;
      // Don't hijack space when a prefecture button is focused (default toggles it).
      if ((e.key === " " || e.code === "Space") && tag === "BUTTON") return;

      if (e.key === " " || e.code === "Space") {
        e.preventDefault();
        revealAnswer();
      } else if (e.key === "ArrowRight") {
        e.preventDefault();
        next();
      } else if (e.key === "ArrowLeft") {
        e.preventDefault();
        prev();
      } else if (e.key === "Enter") {
        e.preventDefault();
        if (current.state === "fresh" && selected.size > 0) submit();
        else next();
      }
    });

    // State key for CSS class suffixes — collapses (state, grade) to one of:
    //   correct / partial / wrong / revealed / fresh
    function stateKey(h) {
      if (h.state === "answered") return h.grade;
      return h.state;
    }
    function gradeMark(h) {
      if (h.state === "answered") {
        if (h.grade === "correct") return "◯";
        if (h.grade === "partial") return "△";
        return "×";
      }
      if (h.state === "revealed") return "答";
      return "—";
    }

    function renderHistoryList() {
      if (!historyListEl) return;
      historyListEl.textContent = "";
      if (historyCountEl) {
        historyCountEl.textContent = history.length > 0 ? "(" + history.length + " 問)" : "";
      }
      if (historyToggleCountEl) historyToggleCountEl.textContent = String(history.length);
      if (history.length === 0) {
        if (historyEmptyEl) historyEmptyEl.style.display = "block";
        return;
      }
      if (historyEmptyEl) historyEmptyEl.style.display = "none";

      // Most recent first
      for (let i = history.length - 1; i >= 0; i--) {
        const h = history[i];
        const key = stateKey(h);

        const li = document.createElement("li");
        li.className = "mq-history-item mq-history-item-" + key + (i === cursor ? " is-current" : "");

        const gradeSpan = document.createElement("span");
        gradeSpan.className = "mq-history-grade mq-history-grade-" + key;
        gradeSpan.textContent = gradeMark(h);

        const body = document.createElement("div");
        body.className = "mq-history-body";
        const name = document.createElement("span");
        name.className = "mq-history-name";
        name.textContent = h.name;
        const prefs = document.createElement("span");
        prefs.className = "mq-history-prefs";
        prefs.textContent = (h.prefs || []).join("、");
        body.appendChild(name);
        body.appendChild(prefs);

        li.appendChild(gradeSpan);
        li.appendChild(body);
        li.addEventListener("click", () => go(i));
        historyListEl.appendChild(li);
      }
    }

    // Initial render
    renderScore(loadJSON(SCORE_KEY, {}));

    // Pre-fill button selections if current question carries them.
    if (current.state === "fresh" && current.selected && current.selected.length) {
      const sel = new Set(current.selected);
      buttons.forEach((b) => {
        if (sel.has(b.dataset.pref)) b.classList.add("selected");
      });
      submitBtn.disabled = false;
    }
    renderQuestion();
    renderHistoryList();
  })();
  </script>

  <Footer lang={lang} title={pageTitle} permalink={canonical} />
  <SearchModal lang={lang} />
</body>
</html>
