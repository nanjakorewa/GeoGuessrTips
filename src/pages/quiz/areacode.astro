---
import fs from "node:fs";
import path from "node:path";
import Head from "@components/seo/Head.astro";
import Navbar from "@components/navigation/Navbar.astro";
import Footer from "@components/footer/Footer.astro";
import SearchModal from "@components/search/SearchModal.astro";
import quizData from "../../data/areacode-quiz.json";

const lang = "ja" as const;
const site = "https://geopinning.space";
const pageTitle = "市外局番クイズ｜地図で対応する市区町村を当てよう";
const pageDescription =
  "ランダムに出題される市外局番（052、0586 など）に対応する地域を、日本地図から探して当てるクイズ。全国地図で都道府県を選び、さらにその県の地図で市区町村をクリックして解答します。";
const canonical = `${site}/quiz/areacode/`;

const totalCodes = quizData.questions.length;

const crumbs = [
  { name: "トップ", url: "/" },
  { name: "クイズ", url: "/quiz/" },
  { name: "市外局番クイズ", url: "/quiz/areacode/" },
];

// Inline the nationwide prefecture SVG (47 prefectures, data-code="JP-xx").
const japanSvgPath = path.join(process.cwd(), "public", "maps", "countries", "japan.svg");
const japanSvgRaw = fs
  .readFileSync(japanSvgPath, "utf8")
  .replace(/^\uFEFF/, "")
  .replace(/<\?xml[^>]*\?>\s*/i, "");
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <Head
    title={pageTitle}
    description={pageDescription}
    lang={lang}
    canonical={canonical}
    ogImage={`${site}/images/icon-512x512.png`}
    ogType="website"
    breadcrumbs={crumbs}
    collection="quiz"
  />
  <style is:global>
    html, body { min-height: 100vh; }
    body { overflow-x: hidden; display: flex; flex-direction: column; }
    body > header { flex: 0 0 auto; }
    body > main { flex: 1 0 auto; }
    body > .site-footer, body > footer { flex: 0 0 auto; margin-top: 0; }

    .aq-page { max-width: 920px; margin: 0 auto; padding: 0.6rem 0.9rem 1.2rem; }

    /* Title row */
    .aq-bar {
      display: flex; align-items: center; justify-content: space-between;
      gap: 0.8rem; flex-wrap: wrap; margin-bottom: 0.6rem;
    }
    .aq-title { font-size: 1.15rem; font-weight: 800; margin: 0; letter-spacing: 0.02em; }
    .aq-title-sub { font-size: 0.78rem; color: rgba(100,100,100,0.7); margin-left: 0.5rem; font-weight: 500; }
    .aq-stats { display: flex; gap: 0.4rem; font-size: 0.82rem; flex-wrap: wrap; }
    .aq-stats span {
      padding: 0.18em 0.65em; background: rgba(0,0,0,0.05); font-weight: 600;
      border-radius: 4px;
    }
    .aq-stats .aq-correct { background: rgba(74,158,92,0.15); color: #2c6f3c; }
    .aq-stats .aq-wrong   { background: rgba(192,57,43,0.13); color: #9a2d24; }
    .aq-stats .aq-streak  {
      background: linear-gradient(135deg, rgba(249,115,22,0.22) 0%, rgba(234,88,12,0.15) 100%);
      color: #c2410c;
    }
    .aq-stats .aq-streak[hidden] { display: none; }

    /* Question card */
    .aq-question {
      position: relative; text-align: center; padding: 0.9rem 1.1rem 1rem;
      background: linear-gradient(135deg, rgba(68,110,114,0.10) 0%, rgba(68,110,114,0.04) 100%);
      border: 1px solid var(--border-soft, #e0e0e0); border-radius: 8px;
      margin-bottom: 0.7rem; transition: border-color 0.2s, background 0.2s;
    }
    .aq-prompt { font-size: 0.82rem; color: rgba(90,90,90,0.9); margin: 0 0 0.35rem; }
    .aq-code {
      font-size: 2.6rem; font-weight: 800; letter-spacing: 0.12em; line-height: 1.05;
      margin: 0; font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, monospace;
      color: var(--primary-color, #2b5f63);
    }
    .aq-code-note { font-size: 0.74rem; color: rgba(120,120,120,0.85); margin: 0.35rem 0 0; }

    .aq-result {
      margin-top: 0.55rem; min-height: 1.5rem; font-size: 0.95rem; font-weight: 700;
      line-height: 1.5; visibility: hidden;
    }
    .aq-result.shown { visibility: visible; }
    .aq-result small { display: block; font-weight: 500; font-size: 0.82rem; color: rgba(80,80,80,0.9); margin-top: 0.15rem; }
    .aq-question[data-r="correct"] { border-color: rgba(74,158,92,0.5); background: linear-gradient(135deg, rgba(74,158,92,0.16) 0%, rgba(74,158,92,0.05) 100%); }
    .aq-question[data-r="wrong"]   { border-color: rgba(192,57,43,0.45); background: linear-gradient(135deg, rgba(192,57,43,0.14) 0%, rgba(192,57,43,0.04) 100%); }
    .aq-question[data-r="correct"] .aq-result { color: #2c6f3c; }
    .aq-question[data-r="wrong"]   .aq-result { color: #9a2d24; }

    /* Map */
    .aq-mapbar {
      display: flex; align-items: center; justify-content: space-between; gap: 0.6rem;
      flex-wrap: wrap; margin-bottom: 0.4rem;
    }
    .aq-crumbs { font-size: 0.9rem; font-weight: 700; color: #234; display: flex; align-items: center; gap: 0.3em; flex-wrap: wrap; }
    .aq-crumbs .sep { color: rgba(120,120,120,0.6); }
    .aq-crumbs .cur { color: var(--primary-color, #2b5f63); }
    .aq-mapbar-right { display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap; }
    .aq-zoom { display: inline-flex; gap: 0.25rem; }
    .aq-zoom button {
      width: 2rem; height: 2rem; border: 1px solid var(--border-soft, #d8d4ca); background: #fff;
      color: #234; font-size: 1.05rem; font-weight: 800; line-height: 1; border-radius: 6px; cursor: pointer;
      display: inline-flex; align-items: center; justify-content: center; padding: 0;
    }
    .aq-zoom button:hover { background: #f3f6f6; }
    .aq-zoom button:disabled { opacity: 0.4; cursor: not-allowed; }
    .aq-back {
      border: 1px solid var(--border-soft, #d8d4ca); background: #fff; color: #335;
      font-size: 0.82rem; font-weight: 700; padding: 0.3em 0.85em; border-radius: 6px; cursor: pointer;
    }
    .aq-back:hover { background: #f3f6f6; }
    .aq-back[hidden] { display: none; }

    .aq-map {
      position: relative; border: 1px solid var(--border-soft, #e0e0e0); border-radius: 8px;
      background: #f6fafe; overflow: auto; height: 80vh; touch-action: pan-x pan-y;
      -webkit-overflow-scrolling: touch; cursor: grab;
    }
    .aq-map.grabbing { cursor: grabbing; }
    .aq-map-inner {
      width: 100%; height: 100%; min-width: 100%; min-height: 100%;
      display: flex; align-items: center; justify-content: center;
    }
    .aq-map-inner svg { display: block; width: 100%; height: 100%; }
    .aq-map svg path { transition: fill 0.12s, stroke 0.12s; }
    /* interactive regions */
    .aq-map[data-phase] svg .pref-muni-svg__paths path { cursor: pointer; }
    .aq-map svg path:hover { fill: #cfe4fb; }
    .aq-map.locked svg .pref-muni-svg__paths path { cursor: default; }
    .aq-map.locked svg path:hover { fill: #eaf2fb; }
    /* result highlights (added via JS) */
    .aq-map svg path.aq-pick-wrong { fill: #e9897e !important; stroke: #c0392b; stroke-width: 1; }
    .aq-map svg path.aq-answer { fill: #4a9e5c !important; stroke: #1f5b30; stroke-width: 1; }

    .aq-hint-pref { font-size: 0.82rem; color: #6b21a8; font-weight: 700; }
    .aq-hint-pref[hidden] { display: none; }

    /* Actions */
    .aq-actions { display: flex; gap: 0.5rem; justify-content: center; align-items: center; margin-top: 0.8rem; flex-wrap: wrap; }
    .aq-btn { padding: 0.5rem 1.2rem; border: none; font-weight: 700; font-size: 0.92rem; cursor: pointer; border-radius: 6px; transition: filter 0.12s; }
    .aq-btn-primary { background: var(--primary-color, #446e72); color: #fff; }
    .aq-btn-primary:hover { filter: brightness(1.1); }
    .aq-btn-secondary { background: rgba(0,0,0,0.06); color: #334; }
    .aq-btn-secondary:hover { background: rgba(0,0,0,0.1); }
    .aq-btn:disabled { opacity: 0.5; cursor: not-allowed; }
    .aq-btn-memorize { background: #fff4dc; color: #92670f; border: 1px solid #e3c987; }
    .aq-btn-memorize:hover { background: #ffeec2; }
    .aq-btn-memorize.is-active { background: linear-gradient(135deg, #f6b73c 0%, #e0982a 100%); color: #3d2a06; border-color: #c98f1f; }

    /* memorize / study mode */
    .aq-memo-note {
      font-size: 0.84rem; color: #7a5a10; background: rgba(246,183,60,0.12);
      border-radius: 6px; padding: 0.5rem 0.7rem; margin: 0.2rem 0 0; line-height: 1.55;
    }
    .aq-memo-note[hidden] { display: none; }
    .aq-question.is-memorize .aq-code,
    .aq-question.is-memorize .aq-code-note,
    .aq-question.is-memorize .aq-result { display: none; }
    .aq-actions.is-memorize #aq-hint,
    .aq-actions.is-memorize #aq-skip,
    .aq-actions.is-memorize #aq-next { display: none; }
    .aq-map svg path.aq-has-code { fill: #fde8c4; }
    .aq-map svg path.aq-has-code:hover { fill: #f9d79a; }
    .aq-tip {
      position: fixed; z-index: 100001; pointer-events: none; display: none;
      background: #1f2a37; color: #fff; font-size: 0.86rem; font-weight: 700;
      padding: 0.32em 0.62em; border-radius: 6px; box-shadow: 0 4px 14px rgba(0,0,0,0.25);
      white-space: nowrap; max-width: 80vw; overflow: hidden; text-overflow: ellipsis;
    }
    .aq-tip.shown { display: block; }

    .aq-shortcuts { text-align: center; font-size: 0.74rem; color: rgba(120,120,120,0.8); margin: 0.6rem 0 0; }
    .aq-help { margin: 1rem 0 0; font-size: 0.82rem; color: rgba(90,90,90,0.95); line-height: 1.6; }

    /* Toast */
    .aq-toast {
      position: fixed; bottom: 28px; top: auto; left: 50%; transform: translateX(-50%) translateY(220%);
      color: #fff; padding: 0.7rem 1.3rem; border-radius: 999px; font-weight: 800; font-size: 1rem;
      box-shadow: 0 8px 28px rgba(0,0,0,0.28); z-index: 100000; display: flex; align-items: center; gap: 0.5em;
      pointer-events: none; transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1); max-width: 92vw; text-align: center;
      background: linear-gradient(135deg, #4a9e5c 0%, #2c6f3c 100%);
    }
    .aq-toast.wrong { background: linear-gradient(135deg, #d35a4d 0%, #9a2d24 100%); }
    .aq-toast.shown { transform: translateX(-50%) translateY(0); }

    @media (max-width: 520px) {
      .aq-code { font-size: 2.1rem; }
      .aq-page { padding: 0.5rem 0.6rem 1.2rem; }
    }
  </style>
</head>
<body>
  <Navbar lang={lang} isHome={false} />

  <main>
    <div class="aq-page">
      <div class="aq-bar">
        <h1 class="aq-title">
          市外局番クイズ
          <span class="aq-title-sub">{totalCodes} コードからランダム出題</span>
        </h1>
        <div class="aq-stats" aria-live="polite">
          <span class="aq-correct">◯ <span id="aq-cnt-correct">0</span></span>
          <span class="aq-wrong">× <span id="aq-cnt-wrong">0</span></span>
          <span class="aq-streak" id="aq-streak" hidden>🔥 <span id="aq-streak-num">0</span> 連続</span>
        </div>
      </div>

      <section class="aq-question" id="aq-question" aria-live="polite">
        <p class="aq-prompt">この市外局番に対応する地域を地図で選ぼう</p>
        <p class="aq-code" id="aq-code">―</p>
        <p class="aq-code-note">全国地図で都道府県をクリック → その県の地図で市区町村をクリック</p>
        <div class="aq-result" id="aq-result"></div>
        <p class="aq-memo-note" id="aq-memo-note" hidden>暗記モード：地図にカーソルを合わせる（スマホはタップ）と、その市区町村の市外局番が表示されます。色のついた市区町村は市外局番データがある地域です。都道府県をクリックすると市区町村地図に切り替わります。</p>
      </section>

      <div class="aq-mapbar">
        <div class="aq-crumbs" id="aq-crumbs"><span class="cur">日本全国</span></div>
        <div class="aq-mapbar-right">
          <span class="aq-hint-pref" id="aq-hint-pref" hidden></span>
          <span class="aq-zoom" role="group" aria-label="地図の拡大・縮小">
            <button id="aq-zoom-out" type="button" title="縮小" aria-label="縮小">−</button>
            <button id="aq-zoom-in" type="button" title="拡大" aria-label="拡大">＋</button>
            <button id="aq-zoom-reset" type="button" title="拡大リセット" aria-label="拡大リセット">⟲</button>
          </span>
          <button class="aq-back" id="aq-back" type="button" hidden>← 全国へ戻る</button>
        </div>
      </div>

      <div class="aq-map" id="aq-map" data-phase="nation">
        <div class="aq-map-inner" id="aq-map-inner" set:html={japanSvgRaw}></div>
      </div>

      <div class="aq-actions" id="aq-actions">
        <button class="aq-btn aq-btn-memorize" id="aq-memorize" type="button" aria-pressed="false" title="Mキー">暗記モード</button>
        <button class="aq-btn aq-btn-secondary" id="aq-hint" type="button">ヒント（都道府県）</button>
        <button class="aq-btn aq-btn-secondary" id="aq-skip" type="button">スキップ</button>
        <button class="aq-btn aq-btn-primary" id="aq-next" type="button" title="Enter / → キー">次の問題 ›</button>
      </div>

      <p class="aq-shortcuts">ショートカット: <b>Enter</b> / <b>→</b> 次の問題　<b>Esc</b> 全国地図へ戻る　<b>M</b> 暗記モード</p>

      <p class="aq-help">
        出題された市外局番（番号区画）に対応する地域を当てるクイズです。まず全国地図で都道府県をクリックすると、その都道府県の市区町村地図に切り替わります。
        正解と思う市区町村をクリックして解答してください。同じ市外局番が複数の地域にまたがる場合は、いずれかの正解地域を選べば正解になります。
      </p>
    </div>

    <div class="aq-toast" id="aq-toast" role="status" aria-live="polite">
      <span id="aq-toast-text">―</span>
    </div>
    <div class="aq-tip" id="aq-tip" role="status" aria-hidden="true"></div>
  </main>

  <Footer lang={lang} title={pageTitle} permalink={canonical} />
  <SearchModal lang={lang} />

  <script id="aq-data" type="application/json" set:html={JSON.stringify(quizData)}></script>

  <script is:inline>
  (function () {
    const dataEl = document.getElementById("aq-data");
    const DATA = JSON.parse(dataEl.textContent || "{}");
    const QUESTIONS = (DATA && DATA.questions) || [];
    const PREFS = (DATA && DATA.prefectures) || {}; // "JP-13" -> {slug, ja}
    if (!QUESTIONS.length) return;

    // slug -> {ja, jp}
    const SLUG = {};
    for (const jp of Object.keys(PREFS)) {
      SLUG[PREFS[jp].slug] = { ja: PREFS[jp].ja, jp };
    }

    const el = (id) => document.getElementById(id);
    const mapEl     = el("aq-map");
    const mapInner  = el("aq-map-inner");
    const crumbsEl  = el("aq-crumbs");
    const backBtn   = el("aq-back");
    const codeEl    = el("aq-code");
    const resultEl  = el("aq-result");
    const questionEl= el("aq-question");
    const hintPrefEl= el("aq-hint-pref");
    const toastEl   = el("aq-toast");
    const toastText = el("aq-toast-text");
    const memorizeBtn = el("aq-memorize");
    const memoNote  = el("aq-memo-note");
    const actionsEl = el("aq-actions");
    const tipEl     = el("aq-tip");

    // Reverse lookup for memorize mode: "slug|municipality" -> [areacode, ...]
    const MUNI_CODES = {};
    for (const it of QUESTIONS) {
      for (const a of it.answers) {
        const k = a.slug + "|" + a.muni;
        const arr = (MUNI_CODES[k] = MUNI_CODES[k] || []);
        if (arr.indexOf(it.code) === -1) arr.push(it.code);
      }
    }
    let memorize = false;

    const state = {
      q: null,          // current question
      phase: "nation",  // "nation" | "pref"
      slug: null,       // current prefecture slug (pref phase)
      answered: false,  // already judged this question
      prevIndex: -1,
    };

    const prefSvgCache = {};

    let correct = 0, wrong = 0, streak = 0;

    function updateStats() {
      el("aq-cnt-correct").textContent = String(correct);
      el("aq-cnt-wrong").textContent = String(wrong);
      const s = el("aq-streak");
      if (streak >= 2) { s.hidden = false; el("aq-streak-num").textContent = String(streak); }
      else { s.hidden = true; }
    }

    let toastTimer = null;
    function toast(msg, isWrong) {
      toastText.textContent = msg;
      toastEl.classList.toggle("wrong", !!isWrong);
      toastEl.classList.add("shown");
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => toastEl.classList.remove("shown"), 1600);
    }

    // ---- zoom / pan ----
    const ZMIN = 1, ZMAX = 4, ZSTEP = 0.5;
    let zoom = 1;
    function applyZoom(recenter) {
      mapInner.style.width = (zoom * 100) + "%";
      mapInner.style.height = (zoom * 100) + "%";
      el("aq-zoom-out").disabled = zoom <= ZMIN;
      el("aq-zoom-in").disabled = zoom >= ZMAX;
      if (recenter) {
        mapEl.scrollLeft = (mapEl.scrollWidth - mapEl.clientWidth) / 2;
        mapEl.scrollTop = (mapEl.scrollHeight - mapEl.clientHeight) / 2;
      }
    }
    function setZoom(z, recenter) {
      zoom = Math.min(ZMAX, Math.max(ZMIN, Math.round(z * 100) / 100));
      applyZoom(recenter);
    }

    // ---- map rendering ----
    function showNation() {
      state.phase = "nation";
      state.slug = null;
      mapEl.setAttribute("data-phase", "nation");
      mapEl.classList.remove("locked");
      mapInner.innerHTML = NATION_SVG;
      setZoom(1);
      backBtn.hidden = true;
      renderCrumbs();
    }

    async function loadPrefSvg(slug) {
      if (prefSvgCache[slug]) return prefSvgCache[slug];
      const res = await fetch(`/maps/prefectures/${slug}.svg`);
      let txt = await res.text();
      txt = txt.replace(/^\uFEFF/, "").replace(/<\?xml[^>]*\?>\s*/i, "");
      prefSvgCache[slug] = txt;
      return txt;
    }

    async function showPrefecture(slug) {
      const svg = await loadPrefSvg(slug);
      // ignore if the question changed while fetching
      state.phase = "pref";
      state.slug = slug;
      mapEl.setAttribute("data-phase", "pref");
      mapInner.innerHTML = svg;
      setZoom(1);
      mapEl.classList.toggle("locked", state.answered);
      backBtn.hidden = false;
      renderCrumbs();
      if (state.answered) markAnswerOnPref();
      if (memorize) applyMemoTints();
    }

    function renderCrumbs() {
      if (state.phase === "nation") {
        crumbsEl.innerHTML = '<span class="cur">日本全国</span>';
      } else {
        const ja = (SLUG[state.slug] && SLUG[state.slug].ja) || state.slug;
        crumbsEl.innerHTML =
          '<span>日本全国</span><span class="sep">›</span><span class="cur">' + ja + "</span>";
      }
    }

    // ---- question flow ----
    function pickQuestion() {
      let i = Math.floor(Math.random() * QUESTIONS.length);
      if (QUESTIONS.length > 1 && i === state.prevIndex) i = (i + 1) % QUESTIONS.length;
      state.prevIndex = i;
      state.q = QUESTIONS[i];
      state.answered = false;
      codeEl.textContent = state.q.code;
      questionEl.removeAttribute("data-r");
      resultEl.classList.remove("shown");
      resultEl.innerHTML = "";
      hintPrefEl.hidden = true;
      hintPrefEl.textContent = "";
      showNation();
    }

    function answerSlugs() {
      const set = {};
      for (const a of state.q.answers) (set[a.slug] = set[a.slug] || []).push(a.muni);
      return set;
    }

    function prefJaList() {
      const seen = [];
      for (const a of state.q.answers) {
        const ja = (SLUG[a.slug] && SLUG[a.slug].ja) || a.slug;
        if (!seen.includes(ja)) seen.push(ja);
      }
      return seen;
    }

    function markAnswerOnPref() {
      // highlight correct municipalities in the currently shown prefecture
      const munis = (answerSlugs()[state.slug]) || [];
      for (const m of munis) {
        mapInner.querySelectorAll('path[data-name="' + cssEsc(m) + '"]').forEach((p) => p.classList.add("aq-answer"));
      }
    }

    function cssEsc(s) {
      // value goes inside a quoted attribute selector, so only " and \ need escaping
      return String(s).replace(/["\\]/g, "\\$&");
    }

    function describeAnswer() {
      const parts = state.q.answers.map((a) => {
        const ja = (SLUG[a.slug] && SLUG[a.slug].ja) || a.slug;
        return a.muni + "（" + ja + "）";
      });
      // de-dup & cap
      const uniq = [];
      for (const p of parts) if (!uniq.includes(p)) uniq.push(p);
      const shown = uniq.slice(0, 6).join("・");
      const more = uniq.length > 6 ? " ほか" : "";
      const ma = (state.q.ma || []).join("・");
      return { shown, more, ma };
    }

    async function judge(clickedMuni) {
      if (state.answered) return;
      const munisHere = (answerSlugs()[state.slug]) || [];
      const isCorrect = munisHere.indexOf(clickedMuni) !== -1;
      state.answered = true;
      mapEl.classList.add("locked");
      backBtn.hidden = false;

      const info = describeAnswer();
      if (isCorrect) {
        correct++; streak++;
        questionEl.setAttribute("data-r", "correct");
        resultEl.innerHTML = "◯ 正解！ <small>" + info.shown + info.more +
          "／番号区画: " + info.ma + "</small>";
        resultEl.classList.add("shown");
        // highlight the chosen correct muni
        mapInner.querySelectorAll('path[data-name="' + cssEsc(clickedMuni) + '"]').forEach((p) => p.classList.add("aq-answer"));
        toast("正解！ " + clickedMuni, false);
      } else {
        wrong++; streak = 0;
        questionEl.setAttribute("data-r", "wrong");
        resultEl.innerHTML = "× 不正解 <small>正解: " + info.shown + info.more +
          "／番号区画: " + info.ma + "</small>";
        resultEl.classList.add("shown");
        // mark the wrong pick
        mapInner.querySelectorAll('path[data-name="' + cssEsc(clickedMuni) + '"]').forEach((p) => p.classList.add("aq-pick-wrong"));
        toast("不正解… " + (info.shown.split("（")[0]), true);
        // navigate to a correct prefecture and reveal, if not already there
        const targetSlug = state.q.answers[0].slug;
        if (state.slug !== targetSlug) {
          await showPrefecture(targetSlug);
        } else {
          markAnswerOnPref();
        }
      }
      updateStats();
    }

    // ---- memorize (study) mode ----
    function applyMemoTints() {
      if (!memorize || state.phase !== "pref") return;
      mapInner.querySelectorAll("path[data-name]").forEach((p) => {
        const n = p.getAttribute("data-name");
        if (MUNI_CODES[state.slug + "|" + n]) p.classList.add("aq-has-code");
      });
    }
    function tipText(p) {
      if (state.phase === "nation") {
        const jp = p.getAttribute("data-code");
        return PREFS[jp] ? PREFS[jp].ja + "（クリックで市区町村へ）" : null;
      }
      const n = p.getAttribute("data-name");
      if (!n) return null;
      const c = MUNI_CODES[state.slug + "|" + n];
      return c && c.length ? n + "　市外局番 " + c.join(" / ") : n + "　（市外局番データなし）";
    }
    function showTip(e) {
      const p = e.target.closest && e.target.closest("path");
      if (!p) { hideTip(); return; }
      const t = tipText(p);
      if (!t) { hideTip(); return; }
      tipEl.textContent = t;
      tipEl.classList.add("shown");
      const pad = 14;
      let x = e.clientX + pad, y = e.clientY + pad;
      const w = tipEl.offsetWidth, h = tipEl.offsetHeight;
      if (x + w > window.innerWidth - 6) x = e.clientX - w - pad;
      if (y + h > window.innerHeight - 6) y = e.clientY - h - pad;
      tipEl.style.left = Math.max(6, x) + "px";
      tipEl.style.top = Math.max(6, y) + "px";
    }
    function hideTip() { tipEl.classList.remove("shown"); }

    function setMemorize(on) {
      memorize = !!on;
      memorizeBtn.classList.toggle("is-active", memorize);
      memorizeBtn.setAttribute("aria-pressed", memorize ? "true" : "false");
      memorizeBtn.textContent = memorize ? "暗記モード：ON" : "暗記モード";
      questionEl.classList.toggle("is-memorize", memorize);
      actionsEl.classList.toggle("is-memorize", memorize);
      memoNote.hidden = !memorize;
      if (memorize) {
        // switch to free study: drop any pending result, unlock the map for exploring
        state.answered = false;
        mapEl.classList.remove("locked");
        questionEl.removeAttribute("data-r");
        resultEl.classList.remove("shown");
        applyMemoTints();
      } else {
        hideTip();
        pickQuestion(); // resume the quiz with a fresh question
      }
    }
    function toggleMemorize() { setMemorize(!memorize); }

    // ---- mouse drag to pan ----
    let panning = false, panMoved = false, psx = 0, psy = 0, psl = 0, pst = 0;
    mapEl.addEventListener("pointerdown", (e) => {
      if (e.pointerType !== "mouse" || e.button !== 0) return; // touch uses native scroll
      panning = true; panMoved = false;
      psx = e.clientX; psy = e.clientY; psl = mapEl.scrollLeft; pst = mapEl.scrollTop;
    });
    mapEl.addEventListener("pointermove", (e) => {
      if (!panning) return;
      const dx = e.clientX - psx, dy = e.clientY - psy;
      if (!panMoved && (Math.abs(dx) > 5 || Math.abs(dy) > 5)) { panMoved = true; mapEl.classList.add("grabbing"); }
      if (panMoved) { mapEl.scrollLeft = psl - dx; mapEl.scrollTop = pst - dy; e.preventDefault(); }
    });
    function endPan() { panning = false; mapEl.classList.remove("grabbing"); }
    mapEl.addEventListener("pointerup", endPan);
    mapEl.addEventListener("pointercancel", endPan);
    mapEl.addEventListener("pointerleave", endPan);

    // ---- interactions ----
    mapEl.addEventListener("click", async (e) => {
      if (panMoved) { panMoved = false; return; } // ignore the click that ends a drag
      const p = e.target.closest && e.target.closest("path");
      if (!p) return;
      if (state.phase === "nation") {
        if (state.answered) return;
        const jp = p.getAttribute("data-code");      // "JP-xx"
        const pref = PREFS[jp];
        if (!pref) return;
        await showPrefecture(pref.slug);
      } else {
        const name = p.getAttribute("data-name");    // municipality
        if (!name) return;
        if (memorize) { showTip(e); return; }         // study mode: reveal, don't grade
        if (state.answered) return;
        judge(name);
      }
    });

    // hover tooltip (memorize mode only)
    mapEl.addEventListener("mousemove", (e) => { if (memorize && !panning) showTip(e); });
    mapEl.addEventListener("mouseleave", () => { hideTip(); });

    backBtn.addEventListener("click", () => { showNation(); });

    el("aq-next").addEventListener("click", pickQuestion);
    el("aq-skip").addEventListener("click", pickQuestion);

    el("aq-zoom-in").addEventListener("click", () => setZoom(zoom + ZSTEP, true));
    el("aq-zoom-out").addEventListener("click", () => setZoom(zoom - ZSTEP, true));
    el("aq-zoom-reset").addEventListener("click", () => setZoom(1));

    memorizeBtn.addEventListener("click", toggleMemorize);

    el("aq-hint").addEventListener("click", () => {
      if (!state.q) return;
      hintPrefEl.textContent = "ヒント: " + prefJaList().join("・");
      hintPrefEl.hidden = false;
    });

    document.addEventListener("keydown", (e) => {
      if (e.target && /^(INPUT|TEXTAREA|SELECT)$/.test(e.target.tagName)) return;
      if (e.key === "m" || e.key === "M") { toggleMemorize(); return; }
      if (memorize) { if (e.key === "Escape" && state.phase === "pref") showNation(); return; }
      if (e.key === "Enter" || e.key === "ArrowRight") { e.preventDefault(); pickQuestion(); }
      else if (e.key === "Escape") { if (state.phase === "pref") showNation(); }
    });

    // Keep the original nationwide SVG markup to restore when returning.
    const NATION_SVG = mapInner.innerHTML;

    // boot
    updateStats();
    pickQuestion();
  })();
  </script>
