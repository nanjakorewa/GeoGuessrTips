---
import { getCollection } from "astro:content";
import { extractLangFromId, extractSlugFromId, buildUrl, LANGUAGES, DEFAULT_LANG } from "@lib/i18n-utils";
import { t } from "@i18n/translations";
import Head from "@components/seo/Head.astro";
import Navbar from "@components/navigation/Navbar.astro";
import Footer from "@components/footer/Footer.astro";
import SearchModal from "@components/search/SearchModal.astro";
import type { Language } from "@lib/i18n-utils";
import fs from "node:fs";
import nodePath from "node:path";

const lang: Language = "ja";
const site = "https://geopinning.space";
const siteTitle = "GeoGuessrの攻略めも";

// Translation URLs for homepage
const translationUrls: { lang: Language; url: string }[] = LANGUAGES.map((l) => ({
  lang: l,
  url: l === DEFAULT_LANG ? `${site}/` : `${site}/${l}/`,
}));

// Gather top-level section pages (type: docs, depth 1) for topic cards
const allCollections = ["rule", "quiz", "about", "web", "industry"] as const;
interface TopicCard {
  title: string;
  description: string;
  url: string;
  cardImage: string;
  weight: number;
  isRule: boolean;
}

const topicCards: TopicCard[] = [];
for (const col of allCollections) {
  const entries = await getCollection(col);
  // Only include section pages with type: "docs" (matches Hugo behavior)
  const sectionEntries = entries.filter((e: any) => {
    if (extractLangFromId(e.id) !== lang) return false;
    if (e.data.draft) return false;
    if (e.data.type !== "docs") return false;
    return true;
  });

  for (const entry of sectionEntries) {
    const slug = extractSlugFromId(entry.id);
    const url = buildUrl(col, slug, lang);
    const cardImageRaw = entry.data.card_image || entry.data.bg || "";
    let cardImage = "";
    if (cardImageRaw) {
      if (cardImageRaw.startsWith("http")) {
        cardImage = cardImageRaw;
      } else {
        const normalized = cardImageRaw.replace(/^\//, "");
        cardImage = normalized.startsWith("bg/") ? `/${normalized}` : `/bg/${normalized}`;
      }
    }

    const isRule = col === "rule";
    topicCards.push({
      title: entry.data.title,
      description: entry.data.description || "",
      url,
      cardImage,
      weight: entry.data.weight ?? 99,
      isRule,
    });
  }
}

const ruleCards = topicCards.filter((c) => c.isRule).sort((a, b) => a.weight - b.weight);
const otherCards = topicCards.filter((c) => !c.isRule).sort((a, b) => a.weight - b.weight);

// Hero slideshow: collect images from rule pages and industry galleries
interface HeroSlide {
  image: string;
  title: string;
  url: string;
}

const ruleSlides: HeroSlide[] = [];
const industrySlides: HeroSlide[] = [];

// Collect images from rule pages (country/region directories)
const ruleEntries = await getCollection("rule");
for (const entry of ruleEntries) {
  if (extractLangFromId(entry.id) !== lang) continue;
  if (entry.data.draft) continue;

  // Derive the country directory path from the entry id
  // e.g. "africa/algeria/_index.ja" -> public/rule/africa/algeria/
  const idParts = entry.id.split("/");
  // Remove the filename part (_index.ja.md etc)
  const dirParts = idParts.slice(0, -1);
  if (dirParts.length === 0) continue;

  const dirPath = nodePath.resolve("public", "rule", ...dirParts);
  if (!fs.existsSync(dirPath)) continue;

  // Only get scenic photos: JPG/WebP only (PNG is mostly screenshots,
  // license plates, road signs, logos, etc.)
  const images = fs.readdirSync(dirPath)
    .filter((f: string) => {
      if (!/\.(jpg|jpeg|webp)$/i.test(f)) return false;
      try {
        const stat = fs.statSync(nodePath.join(dirPath, f));
        return stat.size > 20000; // skip images smaller than 20KB
      } catch { return false; }
    });
  if (images.length === 0) continue;

  const slug = extractSlugFromId(entry.id);
  const url = buildUrl("rule", slug, lang);

  for (const img of images) {
    ruleSlides.push({
      image: `/rule/${dirParts.join("/")}/${img}`,
      title: entry.data.title,
      url,
    });
  }
}

// Collect gallery images from industry pages (1 representative per page)
const industryEntries = await getCollection("industry");
for (const entry of industryEntries) {
  if (extractLangFromId(entry.id) !== lang) continue;
  if (entry.data.draft) continue;
  const galleryDir = entry.data.galleryDir;
  if (!galleryDir) continue;

  const dirPath = nodePath.resolve("public", "images", "industry", galleryDir);
  if (!fs.existsSync(dirPath)) continue;

  const images = fs.readdirSync(dirPath)
    .filter((f: string) => /\.(jpg|jpeg|png|webp)$/i.test(f));
  if (images.length === 0) continue;

  const slug = extractSlugFromId(entry.id);
  const url = buildUrl("industry", slug, lang);

  // Pick one random representative image per industry page
  const pick = images[Math.floor(Math.random() * images.length)];
  industrySlides.push({
    image: `/images/industry/${galleryDir}/${pick}`,
    title: entry.data.title,
    url,
  });
}

// Combine: all rule slides + industry slides
const heroSlides: HeroSlide[] = [...ruleSlides, ...industrySlides].filter((s) => {
  // Final safety: exclude any SVG that might have slipped through
  return !s.image.endsWith(".svg");
});

// Recent updates
const recentUpdates = [
  { title: "『日本の石油・LPガス備蓄基地』のページを追加しました", link: "/industry/japan-stockpile/", date: "2026-03-23" },
  { title: "『日本のコンビナート』のページを追加しました", link: "/industry/japan-combinat/", date: "2026-03-23" },
  { title: "ボスニア・ヘルツェゴビナのページの内容を追加しました", link: "/rule/europe/bosnah/", date: "2025-11-07" },
  { title: "コスタリカ・パラグアイのページの内容を追加しました", link: "/rule/n_america/costa_rica/", date: "2025-11-06" },
  { title: "「ボリビア」を「ボリビア多民族国」へと表記変更しました", link: "/rule/cs_america/bolivia/", date: "2025-11-06" },
  { title: "ネパールの攻略メモを大幅に追記", link: "/rule/asia/nepal/", date: "2025-08-14" },
  { title: "ベトナムのページに道路写真の例を追加", link: "/rule/asia/vietnum/", date: "2025-06-28" },
];
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <Head
    title={siteTitle}
    description="GeoGuessr（ジオゲッサー）のプレイで気付いた特徴や攻略ヒントを国・地域ごとにまとめた個人メモです。地理クイズの練習や配信前の下調べに役立つ情報を整理しています。"
    lang={lang}
    canonical={`${site}/`}
    ogImage={`${site}/images/icon-512x512.png`}
    ogType="website"
    translations={translationUrls}
  />
</head>
<body>
  <header class="banner hero-surface hero-slideshow-header">
    <Navbar lang={lang} isHome={true} />

    {/* Hero slideshow */}
    <div class="hero-slideshow" aria-label="サイト内の画像スライドショー">
      <div class="hero-slideshow__slide hero-slideshow__slide--active" aria-hidden="false"></div>
      <div class="hero-slideshow__slide" aria-hidden="true"></div>
      <div class="hero-slideshow__overlay"></div>
      <div class="hero-slideshow__content">
<a class="hero-slideshow__link" href="/">
          <span class="hero-slideshow__link-label"></span>
          <svg class="hero-slideshow__link-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
      <div class="hero-slideshow__progress">
        <div class="hero-slideshow__progress-bar"></div>
      </div>
    </div>
    <script is:inline define:vars={{ heroSlides }}>
      (function() {
        const slides = heroSlides;
        if (!slides || slides.length === 0) return;

        // Shuffle (Fisher-Yates)
        for (let i = slides.length - 1; i > 0; i--) {
          const j = Math.floor(Math.random() * (i + 1));
          [slides[i], slides[j]] = [slides[j], slides[i]];
        }

        const els = document.querySelectorAll('.hero-slideshow__slide');
        const link = document.querySelector('.hero-slideshow__link');
        const label = document.querySelector('.hero-slideshow__link-label');
        const progressBar = document.querySelector('.hero-slideshow__progress-bar');
        if (!els.length || !link || !label) return;

        let current = 0;
        let activeIndex = 0; // which of the two els is active

        function setSlide(el, index) {
          el.style.backgroundImage = "url('" + slides[index].image + "')";
        }

        function showSlide(index) {
          const activeEl = els[activeIndex];
          const nextElIndex = activeIndex === 0 ? 1 : 0;
          const nextEl = els[nextElIndex];

          setSlide(nextEl, index);
          // Crossfade
          activeEl.classList.remove('hero-slideshow__slide--active');
          activeEl.setAttribute('aria-hidden', 'true');
          nextEl.classList.add('hero-slideshow__slide--active');
          nextEl.setAttribute('aria-hidden', 'false');
          activeIndex = nextElIndex;

          link.setAttribute('href', slides[index].url);
          label.textContent = slides[index].title;

          // Restart progress bar
          if (progressBar) {
            progressBar.style.animation = 'none';
            progressBar.offsetHeight; // trigger reflow
            progressBar.style.animation = '';
          }
        }

        // Initial slide
        setSlide(els[0], 0);
        link.setAttribute('href', slides[0].url);
        label.textContent = slides[0].title;

        // Preload next image
        function preloadNext() {
          const next = (current + 1) % slides.length;
          const img = new Image();
          img.src = slides[next].image;
        }

        // Auto-rotate
        const INTERVAL = 5000;
        preloadNext();
        setInterval(function() {
          current = (current + 1) % slides.length;
          showSlide(current);
          preloadNext();
        }, INTERVAL);
      })();
    </script>
  </header>

  {/* Topics section */}
  <section class="section" style="margin-bottom:0px;padding-bottom:0px;">
    <div class="container">
      {ruleCards.length > 0 && (
        <div class="row justify-content-center mb-4">
          <div class="col-12">
            <h2 class="section-title text-left" style="margin-bottom:1.5rem;">{t("homepage_rule_section_title", lang)}</h2>
          </div>
          {ruleCards.map((card) => (
            <div class="col-lg-4 col-sm-6 mb-3">
              <a
                href={card.url}
                class={`px-3 py-2 shadow d-block match-height apply-bg ${card.cardImage ? "card-with-image" : ""}`}
                style={card.cardImage ? `--card-bg-image: url('${card.cardImage}');` : undefined}
              >
                <h3 class="mb-3 mt-0">
                  {card.weight === 1 && <i class="fas fa-map-marker-alt" style="margin-right:0.2em; color:rgb(188, 57, 57);"></i>}
                  {card.title}
                </h3>
                <p class="mb-0">{card.description}</p>
              </a>
            </div>
          ))}
        </div>
      )}

      <div class="row justify-content-center">
        {otherCards.length > 0 && (
          <>
            <div class="col-12">
              <h2 class="section-title text-left" style="margin-bottom:1.5rem;">{t("homepage_other_section_title", lang)}</h2>
            </div>
            {otherCards.map((card) => (
              <div class="col-lg-4 col-sm-6 mb-3">
                <a
                  href={card.url}
                  class={`px-3 py-2 shadow d-block match-height apply-bg ${card.cardImage ? "card-with-image" : ""}`}
                  style={card.cardImage ? `--card-bg-image: url('${card.cardImage}');` : undefined}
                >
                  <h3 class="mb-3 mt-0">{card.title}</h3>
                  <p class="mb-0">{card.description}</p>
                </a>
              </div>
            ))}
          </>
        )}
        <div class="col-lg-4 col-sm-6 mb-3">
          <a href="https://nanjakorewa.booth.pm/" class="px-3 py-2 shadow d-block match-height apply-bg card-with-image" style="--card-bg-image: url('/bg/default.jpg');">
            <h3 class="mb-3 mt-0">BOOTH</h3>
            <p class="mb-0">{t("homepage_booth_caption", lang)}</p>
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* Updates + Milestone (Japanese only) */}
  <section class="section section-updates pt-0 pb-5">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-xl-9 col-lg-10">
          <div class="update-milestone-card">
            <div class="update-milestone-card__updates">
              <div class="update-milestone-card__label">最近の更新</div>
              <ul class="update-milestone-card__list">
                {recentUpdates.map((item) => (
                  <li class="update-milestone-card__item">
                    <a href={item.link}>{item.title}</a>
                    <span class="update-milestone-card__date">@{item.date}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div class="update-milestone-card__divider" aria-hidden="true"></div>
            <div class="update-milestone-card__milestone">
              <div class="update-milestone-card__milestone-badge">Milestone</div>
              <h3 class="update-milestone-card__title">サイト累計50万アクセスを突破しました</h3>
              <p class="update-milestone-card__text">いつもご覧いただきありがとうございます。</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer lang={lang} title={siteTitle} permalink={`${site}/`} translations={translationUrls} />
  <SearchModal lang={lang} />
</body>
</html>
