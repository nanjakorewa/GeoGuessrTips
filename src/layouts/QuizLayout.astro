---
import type { Language } from "@lib/i18n-utils";
import { getLocale, buildUrl, extractLangFromId, extractSlugFromId, LANGUAGES, DEFAULT_LANG } from "@lib/i18n-utils";
import { t } from "@i18n/translations";
import { generateDescription } from "@lib/seo-utils";
import { getCollection } from "astro:content";
import Head from "@components/seo/Head.astro";
import Navbar from "@components/navigation/Navbar.astro";
import Footer from "@components/footer/Footer.astro";
import SearchModal from "@components/search/SearchModal.astro";

interface Props {
  entry: any;
  lang: Language;
  collection: string;
  hasContent?: boolean;
}

const { entry, lang, collection, hasContent = true } = Astro.props;
const data = entry.data;
const site = "https://geopinning.space";
const siteTitle = "GeoGuessrの攻略めも";

// --- SEO ---
const seoTitle = data.quiz_suffix
  ? `${data.title} - ${data.quiz_suffix} | ${siteTitle}`
  : `${data.title} | ${siteTitle}`;
const seoDescription = generateDescription(entry, lang, collection);
const ogImage = `${site}/images/icon-512x512.png`;
const currentSlug = extractSlugFromId(entry.id);
const canonical = `${site}${buildUrl(collection, currentSlug, lang)}`;

// --- Translation URLs ---
const allEntries = await getCollection(collection);
const translationUrls: { lang: Language; url: string }[] = [];
for (const tLang of LANGUAGES) {
  const translationId = entry.id.replace(/\.(ja|en|id|es|pt)$/, `.${tLang}`);
  const found = allEntries.find((e: any) => e.id === translationId);
  if (found) {
    translationUrls.push({ lang: tLang, url: `${site}${buildUrl(collection, currentSlug, tLang)}` });
  }
}

// --- Breadcrumbs ---
interface Crumb { name: string; url: string }
const crumbs: Crumb[] = [
  { name: t("toppage", lang), url: lang === DEFAULT_LANG ? "/" : `/${lang}/` },
  { name: t("breadcrumb_quiz", lang) || "Quiz", url: `${lang === DEFAULT_LANG ? "" : `/${lang}`}/quiz/` },
];
if (currentSlug) {
  crumbs.push({ name: data.title, url: buildUrl(collection, currentSlug, lang) });
}

// --- Dates ---
const publishedTime = data.date ? new Date(data.date) : undefined;
const modifiedTime = data.lastmod ? new Date(data.lastmod) : publishedTime;

// --- Share ---
const shareText = encodeURIComponent(`${data.title} | ${siteTitle}`);
const shareURL = `https://twitter.com/intent/tweet?url=${encodeURIComponent(canonical)}&text=${shareText}`;

// --- Quiz Data ---
const options = data.quiz_options || [];
const correctAnswer = data.quiz_answer || 1;
const mapUrl = data.quiz_map_url || "";
const difficulty = data.difficulty || 1;
const hint = data.quiz_hint || "";
const question = data.quiz_question || t("quiz_default_question", lang);
const quizImage = data.quiz_image || "";
const quizNum = currentSlug.replace("quiz", "");
// Build quiz image URL (relative to the quiz content directory)
const quizImageUrl = quizImage ? `/quiz/quiz${quizNum}/${quizImage}` : "";

// --- Group-aware quiz entries ---
const quizGroup = data.quiz_group || "";
const allQuizEntries = allEntries
  .filter((e: any) => extractLangFromId(e.id) === lang && e.data.pagetype === "quiz")
  .sort((a: any, b: any) => (a.data.weight || 99) - (b.data.weight || 99));

// Filter by group for numbering, progress, and navigation
const quizEntries = quizGroup
  ? allQuizEntries.filter((e: any) => e.data.quiz_group === quizGroup)
  : allQuizEntries;
const currentIndex = quizEntries.findIndex((e: any) => e.id === entry.id);
const prevQuiz = currentIndex > 0 ? quizEntries[currentIndex - 1] : null;
const nextQuiz = currentIndex < quizEntries.length - 1 ? quizEntries[currentIndex + 1] : null;
const prevUrl = prevQuiz ? buildUrl(collection, extractSlugFromId(prevQuiz.id), lang) : "";
const nextUrl = nextQuiz ? buildUrl(collection, extractSlugFromId(nextQuiz.id), lang) : "";
const totalQuizzes = quizEntries.length;
const groupQuizNum = currentIndex + 1; // 1-based index within group

// --- Quiz group index URL (for "back to list" link) ---
const quizGroupIndexEntry = quizGroup
  ? allEntries.find((e: any) => extractLangFromId(e.id) === lang && e.data.pagetype === "quiz-index" && e.data.quiz_group === quizGroup)
  : null;
const quizGroupIndexUrl = quizGroupIndexEntry
  ? buildUrl(collection, extractSlugFromId(quizGroupIndexEntry.id), lang)
  : (lang === "ja" ? "/quiz/" : `/${lang}/quiz/`);

// --- Last modified ---
const lastmodDisplay = modifiedTime
  ? modifiedTime.toLocaleDateString("en-GB", { day: "2-digit", month: "short", year: "numeric" })
  : "";

// Difficulty labels
const difficultyLabels = ["", "\u2605", "\u2605\u2605", "\u2605\u2605\u2605"];
const diffLabelKeys = ["", "quiz_diff_easy", "quiz_diff_medium", "quiz_diff_hard"];
const diffLabel = difficulty > 0 ? t(diffLabelKeys[difficulty], lang) : "";
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <Head
    title={seoTitle}
    description={seoDescription}
    lang={lang}
    canonical={canonical}
    ogImage={ogImage}
    ogType="article"
    publishedTime={publishedTime}
    modifiedTime={modifiedTime}
    translations={translationUrls}
    pageData={data}
    breadcrumbs={crumbs}
    collection={collection}
  />
  <style>
    /* ===== Quiz Page Styles ===== */
    .quiz-container {
      max-width: 720px;
      margin: 0 auto;
      padding: 1.5rem 1rem 3rem;
    }

    /* Header */
    .quiz-header {
      text-align: center;
      margin-bottom: 2rem;
    }
    .quiz-header-number {
      font-size: 0.85rem;
      font-weight: 700;
      color: var(--primary-color);
      text-transform: uppercase;
      letter-spacing: 0.15em;
      margin-bottom: 0.3rem;
    }
    .quiz-header-title {
      font-size: 1.6rem;
      font-weight: 800;
      margin: 0 0 0.5rem;
      color: var(--text-color);
    }
    .quiz-header-meta {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.8rem;
      font-size: 0.85rem;
    }
    .quiz-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      padding: 0.2em 0.7em;
      border-radius: 20px;
      font-weight: 600;
      font-size: 0.82rem;
    }
    .quiz-badge-theme {
      background: rgba(68, 110, 114, 0.08);
      border: 1px solid rgba(68, 110, 114, 0.2);
      color: var(--primary-color);
    }
    .quiz-badge-diff {
      background: rgba(200, 160, 50, 0.1);
      border: 1px solid rgba(200, 160, 50, 0.3);
      color: #9a7b20;
    }
    [data-theme="dark"] .quiz-badge-diff {
      color: #d4b44a;
    }
    .quiz-progress {
      display: flex;
      justify-content: center;
      gap: 4px;
      margin-top: 1rem;
    }
    .quiz-progress-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--border-soft);
      transition: background 0.2s;
    }
    .quiz-progress-dot.is-current {
      background: var(--primary-color);
      transform: scale(1.3);
    }
    .quiz-progress-dot.is-done {
      background: rgba(68, 110, 114, 0.4);
    }

    /* Map area */
    .quiz-map-wrapper {
      position: relative;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 4px 24px rgba(0,0,0,0.1);
      margin-bottom: 1.5rem;
      background: #1a1d21;
    }
    .quiz-map-wrapper iframe {
      display: block;
      width: 100%;
      height: 450px;
      border: 0;
    }
    .quiz-map-overlay {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 66px;
      background: rgba(22, 25, 29, 0.88);
      display: flex;
      align-items: center;
      padding: 0 1.1rem;
      gap: 0.8rem;
      z-index: 10;
      pointer-events: none;
      color: #fff;
      text-shadow: 0 1px 4px rgba(0,0,0,0.3);
    }
    .quiz-map-overlay-num {
      font-size: 1.3rem;
      font-weight: 800;
      letter-spacing: 0.05em;
      flex-shrink: 0;
    }
    .quiz-map-overlay-q {
      font-size: 1rem;
      font-weight: 600;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    /* Quiz image (e.g. map for quiz7) */
    .quiz-image-wrapper {
      position: relative;
      margin-bottom: 1.2rem;
      border-radius: 14px;
      overflow: hidden;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
      border: 1px solid var(--border-soft);
      background: #1a1d21;
    }
    .quiz-image-wrapper img {
      display: block;
      width: 100%;
      height: auto;
      max-height: 450px;
      object-fit: contain;
    }
    .quiz-image-overlay {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 56px;
      background: rgba(22, 25, 29, 0.88);
      display: flex;
      align-items: center;
      padding: 0 1.1rem;
      gap: 0.8rem;
      z-index: 10;
      pointer-events: none;
      color: #fff;
      text-shadow: 0 1px 4px rgba(0,0,0,0.3);
    }
    .quiz-image-overlay-num {
      font-size: 1.3rem;
      font-weight: 800;
      letter-spacing: 0.05em;
      flex-shrink: 0;
    }
    .quiz-image-overlay-q {
      font-size: 1rem;
      font-weight: 600;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    /* Hint */
    .quiz-hint {
      background: rgba(68, 110, 114, 0.06);
      border: 1px solid rgba(68, 110, 114, 0.15);
      border-radius: 10px;
      padding: 0.7rem 1rem;
      margin-bottom: 1.2rem;
      font-size: 0.9rem;
      color: var(--text-color);
    }
    .quiz-hint::before {
      content: "\f0eb";
      font-family: "Font Awesome 5 Free";
      font-weight: 900;
      margin-right: 0.5rem;
      color: var(--primary-color);
    }

    /* Options */
    .quiz-options {
      display: flex;
      flex-direction: column;
      gap: 0.7rem;
      margin-bottom: 1.5rem;
    }
    .quiz-option-btn {
      display: flex;
      align-items: center;
      gap: 0.9rem;
      background: var(--surface-color, #fff);
      border: 2px solid var(--border-soft);
      border-radius: 14px;
      padding: 1rem 1.3rem;
      cursor: pointer;
      transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
      font-size: 1.05rem;
      font-weight: 600;
      color: var(--text-color);
      text-align: left;
    }
    .quiz-option-btn:hover:not(.is-locked) {
      border-color: var(--primary-color);
      transform: translateX(4px);
      box-shadow: 0 4px 16px rgba(68, 110, 114, 0.12);
    }
    .quiz-option-index {
      flex-shrink: 0;
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: rgba(68, 110, 114, 0.08);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 800;
      font-size: 0.9rem;
      color: var(--primary-color);
      transition: all 0.25s;
    }
    .quiz-option-btn.is-correct {
      background: var(--primary-color);
      border-color: var(--primary-color);
      color: #fff;
      animation: qCorrectPulse 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
      box-shadow: 0 0 0 0 rgba(68, 110, 114, 0.4);
    }
    .quiz-option-btn.is-correct .quiz-option-index {
      background: rgba(255,255,255,0.25);
      color: #fff;
    }
    .quiz-option-btn.is-correct .quiz-option-index::after {
      content: "\2713";
      position: absolute;
      font-size: 1.1rem;
      font-weight: 900;
    }
    .quiz-option-btn.is-correct .quiz-option-index span { visibility: hidden; }
    .quiz-option-btn.is-correct::after {
      content: "";
      position: absolute;
      inset: 0;
      border-radius: 14px;
      box-shadow: 0 0 20px 4px rgba(68, 110, 114, 0.35);
      animation: qGlow 1.5s ease-out forwards;
      pointer-events: none;
    }
    .quiz-option-btn.is-incorrect {
      background: rgba(179, 64, 64, 0.08);
      border-color: rgba(179, 64, 64, 0.5);
      color: rgba(140, 40, 40, 0.85);
      animation: qShake 0.5s cubic-bezier(0.36, 0.07, 0.19, 0.97);
    }
    .quiz-option-btn.is-incorrect .quiz-option-index {
      background: rgba(179, 64, 64, 0.15);
      color: rgba(140, 40, 40, 0.85);
    }
    .quiz-option-btn.is-incorrect .quiz-option-index::after {
      content: "\2717";
      position: absolute;
      font-size: 1.1rem;
      font-weight: 900;
    }
    .quiz-option-btn.is-incorrect .quiz-option-index span { visibility: hidden; }
    .quiz-option-btn.is-reveal-correct {
      background: var(--primary-color);
      border-color: var(--primary-color);
      color: #fff;
      animation: qRevealBounce 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .quiz-option-btn.is-reveal-correct .quiz-option-index {
      background: rgba(255,255,255,0.25);
      color: #fff;
    }
    .quiz-option-btn {
      position: relative;
      overflow: visible;
    }
    .quiz-option-index {
      position: relative;
    }
    @keyframes qCorrectPulse {
      0% { transform: scale(1); }
      30% { transform: scale(1.05); }
      60% { transform: scale(0.98); }
      100% { transform: scale(1); }
    }
    @keyframes qGlow {
      0% { box-shadow: 0 0 20px 4px rgba(68, 110, 114, 0.35); }
      100% { box-shadow: 0 0 0 0 rgba(68, 110, 114, 0); }
    }
    @keyframes qShake {
      0%, 100% { transform: translateX(0); }
      15% { transform: translateX(-10px); }
      30% { transform: translateX(8px); }
      45% { transform: translateX(-6px); }
      60% { transform: translateX(5px); }
      75% { transform: translateX(-3px); }
      90% { transform: translateX(2px); }
    }
    @keyframes qRevealBounce {
      0% { transform: scale(0.95); opacity: 0.7; }
      50% { transform: scale(1.04); }
      100% { transform: scale(1); opacity: 1; }
    }

    /* Explanation */
    .quiz-explanation {
      opacity: 0;
      max-height: 0;
      overflow: hidden;
      transition: opacity 0.5s ease, max-height 0.5s ease;
    }
    .quiz-explanation.is-visible {
      opacity: 1;
      max-height: 3000px;
    }
    .quiz-explanation-inner {
      background: var(--surface-alt, #f5f3f1);
      border-radius: 14px;
      padding: 1.5rem;
      margin-top: 0.5rem;
    }
    .quiz-explanation-label {
      font-size: 0.82rem;
      font-weight: 700;
      color: var(--primary-color);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 0.6rem;
    }
    .quiz-explanation-inner .content {
      font-size: 0.95rem;
      line-height: 1.75;
    }

    /* Dynamic element styles moved to <style is:global> below */

    /* Navigation */
    .quiz-nav {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      margin-top: 2rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--border-soft);
    }
    .quiz-nav-prev { justify-self: start; }
    .quiz-nav-next { justify-self: end; }
    .quiz-nav a {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.6rem 1.2rem;
      border-radius: 10px;
      font-weight: 600;
      font-size: 0.9rem;
      color: var(--primary-color);
      background: rgba(68, 110, 114, 0.06);
      border: 1px solid rgba(68, 110, 114, 0.15);
      text-decoration: none;
      transition: all 0.2s;
    }
    .quiz-nav a:hover {
      background: rgba(68, 110, 114, 0.12);
      transform: translateY(-1px);
    }
    .quiz-nav-list {
      justify-self: center;
      font-size: 0.82rem !important;
      padding: 0.4rem 0.8rem !important;
      opacity: 0.8;
    }

    /* Breadcrumb */
    .quiz-breadcrumb {
      font-size: 0.82rem;
      color: rgba(100,100,100,0.7);
      margin-bottom: 1rem;
    }
    .quiz-breadcrumb a { color: rgba(100,100,100,0.7); text-decoration: none; }
    .quiz-breadcrumb a:hover { color: var(--primary-color); }

    @media (max-width: 640px) {
      .quiz-container { padding: 1rem 0.75rem 2rem; }
      .quiz-header-title { font-size: 1.3rem; }
      .quiz-map-wrapper iframe { height: 320px; }
      .quiz-map-overlay { height: 54px; }
      .quiz-map-overlay-num { font-size: 1.1rem; }
      .quiz-map-overlay-q { font-size: 0.88rem; }
      .quiz-option-btn { padding: 0.85rem 1rem; font-size: 0.95rem; }
      .quiz-image-overlay { height: 46px; }
      .quiz-image-overlay-num { font-size: 1.1rem; }
      .quiz-image-overlay-q { font-size: 0.85rem; }
      .quiz-image-wrapper img { max-height: 350px; }
    }
  </style>
  <style is:global>
    /* Styles for dynamically created elements (JS createElement) */
    .quiz-overlay {
      position: fixed;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      opacity: 0;
      pointer-events: none;
      z-index: 5000;
      transition: opacity 0.35s ease;
    }
    .quiz-overlay.is-visible {
      opacity: 1;
      pointer-events: auto;
    }
    .quiz-overlay-bg {
      position: absolute;
      inset: 0;
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
    }
    .quiz-overlay.is-correct .quiz-overlay-bg { background: rgba(68, 110, 114, 0.5); }
    .quiz-overlay.is-miss .quiz-overlay-bg { background: rgba(89, 30, 30, 0.45); }
    .quiz-overlay-content {
      position: relative;
      z-index: 1;
      text-align: center;
    }
    .quiz-overlay-icon {
      font-size: clamp(4rem, 12vw, 7rem);
      display: block;
      animation: qOverlayPop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }
    .quiz-overlay-text {
      color: #fff;
      font-size: clamp(1.6rem, 5vw, 2.6rem);
      font-weight: 800;
      letter-spacing: 0.15em;
      margin-top: 0.6rem;
      text-shadow: 0 4px 20px rgba(0,0,0,0.5);
      animation: qTextSlideUp 0.5s 0.15s ease both;
    }
    @keyframes qOverlayPop {
      0% { transform: scale(0.2) rotate(-10deg); opacity: 0; }
      60% { transform: scale(1.15) rotate(3deg); opacity: 1; }
      100% { transform: scale(1) rotate(0deg); opacity: 1; }
    }
    @keyframes qTextSlideUp {
      0% { transform: translateY(20px); opacity: 0; }
      100% { transform: translateY(0); opacity: 1; }
    }
    .quiz-confetti {
      position: fixed;
      z-index: 5001;
      pointer-events: none;
      width: 10px;
      height: 10px;
      border-radius: 2px;
    }
    .quiz-ring {
      position: absolute;
      top: 50%;
      left: 50%;
      width: 40px;
      height: 40px;
      margin-top: -20px;
      margin-left: -20px;
      border-radius: 50%;
      border: 3px solid var(--primary-color);
      pointer-events: none;
      animation: qRingExpand 0.8s ease-out forwards;
      z-index: 10;
    }
    @keyframes qRingExpand {
      0% { transform: scale(0.5); opacity: 1; }
      100% { transform: scale(12); opacity: 0; }
    }
    .quiz-vignette {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 4999;
      animation: qVignetteFlash 0.6s ease-out forwards;
    }
    @keyframes qVignetteFlash {
      0% { box-shadow: inset 0 0 120px 40px rgba(179, 40, 40, 0.5); }
      100% { box-shadow: inset 0 0 0 0 rgba(179, 40, 40, 0); }
    }
    @keyframes qScreenShake {
      0%, 100% { transform: translate(0, 0); }
      10% { transform: translate(-8px, -4px); }
      20% { transform: translate(8px, 2px); }
      30% { transform: translate(-6px, 4px); }
      40% { transform: translate(6px, -2px); }
      50% { transform: translate(-4px, 2px); }
      60% { transform: translate(4px, -2px); }
      70% { transform: translate(-2px, 2px); }
      80% { transform: translate(2px, -1px); }
    }
    .quiz-screen-shake {
      animation: qScreenShake 0.5s ease-in-out;
    }
  </style>
</head>
<body>
  <header class="shadow-bottom sticky-top bg-white">
    <Navbar lang={lang} isHome={false} />
  </header>

  <main class="quiz-container">
    {/* Breadcrumb */}
    <nav class="quiz-breadcrumb">
      {crumbs.map((c, i) =>
        i === crumbs.length - 1
          ? <span>{c.name}</span>
          : <><a href={c.url}>{c.name}</a> <span>/</span> </>
      )}
    </nav>

    {/* Header */}
    <div class="quiz-header">
      <div class="quiz-header-number">{t("quiz_question_label", lang)} {groupQuizNum}</div>
      <h1 class="quiz-header-title">{data.title}</h1>
      <div class="quiz-header-meta">
        {data.quiz_suffix && <span class="quiz-badge quiz-badge-theme">{data.quiz_suffix}</span>}
        {difficulty > 0 && <span class="quiz-badge quiz-badge-diff">{diffLabel} {difficultyLabels[difficulty]}</span>}
      </div>
      {/* Progress dots */}
      <div class="quiz-progress">
        {quizEntries.map((_: any, i: number) =>
          <div class={`quiz-progress-dot${i === currentIndex ? " is-current" : i < currentIndex ? " is-done" : ""}`} />
        )}
      </div>
    </div>

    {/* Map */}
    {mapUrl && (
      <div class="quiz-map-wrapper">
        <div class="quiz-map-overlay">
          <span class="quiz-map-overlay-num">Q{groupQuizNum}</span>
          <span class="quiz-map-overlay-q">{question}</span>
        </div>
        <iframe src={mapUrl} allowfullscreen loading="lazy"></iframe>
      </div>
    )}

    {/* Quiz image */}
    {quizImageUrl && (
      <div class="quiz-image-wrapper">
        <div class="quiz-image-overlay">
          <span class="quiz-image-overlay-num">Q{groupQuizNum}</span>
          <span class="quiz-image-overlay-q">{question}</span>
        </div>
        <img src={quizImageUrl} alt={`Quiz ${groupQuizNum}`} />
      </div>
    )}

    {/* Hint */}
    {hint && <div class="quiz-hint">{hint}</div>}

    {/* Options */}
    {options.length > 0 && (
      <div class="quiz-options" id="quiz-options" data-correct={correctAnswer} data-text-correct={t("quiz_correct", lang)} data-text-miss={t("quiz_miss", lang)}>
        {options.map((opt: string, i: number) => (
          <button class="quiz-option-btn" data-index={i + 1} type="button">
            <span class="quiz-option-index"><span>{String.fromCharCode(65 + i)}</span></span>
            <span>{opt}</span>
          </button>
        ))}
      </div>
    )}

    {/* Explanation (hidden until correct) */}
    <div class="quiz-explanation" id="quiz-explanation">
      <div class="quiz-explanation-inner">
        <div class="quiz-explanation-label">{t("quiz_explanation", lang)}</div>
        {hasContent && (
          <div class="content">
            <slot />
          </div>
        )}
      </div>
    </div>

    {/* Prev / Next navigation */}
    <nav class="quiz-nav">
      <div class="quiz-nav-prev">
        {prevUrl && <a href={prevUrl}><i class="fas fa-chevron-left"></i> {t("quiz_prev", lang)}</a>}
      </div>
      <a href={quizGroupIndexUrl} class="quiz-nav-list"><i class="fas fa-th-list"></i> {t("quiz_back_to_list", lang)}</a>
      <div class="quiz-nav-next">
        {nextUrl && <a href={nextUrl}>{t("quiz_next", lang)} <i class="fas fa-chevron-right"></i></a>}
      </div>
    </nav>

    {lastmodDisplay && <p style="font-size:0.8rem;color:rgba(100,100,100,0.5);margin-top:1rem;">{t("quiz_updated_on", lang)} {lastmodDisplay}</p>}
  </main>

  {/* Quiz interaction script */}
  <script is:inline>
  (function(){
    var container = document.getElementById('quiz-options');
    if (!container) return;
    var correct = parseInt(container.dataset.correct, 10);
    var textCorrect = container.dataset.textCorrect || '正解！';
    var textMiss = container.dataset.textMiss || 'はずれ';
    var buttons = container.querySelectorAll('.quiz-option-btn');
    var explanation = document.getElementById('quiz-explanation');
    var locked = false;

    function createOverlay(cls, icon, text) {
      var el = document.createElement('div');
      el.className = 'quiz-overlay ' + cls;
      el.innerHTML = '<div class="quiz-overlay-bg"></div><div class="quiz-overlay-content"><span class="quiz-overlay-icon">' + icon + '</span><span class="quiz-overlay-text">' + text + '</span></div>';
      document.body.appendChild(el);
      return el;
    }

    function flash(el, duration) {
      el.classList.add('is-visible');
      setTimeout(function(){ el.classList.remove('is-visible'); }, duration || 1200);
    }

    // Confetti burst for correct answers (improved physics)
    function spawnConfetti() {
      var colors = ['#446E72', '#5A9196', '#FFD700', '#FF6B6B', '#48BB78', '#9F7AEA', '#F6AD55', '#63B3ED', '#FC8181', '#68D391'];
      var count = 55;
      for (var i = 0; i < count; i++) {
        (function(idx) {
          setTimeout(function() {
            var p = document.createElement('div');
            p.className = 'quiz-confetti';
            var color = colors[Math.floor(Math.random() * colors.length)];
            var left = 20 + Math.random() * 60; // cluster more toward center
            var size = 6 + Math.random() * 10;
            var duration = 1.5 + Math.random() * 2;
            var drift = (Math.random() - 0.5) * 300;
            var startY = -10 - Math.random() * 40;
            var rotation = Math.floor(Math.random() * 1080);
            var shape = Math.random();
            var radius = shape > 0.6 ? '50%' : shape > 0.3 ? '2px' : '0';
            p.style.cssText = 'left:' + left + '%;top:' + startY + 'px;width:' + size + 'px;height:' + (size * (0.5 + Math.random() * 0.8)) + 'px;background:' + color + ';border-radius:' + radius + ';opacity:1;';
            document.body.appendChild(p);
            // Animate with JS for more natural movement
            var startTime = performance.now();
            var startLeft = parseFloat(p.style.left);
            function animate(now) {
              var elapsed = (now - startTime) / 1000;
              var progress = elapsed / duration;
              if (progress >= 1) { p.remove(); return; }
              var y = startY + elapsed * elapsed * 220; // gravity
              var x = drift * Math.sin(elapsed * 3) * 0.3 + drift * progress;
              var rot = rotation * progress;
              var opacity = progress > 0.75 ? 1 - (progress - 0.75) / 0.25 : 1;
              p.style.transform = 'translateX(' + x + 'px) translateY(' + y + 'px) rotate(' + rot + 'deg)';
              p.style.opacity = opacity;
              requestAnimationFrame(animate);
            }
            requestAnimationFrame(animate);
          }, idx * 25);
        })(i);
      }
    }

    // Ring expansion from button
    function spawnRing(btn) {
      var ring = document.createElement('div');
      ring.className = 'quiz-ring';
      btn.appendChild(ring);
      setTimeout(function(){ ring.remove(); }, 900);
    }

    // Red vignette flash
    function flashVignette() {
      var v = document.createElement('div');
      v.className = 'quiz-vignette';
      document.body.appendChild(v);
      setTimeout(function(){ v.remove(); }, 700);
    }

    // Screen shake for wrong answers
    function shakeScreen() {
      document.body.classList.add('quiz-screen-shake');
      setTimeout(function(){ document.body.classList.remove('quiz-screen-shake'); }, 500);
    }

    buttons.forEach(function(btn) {
      btn.addEventListener('click', function() {
        if (locked) return;
        var idx = parseInt(btn.dataset.index, 10);
        var isCorrect = idx === correct;

        // Lock all buttons
        locked = true;
        buttons.forEach(function(b){ b.classList.add('is-locked'); });

        if (isCorrect) {
          btn.classList.add('is-correct');
          spawnRing(btn);
          spawnConfetti();
          flash(createOverlay('is-correct', '\u{1F389}', textCorrect), 1600);
          if (explanation) {
            setTimeout(function(){
              explanation.classList.add('is-visible');
              explanation.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }, 800);
          }
        } else {
          btn.classList.add('is-incorrect');
          shakeScreen();
          flashVignette();
          // Show correct answer after shake finishes (0.5s)
          setTimeout(function() {
            buttons.forEach(function(b) {
              if (parseInt(b.dataset.index, 10) === correct) b.classList.add('is-reveal-correct');
            });
            if (explanation) {
              setTimeout(function(){
                explanation.classList.add('is-visible');
                explanation.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
              }, 300);
            }
          }, 550);
        }
      });
    });
  })();
  </script>

  <Footer lang={lang} title={data.title} permalink={canonical} translations={translationUrls} />
  <SearchModal lang={lang} />
</body>
</html>
