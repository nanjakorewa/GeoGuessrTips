---
import type { Language } from "@lib/i18n-utils";
import { buildUrl, extractLangFromId, extractSlugFromId, LANGUAGES, DEFAULT_LANG } from "@lib/i18n-utils";
import { t } from "@i18n/translations";
import { generateDescription } from "@lib/seo-utils";
import { getCollection } from "astro:content";
import municipalitiesData from "../data/municipalities.json";
import areacodeData from "../data/areacodes.json";
import highwayData from "../data/highways.json";
import Head from "@components/seo/Head.astro";
import Navbar from "@components/navigation/Navbar.astro";
import Footer from "@components/footer/Footer.astro";
import SearchModal from "@components/search/SearchModal.astro";

interface Props {
  entry: any;
  lang: Language;
  collection: string;
  hasContent?: boolean;
}

const { entry, lang, collection, hasContent = false } = Astro.props;
const data = entry.data;
const site = "https://geopinning.space";
const siteTitle = "GeoGuessrの攻略めも";

// --- SEO ---
const seoTitle = `${data.title} | ${siteTitle}`;
const seoDescription = data.description || generateDescription(entry, lang, collection);
const ogImage = `${site}/images/icon-512x512.png`;
const currentSlug = extractSlugFromId(entry.id);
const canonical = `${site}${buildUrl(collection, currentSlug, lang)}`;

// --- Translation URLs ---
const allEntries = await getCollection(collection);
const translationUrls: { lang: Language; url: string }[] = [];
for (const tLang of LANGUAGES) {
  const translationId = entry.id.replace(/\.(ja|en|id|es|pt)$/, `.${tLang}`);
  const found = allEntries.find((e: any) => e.id === translationId);
  if (found) {
    translationUrls.push({ lang: tLang, url: `${site}${buildUrl(collection, currentSlug, tLang)}` });
  }
}

// --- Breadcrumbs ---
interface Crumb { name: string; url: string }
const crumbs: Crumb[] = [
  { name: t("toppage", lang), url: lang === DEFAULT_LANG ? "/" : `/${lang}/` },
  { name: data.title, url: buildUrl(collection, currentSlug, lang) },
];

// --- Dates ---
const publishedTime = data.date ? new Date(data.date) : undefined;
const modifiedTime = data.lastmod ? new Date(data.lastmod) : publishedTime;

// --- Discover quiz groups (quiz-index pages) ---
const groupEntries = allEntries
  .filter((e: any) => extractLangFromId(e.id) === lang && e.data.pagetype === "quiz-index")
  .sort((a: any, b: any) => (a.data.weight || 99) - (b.data.weight || 99));

// Count quizzes per group
const quizEntries = allEntries.filter((e: any) => extractLangFromId(e.id) === lang && e.data.pagetype === "quiz");

const difficultyLabels: Record<string, string[]> = {
  ja: ["", t("quiz_diff_easy", "ja"), t("quiz_diff_medium", "ja"), t("quiz_diff_hard", "ja")],
  en: ["", t("quiz_diff_easy", "en"), t("quiz_diff_medium", "en"), t("quiz_diff_hard", "en")],
  es: ["", t("quiz_diff_easy", "es"), t("quiz_diff_medium", "es"), t("quiz_diff_hard", "es")],
  id: ["", t("quiz_diff_easy", "id"), t("quiz_diff_medium", "id"), t("quiz_diff_hard", "id")],
  pt: ["", t("quiz_diff_easy", "pt"), t("quiz_diff_medium", "pt"), t("quiz_diff_hard", "pt")],
};

const groups = groupEntries.map((g: any) => {
  const gSlug = extractSlugFromId(g.id);
  const gUrl = buildUrl(collection, gSlug, lang);
  const groupId = g.data.quiz_group || "";
  const groupQuizzes = quizEntries.filter((e: any) => e.data.quiz_group === groupId);
  const count = groupQuizzes.length;
  const diffs = [0, 0, 0, 0];
  groupQuizzes.forEach((e: any) => { diffs[e.data.difficulty || 1]++; });
  return {
    title: g.data.title,
    description: g.data.description || "",
    icon: g.data.quiz_group_icon || "🌍",
    image: g.data.quiz_group_image as string | undefined,
    url: gUrl,
    count,
    diffs,
  };
});

// Interactive (client-side) quizzes that are not part of the content collection.
// Only surfaced on the Japanese hub for now since the dataset is JP-only.
if (lang === "ja") {
  // 州当てクイズ: count countries+prefectures with municipality data.
  // Each card on /quiz/states/ links to one of these pages.
  const ruleEntries = await getCollection("rule");
  const stateQuizPages = ruleEntries.filter(
    (e: any) =>
      extractLangFromId(e.id) === "ja" && (e.data as any).municipalities,
  );
  groups.push({
    title: "州当てクイズ",
    description:
      "出題された州・地域・市町村を地図上の正しい場所をクリックして当てよう。日本47県＋世界主要国に対応。",
    icon: "",
    image: "/images/quiz-cover/03.jpg",
    url: "/quiz/states/",
    count: stateQuizPages.length,
    unit: "ページ",
    diffs: [0, 0, 0, 0],
  });

  const municipalityCount = Object.values(municipalitiesData as Record<string, string[]>)
    .reduce((acc, prs) => acc + prs.length, 0);
  groups.push({
    title: "自治体クイズ",
    description: "ランダムに出題される自治体名から、その都道府県をすべて当てよう。",
    icon: "🏯",
    image: "/images/quiz-cover/04.jpg",
    url: "/quiz/municipality/",
    count: municipalityCount,
    diffs: [0, 0, 0, 0],
  });

  const areacodeCount = Object.keys(areacodeData as Record<string, string[]>).length;
  groups.push({
    title: "市外局番クイズ",
    description: "番号区画名（札幌、岩見沢など）から市外局番を入力して当てよう。",
    icon: "📞",
    image: "/images/quiz-cover/06.jpg",
    url: "/quiz/areacode/",
    count: areacodeCount,
    diffs: [0, 0, 0, 0],
  });

  const highwayCount = (highwayData as Array<unknown>).length;
  groups.push({
    title: "国道クイズ",
    description: "ランダム出題される国道X号の起点・終点の都道府県を当てよう。",
    icon: "🛣️",
    image: "/images/quiz-cover/05.jpg",
    url: "/quiz/highway/",
    count: highwayCount,
    diffs: [0, 0, 0, 0],
  });
}
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <Head
    title={seoTitle}
    description={seoDescription}
    lang={lang}
    canonical={canonical}
    ogImage={ogImage}
    ogType="website"
    publishedTime={publishedTime}
    modifiedTime={modifiedTime}
    translations={translationUrls}
    pageData={data}
    breadcrumbs={crumbs}
    collection={collection}
  />
  <style>
    body { overflow-x: hidden; }
    .qh-container {
      max-width: 860px;
      margin: 0 auto;
      padding: 2rem 1rem 3rem;
      position: relative;
    }
    /* Hover background: when a card with an image is hovered, JS sets
       --qh-bg-image and adds .qh-bg-active to fade the image in. The
       ::before extends to the full viewport width via the 50% / -50vw
       trick so the image fills the page edge-to-edge. */
    .qh-container::before {
      content: "";
      position: absolute;
      top: 0;
      bottom: 0;
      left: 50%;
      width: 100vw;
      margin-left: -50vw;
      background-image: var(--qh-bg-image, none);
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      opacity: 0;
      transition: opacity 0.45s ease;
      pointer-events: none;
      z-index: 0;
    }
    .qh-container.qh-bg-active::before { opacity: 0.28; }
    .qh-container > * { position: relative; z-index: 1; }

    /* Hero */
    .qh-hero {
      text-align: center;
      margin-bottom: 2.5rem;
    }
    .qh-hero-icon {
      font-size: 3rem;
      margin-bottom: 0.5rem;
      display: block;
    }
    .qh-hero h1 {
      font-size: 2rem;
      font-weight: 800;
      color: var(--text-color);
      margin: 0 0 0.5rem;
    }
    .qh-hero-desc {
      font-size: 1rem;
      color: rgba(100,100,100,0.7);
      margin: 0;
    }

    /* Group cards */
    .qh-groups {
      display: flex;
      flex-direction: column;
      gap: 1.2rem;
    }
    .qh-group {
      display: flex;
      align-items: stretch;
      background: var(--surface-color, #fff);
      border: 1px solid var(--border-soft);
      overflow: hidden;
      text-decoration: none;
      color: var(--text-color);
      transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .qh-group:hover {
      transform: translateY(-3px);
      box-shadow: 0 12px 36px rgba(68, 110, 114, 0.14);
      border-color: var(--primary-color);
    }

    /* Icon area */
    .qh-group-icon {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100px;
      min-height: 120px;
      background: linear-gradient(135deg, rgba(68, 110, 114, 0.08) 0%, rgba(68, 110, 114, 0.03) 100%);
      font-size: 2.5rem;
      flex-shrink: 0;
      border-right: 1px solid var(--border-soft);
      overflow: hidden;
    }
    .qh-group-icon__img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .qh-group-icon__q {
      width: 40px;
      height: 40px;
      color: rgba(68, 110, 114, 0.5);
    }
    [data-theme="dark"] .qh-group-icon__q { color: rgba(180, 200, 205, 0.55); }

    /* Body */
    .qh-group-body {
      flex: 1;
      padding: 1.2rem 1.4rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 0.4rem;
    }
    .qh-group-title {
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--text-color);
      margin: 0;
    }
    .qh-group-desc {
      font-size: 0.88rem;
      color: rgba(100,100,100,0.7);
      margin: 0;
    }
    .qh-group-meta {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-top: 0.3rem;
      font-size: 0.82rem;
    }
    .qh-group-count {
      font-weight: 700;
      color: var(--primary-color);
    }
    .qh-group-diff {
      display: flex;
      gap: 0.5rem;
    }
    .qh-diff-tag {
      padding: 0.1em 0.5em;
      font-weight: 600;
      font-size: 0.75rem;
    }
    .qh-diff-tag[data-diff="1"] {
      background: rgba(74, 158, 92, 0.1);
      color: #3d8b50;
    }
    .qh-diff-tag[data-diff="2"] {
      background: rgba(196, 154, 42, 0.1);
      color: #9a7b20;
    }
    .qh-diff-tag[data-diff="3"] {
      background: rgba(192, 57, 43, 0.1);
      color: #a33025;
    }
    [data-theme="dark"] .qh-diff-tag[data-diff="1"] { color: #6bc77e; }
    [data-theme="dark"] .qh-diff-tag[data-diff="2"] { color: #d4b44a; }
    [data-theme="dark"] .qh-diff-tag[data-diff="3"] { color: #e06050; }

    /* Arrow */
    .qh-group-arrow {
      display: flex;
      align-items: center;
      padding: 0 1.2rem;
      color: rgba(68, 110, 114, 0.3);
      font-size: 1rem;
      transition: all 0.25s;
    }
    .qh-group:hover .qh-group-arrow {
      color: var(--primary-color);
      transform: translateX(3px);
    }

    /* Breadcrumb */
    .qh-breadcrumb {
      font-size: 0.82rem;
      color: rgba(100,100,100,0.7);
      margin-bottom: 1.5rem;
    }
    .qh-breadcrumb a { color: rgba(100,100,100,0.7); text-decoration: none; }
    .qh-breadcrumb a:hover { color: var(--primary-color); }

    @media (max-width: 640px) {
      .qh-container { padding: 1.2rem 0.75rem 2rem; }
      .qh-hero h1 { font-size: 1.5rem; }
      .qh-group-icon { width: 72px; min-height: 90px; font-size: 2rem; }
      .qh-group-icon__q { width: 30px; height: 30px; }
      .qh-group-body { padding: 0.9rem 1rem; }
      .qh-group-title { font-size: 1.05rem; }
      .qh-group-arrow { padding: 0 0.8rem; }
    }
  </style>
</head>
<body>
  <header class="shadow-bottom sticky-top bg-white">
    <Navbar lang={lang} isHome={false} />
  </header>

  <main class="qh-container">
    <nav class="qh-breadcrumb">
      {crumbs.map((c, i) =>
        i === crumbs.length - 1
          ? <span>{c.name}</span>
          : <><a href={c.url}>{c.name}</a> <span>/</span> </>
      )}
    </nav>

    <div class="qh-hero">
      <span class="qh-hero-icon" aria-hidden="true">🧩</span>
      <h1>{data.title}</h1>
      {data.description && <p class="qh-hero-desc">{data.description}</p>}
    </div>

    <div class="qh-groups">
      {groups.map((g: any) => (
        <a
          class:list={["qh-group", { "qh-group--has-image": !!g.image }]}
          href={g.url}
          data-bg-image={g.image || undefined}
        >
          <div class="qh-group-icon">
            {g.image ? (
              <img src={g.image} alt="" class="qh-group-icon__img" loading="lazy" />
            ) : (
              <svg class="qh-group-icon__q" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
                <line x1="12" y1="17" x2="12.01" y2="17"></line>
              </svg>
            )}
          </div>
          <div class="qh-group-body">
            <h2 class="qh-group-title">{g.title}</h2>
            {g.description && <p class="qh-group-desc">{g.description}</p>}
            <div class="qh-group-meta">
              <span class="qh-group-count">
                {g.count}{g.unit ?? t("quiz_count_unit", lang)}
              </span>
              <div class="qh-group-diff">
                {g.diffs[1] > 0 && <span class="qh-diff-tag" data-diff="1">{(difficultyLabels[lang] || difficultyLabels.en)[1]} {g.diffs[1]}</span>}
                {g.diffs[2] > 0 && <span class="qh-diff-tag" data-diff="2">{(difficultyLabels[lang] || difficultyLabels.en)[2]} {g.diffs[2]}</span>}
                {g.diffs[3] > 0 && <span class="qh-diff-tag" data-diff="3">{(difficultyLabels[lang] || difficultyLabels.en)[3]} {g.diffs[3]}</span>}
              </div>
            </div>
          </div>
          <div class="qh-group-arrow"><i class="fas fa-chevron-right"></i></div>
        </a>
      ))}
    </div>
  </main>

  <Footer lang={lang} title={data.title} permalink={canonical} translations={translationUrls} />
  <SearchModal lang={lang} />

  <script is:inline>
    (function () {
      const container = document.querySelector(".qh-container");
      if (!container) return;
      const cards = container.querySelectorAll(".qh-group[data-bg-image]");
      cards.forEach(function (card) {
        const url = card.getAttribute("data-bg-image");
        if (!url) return;
        card.addEventListener("mouseenter", function () {
          container.style.setProperty("--qh-bg-image", "url('" + url + "')");
          container.classList.add("qh-bg-active");
        });
        card.addEventListener("mouseleave", function () {
          container.classList.remove("qh-bg-active");
        });
      });
    })();
  </script>
</body>
</html>
