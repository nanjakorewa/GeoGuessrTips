---
import type { Language } from "@lib/i18n-utils";
import { buildUrl, extractLangFromId, extractSlugFromId, LANGUAGES, DEFAULT_LANG } from "@lib/i18n-utils";
import { t } from "@i18n/translations";
import { generateDescription } from "@lib/seo-utils";
import { getCollection } from "astro:content";
import municipalitiesData from "../data/municipalities.json";
import areacodeData from "../data/areacodes.json";
import highwayData from "../data/highways.json";
import Head from "@components/seo/Head.astro";
import Navbar from "@components/navigation/Navbar.astro";
import Footer from "@components/footer/Footer.astro";
import SearchModal from "@components/search/SearchModal.astro";

interface Props {
  entry: any;
  lang: Language;
  collection: string;
  hasContent?: boolean;
}

const { entry, lang, collection, hasContent = false } = Astro.props;
const data = entry.data;
const site = "https://geopinning.space";
const siteTitle = "GeoGuessrの攻略めも";

// --- SEO ---
const seoTitle = `${data.title} | ${siteTitle}`;
const seoDescription = data.description || generateDescription(entry, lang, collection);
const ogImage = `${site}/images/icon-512x512.png`;
const currentSlug = extractSlugFromId(entry.id);
const canonical = `${site}${buildUrl(collection, currentSlug, lang)}`;

// --- Translation URLs ---
const allEntries = await getCollection(collection);
const translationUrls: { lang: Language; url: string }[] = [];
for (const tLang of LANGUAGES) {
  const translationId = entry.id.replace(/\.(ja|en|id|es|pt)$/, `.${tLang}`);
  const found = allEntries.find((e: any) => e.id === translationId);
  if (found) {
    translationUrls.push({ lang: tLang, url: `${site}${buildUrl(collection, currentSlug, tLang)}` });
  }
}

// --- Breadcrumbs ---
interface Crumb { name: string; url: string }
const crumbs: Crumb[] = [
  { name: t("toppage", lang), url: lang === DEFAULT_LANG ? "/" : `/${lang}/` },
  { name: data.title, url: buildUrl(collection, currentSlug, lang) },
];

// --- Dates ---
const publishedTime = data.date ? new Date(data.date) : undefined;
const modifiedTime = data.lastmod ? new Date(data.lastmod) : publishedTime;

// --- Discover quiz groups (quiz-index pages) ---
const groupEntries = allEntries
  .filter((e: any) => extractLangFromId(e.id) === lang && e.data.pagetype === "quiz-index")
  .sort((a: any, b: any) => (a.data.weight || 99) - (b.data.weight || 99));

// Count quizzes per group
const quizEntries = allEntries.filter((e: any) => extractLangFromId(e.id) === lang && e.data.pagetype === "quiz");

const difficultyLabels: Record<string, string[]> = {
  ja: ["", t("quiz_diff_easy", "ja"), t("quiz_diff_medium", "ja"), t("quiz_diff_hard", "ja")],
  en: ["", t("quiz_diff_easy", "en"), t("quiz_diff_medium", "en"), t("quiz_diff_hard", "en")],
  es: ["", t("quiz_diff_easy", "es"), t("quiz_diff_medium", "es"), t("quiz_diff_hard", "es")],
  id: ["", t("quiz_diff_easy", "id"), t("quiz_diff_medium", "id"), t("quiz_diff_hard", "id")],
  pt: ["", t("quiz_diff_easy", "pt"), t("quiz_diff_medium", "pt"), t("quiz_diff_hard", "pt")],
};

const groups = groupEntries.map((g: any) => {
  const gSlug = extractSlugFromId(g.id);
  const gUrl = buildUrl(collection, gSlug, lang);
  const groupId = g.data.quiz_group || "";
  const groupQuizzes = quizEntries.filter((e: any) => e.data.quiz_group === groupId);
  const count = groupQuizzes.length;
  const diffs = [0, 0, 0, 0];
  groupQuizzes.forEach((e: any) => { diffs[e.data.difficulty || 1]++; });
  return {
    title: g.data.title,
    description: g.data.description || "",
    icon: g.data.quiz_group_icon || "🌍",
    image: g.data.quiz_group_image as string | undefined,
    url: gUrl,
    count,
    diffs,
  };
});

// Interactive (client-side) quizzes that are not part of the content collection.
// Only surfaced on the Japanese hub for now since the dataset is JP-only.
if (lang === "ja") {
  // 州当てクイズ: count countries+prefectures with municipality data.
  // Each card on /quiz/states/ links to one of these pages.
  const ruleEntries = await getCollection("rule");
  const stateQuizPages = ruleEntries.filter(
    (e: any) =>
      extractLangFromId(e.id) === "ja" && (e.data as any).municipalities,
  );
  groups.push({
    title: "州当てクイズ",
    description:
      "出題された州・地域・市町村を地図上の正しい場所をクリックして当てよう。日本47県＋世界主要国に対応。",
    icon: "",
    image: "/images/quiz-cover/03.jpg",
    url: "/quiz/states/",
    count: stateQuizPages.length,
    unit: "ページ",
    diffs: [0, 0, 0, 0],
  });

  // 都市当てクイズ: count countries that have a city-quiz registry entry.
  const { CITY_QUIZ_REGISTRY } = await import("../data/quiz-cities-registry");
  const cityCountryCount = Object.keys(CITY_QUIZ_REGISTRY).length;
  groups.push({
    title: "都市当てクイズ",
    description:
      "地図上のオレンジ色のピンに対応する都市名カードを選ぶクイズ。世界各国の主要都市の位置を覚えよう。",
    icon: "",
    image: "/images/quiz-cover/01.jpg",
    url: "/quiz/cities/",
    count: cityCountryCount,
    unit: "か国",
    diffs: [0, 0, 0, 0],
  });

  // 日本地理クイズ: ダム・山脈・平野・半島・河川 5カテゴリへの入口。
  const { JAPAN_FEATURES_REGISTRY } = await import("../data/quiz-japan-features-registry");
  const japanFeatureCount = Object.values(JAPAN_FEATURES_REGISTRY)
    .reduce((acc, e) => acc + e.features.length, 0);
  groups.push({
    title: "日本地理クイズ",
    description:
      "日本のダム・山脈・平野・半島・河川を、地図上のハイライト位置から名前を当てるクイズ。",
    icon: "",
    image: "/images/japan-features/mountain-ranges.jpg",
    url: "/quiz/japan/",
    count: japanFeatureCount,
    unit: "件",
    diffs: [0, 0, 0, 0],
  });

  const municipalityCount = Object.values(municipalitiesData as Record<string, string[]>)
    .reduce((acc, prs) => acc + prs.length, 0);
  groups.push({
    title: "自治体クイズ",
    description: "ランダムに出題される自治体名から、その都道府県をすべて当てよう。",
    icon: "",
    image: "/images/quiz-cover/04.jpg",
    url: "/quiz/municipality/",
    count: municipalityCount,
    diffs: [0, 0, 0, 0],
  });

  const areacodeCount = Object.keys(areacodeData as Record<string, string[]>).length;
  groups.push({
    title: "市外局番クイズ",
    description: "番号区画名（札幌、岩見沢など）から市外局番を入力して当てよう。",
    icon: "",
    image: "/images/quiz-cover/06.jpg",
    url: "/quiz/areacode/",
    count: areacodeCount,
    diffs: [0, 0, 0, 0],
  });

  const highwayCount = (highwayData as Array<unknown>).length;
  groups.push({
    title: "国道クイズ",
    description: "ランダム出題される国道X号の起点・終点の都道府県を当てよう。",
    icon: "",
    image: "/images/quiz-cover/05.jpg",
    url: "/quiz/highway/",
    count: highwayCount,
    diffs: [0, 0, 0, 0],
  });
}
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <Head
    title={seoTitle}
    description={seoDescription}
    lang={lang}
    canonical={canonical}
    ogImage={ogImage}
    ogType="website"
    publishedTime={publishedTime}
    modifiedTime={modifiedTime}
    translations={translationUrls}
    pageData={data}
    breadcrumbs={crumbs}
    collection={collection}
  />
  <style>
    body { overflow-x: hidden; }
    .qh-container {
      max-width: 1100px;
      margin: 0 auto;
      padding: 2rem 1rem 3rem;
    }

    /* Hero — keep simple, no emoji icon */
    .qh-hero {
      margin-bottom: 1.8rem;
    }
    .qh-hero h1 {
      font-size: 2rem;
      font-weight: 800;
      color: var(--text-color);
      margin: 0 0 0.5rem;
    }
    .qh-hero-desc {
      font-size: 1rem;
      color: rgba(100,100,100,0.75);
      margin: 0;
      line-height: 1.55;
    }

    /* Group cards — image-backed grid panels (matches /quiz/japan/ design).
       Each card uses its quiz_group_image as a full-bleed background, with
       a dark gradient overlay so the white title is legible on top. On hover
       the image gently zooms and brightens, and the overlay tints blue. */
    .qh-groups {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 0.9rem;
    }
    .qh-group {
      position: relative;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      min-height: 200px;
      padding: 1.1rem;
      border: 1px solid var(--border-soft);
      text-decoration: none;
      color: #fff;
      overflow: hidden;
      isolation: isolate;
      transition: transform 0.18s, border-color 0.18s, box-shadow 0.18s;
    }
    .qh-group__bg {
      position: absolute;
      inset: 0;
      background-size: cover;
      background-position: center;
      transform: scale(1.02);
      transition: transform 0.45s ease, filter 0.25s ease;
      z-index: -2;
    }
    /* Fallback solid colour when no image is set */
    .qh-group__bg--solid {
      background: linear-gradient(135deg, #4a6b6f 0%, #2f4346 100%);
    }
    .qh-group::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to top,
        rgba(0,0,0,0.72) 0%,
        rgba(0,0,0,0.40) 45%,
        rgba(0,0,0,0.15) 100%
      );
      z-index: -1;
      transition: background 0.25s ease;
    }
    .qh-group:hover {
      transform: translateY(-3px);
      border-color: var(--primary-color);
      box-shadow: 0 8px 22px rgba(0,0,0,0.18);
    }
    .qh-group:hover .qh-group__bg {
      transform: scale(1.08);
      filter: saturate(1.15) brightness(1.05);
    }
    .qh-group:hover::after {
      background: linear-gradient(
        to top,
        rgba(20,40,70,0.78) 0%,
        rgba(20,40,70,0.45) 50%,
        rgba(20,40,70,0.20) 100%
      );
    }
    .qh-group:focus-visible {
      outline: 3px solid #f59e0b;
      outline-offset: 2px;
    }

    .qh-group-title {
      font-size: 1.3rem;
      font-weight: 800;
      color: #fff;
      letter-spacing: 0.03em;
      text-shadow: 0 2px 6px rgba(0,0,0,0.55);
      margin: 0 0 0.3rem;
      line-height: 1.25;
    }
    .qh-group-desc {
      font-size: 0.82rem;
      color: rgba(255,255,255,0.93);
      text-shadow: 0 1px 4px rgba(0,0,0,0.55);
      margin: 0;
      line-height: 1.45;
      /* Limit to two lines so cards stay consistent regardless of text length */
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .qh-group-meta {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin-top: 0.55rem;
      font-size: 0.78rem;
    }
    .qh-group-count {
      display: inline-block;
      background: rgba(255,255,255,0.18);
      border: 1px solid rgba(255,255,255,0.28);
      padding: 0.08em 0.55em;
      font-weight: 700;
      color: #fff;
      text-shadow: 0 1px 3px rgba(0,0,0,0.45);
    }
    .qh-group-diff {
      display: flex;
      gap: 0.35rem;
    }
    .qh-diff-tag {
      padding: 0.08em 0.45em;
      font-weight: 700;
      font-size: 0.72rem;
      background: rgba(255,255,255,0.16);
      color: #fff;
      text-shadow: 0 1px 3px rgba(0,0,0,0.45);
    }

    /* Breadcrumb */
    .qh-breadcrumb {
      font-size: 0.82rem;
      color: rgba(100,100,100,0.7);
      margin-bottom: 1.2rem;
    }
    .qh-breadcrumb a { color: rgba(100,100,100,0.7); text-decoration: none; }
    .qh-breadcrumb a:hover { color: var(--primary-color); }

    @media (max-width: 640px) {
      .qh-container { padding: 1.2rem 0.75rem 2rem; }
      .qh-hero h1 { font-size: 1.5rem; }
      .qh-groups { grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 0.7rem; }
      .qh-group { min-height: 170px; padding: 0.9rem; }
      .qh-group-title { font-size: 1.1rem; }
    }
  </style>
</head>
<body>
  <header class="shadow-bottom sticky-top bg-white">
    <Navbar lang={lang} isHome={false} />
  </header>

  <main class="qh-container">
    <nav class="qh-breadcrumb">
      {crumbs.map((c, i) =>
        i === crumbs.length - 1
          ? <span>{c.name}</span>
          : <><a href={c.url}>{c.name}</a> <span>/</span> </>
      )}
    </nav>

    <div class="qh-hero">
      <h1>{data.title}</h1>
      {data.description && <p class="qh-hero-desc">{data.description}</p>}
    </div>

    <div class="qh-groups">
      {groups.map((g: any) => (
        <a class="qh-group" href={g.url}>
          {g.image ? (
            <span
              class="qh-group__bg"
              style={`background-image: url(${g.image});`}
              aria-hidden="true"
            ></span>
          ) : (
            <span class="qh-group__bg qh-group__bg--solid" aria-hidden="true"></span>
          )}
          <h2 class="qh-group-title">{g.title}</h2>
          {g.description && <p class="qh-group-desc">{g.description}</p>}
          <div class="qh-group-meta">
            <span class="qh-group-count">
              {g.count}{g.unit ?? t("quiz_count_unit", lang)}
            </span>
            <div class="qh-group-diff">
              {g.diffs[1] > 0 && <span class="qh-diff-tag" data-diff="1">{(difficultyLabels[lang] || difficultyLabels.en)[1]} {g.diffs[1]}</span>}
              {g.diffs[2] > 0 && <span class="qh-diff-tag" data-diff="2">{(difficultyLabels[lang] || difficultyLabels.en)[2]} {g.diffs[2]}</span>}
              {g.diffs[3] > 0 && <span class="qh-diff-tag" data-diff="3">{(difficultyLabels[lang] || difficultyLabels.en)[3]} {g.diffs[3]}</span>}
            </div>
          </div>
        </a>
      ))}
    </div>
  </main>

  <Footer lang={lang} title={data.title} permalink={canonical} translations={translationUrls} />
  <SearchModal lang={lang} /></body>
</html>
