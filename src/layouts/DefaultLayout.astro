---
import type { Language } from "@lib/i18n-utils";
import { t } from "@i18n/translations";
import { getLocale, buildUrl, extractLangFromId, extractSlugFromId, LANGUAGES, DEFAULT_LANG } from "@lib/i18n-utils";
import { buildContentTree, getSiblingCountries } from "@lib/content-tree";
import { generateDescription } from "@lib/seo-utils";
import { encodeWatermark } from "@lib/watermark";
import { getCollection } from "astro:content";
import { siteConfig } from "@config/site";
import Head from "@components/seo/Head.astro";
import Navbar from "@components/navigation/Navbar.astro";
import Sidebar from "@components/navigation/Sidebar.astro";
import Footer from "@components/footer/Footer.astro";
import SearchModal from "@components/search/SearchModal.astro";
import TableOfContents from "@components/TableOfContents.astro";
import IndustryOSMMap from "@components/IndustryOSMMap.astro";

interface Props {
  entry: any;
  lang: Language;
  collection: string;
  hasContent?: boolean;
}

const { entry, lang, collection, hasContent = true } = Astro.props;
// 言語ごとに frontmatter が異なるが、OSM ヒーロー（mapProvider/mapPins 等）の
// 構造的データは JA 版にのみ書かれていることが多い。そのため非 JA ページでも
// JA からフォールバックして同じデザインで表示できるよう、後段でマージする。
let data: any = { ...entry.data };
const site = "https://geopinning.space";
const siteTitle = "GeoGuessrの攻略めも";
const isHome = false;

// --- References (rendered below sibling-countries) ---
// `data.references` is the page-level bibliography. Numbering matches the
// in-body {{% cite "key" %}} markers, which are pre-numbered in frontmatter
// order by the remark-hugo-shortcodes plugin.
type RefItem = { key: string; text: string };
const referenceList: RefItem[] = Array.isArray(data.references)
  ? data.references
  : [];
function linkifyRefText(t: string): string {
  // Convert bare URLs and <URL> to anchors. PDF URLs become a "PDF" badge
  // (mirrors the {{% references %}} shortcode output for visual parity).
  const urlRegex = /<(https?:\/\/[^>]+)>|(https?:\/\/[^\s<]+)/g;
  return t.replace(urlRegex, (_m, bracketUrl, bareUrl) => {
    const url = bracketUrl ?? bareUrl;
    const lower = url.toLowerCase();
    const isPdf =
      lower.endsWith(".pdf") ||
      lower.includes(".pdf?") ||
      lower.includes(".pdf#");
    return isPdf
      ? `<a href="${url}" target="_blank" rel="noopener noreferrer" class="ref-pdf-badge">PDF</a>`
      : `<a href="${url}" target="_blank" rel="noopener noreferrer">${url}</a>`;
  });
}

// --- SEO title computation ---
let seoTitle = "";
if (data.seo_title) {
  seoTitle = data.seo_title;
} else if (data.flag) {
  const flagTitleTemplates: Record<Language, string> = {
    ja: "GeoGuessrで%sを見分けるには？",
    en: "How to identify %s in GeoGuessr?",
    id: "Cara membedakan %s di GeoGuessr",
    es: "¿Cómo identificar %s en GeoGuessr?",
    pt: "Como identificar %s no GeoGuessr?",
  };
  seoTitle = (flagTitleTemplates[lang] || flagTitleTemplates.ja).replace("%s", data.title);
} else if (data.subtitle) {
  seoTitle = data.subtitle;
} else {
  seoTitle = data.title ? `${data.title} | ${siteTitle}` : siteTitle;
}

// --- SEO description ---
const seoDescription = generateDescription(entry, lang, collection);

// --- OG Image ---
let ogImage = "";
if (data.sumnail_mk) {
  ogImage = `${site}/sns/OP-MKnora.jpg`;
} else if (data.og_image) {
  ogImage = data.og_image.startsWith("http") ? data.og_image : `${site}/${data.og_image.replace(/^\//, "")}`;
} else if (data.social_image) {
  ogImage = data.social_image.startsWith("http") ? data.social_image : `${site}/${data.social_image.replace(/^\//, "")}`;
} else if (data.card_image) {
  if (data.card_image.startsWith("http")) {
    ogImage = data.card_image;
  } else {
    const normalized = data.card_image.replace(/^\//, "");
    const path = normalized.startsWith("bg/") ? normalized : `bg/${normalized}`;
    ogImage = `${site}/${path}`;
  }
} else if (data.flag) {
  ogImage = `${site}/flags/${data.flag.replace(".svg", ".png")}`;
} else {
  ogImage = `${site}/images/icon-512x512.png`;
}

// --- Canonical URL ---
const currentSlug = extractSlugFromId(entry.id);
const canonical = `${site}${buildUrl(collection, currentSlug, lang)}`;

// --- OG Type ---
const ogType = "article";

// --- Translation URLs ---
const allEntries = await getCollection(collection);
const translationUrls: { lang: Language; url: string }[] = [];
for (const tLang of LANGUAGES) {
  const translationId = entry.id.replace(/\.(ja|en|id|es|pt)$/, `.${tLang}`);
  const found = allEntries.find((e: any) => e.id === translationId);
  if (found) {
    translationUrls.push({
      lang: tLang,
      url: `${site}${buildUrl(collection, currentSlug, tLang)}`,
    });
  }
}

// --- Sidebar tree ---
const sectionEntries = await getCollection(collection as any);

// --- 構造データを JA フロントマターからフォールバック ---
// 言語非依存（または nameI18n を持つ）構造データは JA 版のみに書かれているケースが多い。
// テキスト系（features/sc/maps/related_quizzes 等）は各言語ファイルの値を尊重し、
// マップやムニシパリティなど「デザインに必須の構造データ」だけをここで補完する。
if (lang !== "ja") {
  const jaEntry = sectionEntries.find((e: any) => {
    const eSlug = extractSlugFromId(e.id);
    return eSlug === currentSlug && extractLangFromId(e.id) === "ja";
  });
  if (jaEntry) {
    const jaData = (jaEntry as any).data;
    data = {
      ...data,
      mapProvider: data.mapProvider ?? jaData.mapProvider,
      mapPins: data.mapPins ?? jaData.mapPins,
      mapCenter: data.mapCenter ?? jaData.mapCenter,
      mapZoom: data.mapZoom ?? jaData.mapZoom,
      mapRegions: data.mapRegions ?? jaData.mapRegions,
      municipalities: data.municipalities ?? jaData.municipalities,
      heroGallery: data.heroGallery ?? jaData.heroGallery,
      prefSymbols: data.prefSymbols ?? jaData.prefSymbols,
    };
  }
}

// prefSymbols のグループ集計：同じ group（例: "diamond"）を持つシンボルを
// 使う都道府県名を集める。ヒーロー直下のシンボルにオンマウスして拡大表示した
// とき、同じシンボルを使う県の一覧をキャプションに出すために使う。
// （prefSymbols は ja 版にのみ定義されるため ja エントリのみ走査）
const symbolGroupMembers: Record<string, string[]> = {};
// 電力会社ごとの県一覧。prefSymbols の imgs のうち src が "/rule/power/" で
// 始まるものを電力会社ロゴとみなし、その alt（会社名）をキーに県名を集める。
// 二社またぎ県（長野・静岡・三重・福井）は両社の一覧に含まれる。
const powerCompanyMembers: Record<string, string[]> = {};
{
  const jaSorted = sectionEntries
    .filter((e: any) => extractLangFromId(e.id) === "ja")
    .sort((a: any, b: any) => (a.id < b.id ? -1 : a.id > b.id ? 1 : 0));
  for (const e of jaSorted) {
    const syms = (e as any).data?.prefSymbols;
    if (!Array.isArray(syms)) continue;
    const title = (e as any).data?.title;
    if (!title) continue;
    for (const s of syms) {
      if (s && s.group) {
        (symbolGroupMembers[s.group] ||= []).push(title);
      }
      if (s && Array.isArray(s.imgs)) {
        for (const im of s.imgs) {
          if (im && typeof im.src === "string" && im.src.startsWith("/rule/power/") && im.alt) {
            (powerCompanyMembers[im.alt] ||= []).push(title);
          }
        }
      }
    }
  }
}

const tree = buildContentTree(
  sectionEntries.map((e: any) => ({ id: e.id, data: e.data })),
  collection,
  lang
);

// Find current section's subtree for sidebar
const currentUrl = buildUrl(collection, currentSlug, lang);

// --- Child tree for section pages ---
import type { TreeNode } from "@lib/content-tree";

const isRuleSection = collection === "rule";
let sectionChildTree: TreeNode[] = [];

// Always build the child tree (needed for pages with content that also have children)
function findNodeByUrl(nodes: TreeNode[], url: string): TreeNode | null {
  for (const n of nodes) {
    if (n.url === url) return n;
    const found = findNodeByUrl(n.children, url);
    if (found) return found;
  }
  return null;
}
const currentNode = findNodeByUrl(tree, currentUrl);
if (currentNode && currentNode.children.length > 0) {
  sectionChildTree = currentNode.children;
} else if (currentSlug === "") {
  sectionChildTree = tree.filter(n => n.url !== currentUrl);
} else if (!hasContent) {
  sectionChildTree = tree;
}

// Recursive HTML builder for section pages (flag grid or page list)
function renderSectionTree(nodes: TreeNode[], useFlags: boolean, parentFlag?: string): string {
  let html = "";
  for (const node of nodes) {
    const unofficialClass = node.isUnofficial ? " unofficial-area" : "";
    const prefClass = node.isPref ? " flag-ispref" : "";
    // 子を持つノードで親と同じフラグの場合は冗長なので非表示
    const hasOwnFlag = node.flag && node.flag !== parentFlag;
    if (useFlags) {
      html += `<li class="${unofficialClass}${prefClass}">`;
      html += `<a href="${node.url}" class="flag-link">`;
      if (hasOwnFlag) {
        html += `<img src="/flags/${node.flag}" alt="${node.title}" class="flag-img-link" loading="lazy" decoding="async"/>`;
      }
      html += `<br/>${node.title}<br/>`;
      if (node.hasGooglecar) html += '<i class="fas fa-car-alt i-googlecar"></i>';
      if (node.hasTrekker) html += '<i class="fas fa-hiking i-googlecar"></i>';
      if (node.hasBollard) html += '<i class="fas fa-magic i-bollard"></i>';
      if (node.isUnofficial) html += '<i class="fa fa-question-circle"></i>';
      html += "</a>";
      if (node.children.length > 0) {
        html += '<ul class="flag-list">' + renderSectionTree(node.children, true, node.flag) + "</ul>";
      }
      html += "</li>";
    } else {
      html += `<li class="sidelist no-dot${unofficialClass}">`;
      html += `<a href="${node.url}">${node.title}`;
      if (node.hasGooglecar) html += '<i class="fas fa-car-alt i-googlecar"></i>';
      if (node.hasTrekker) html += '<i class="fas fa-hiking i-googlecar"></i>';
      if (node.hasBollard) html += '<i class="fas fa-magic i-bollard"></i>';
      if (node.isUnofficial) html += '<i class="fa fa-question-circle"></i>';
      html += "</a>";
      if (node.children.length > 0) {
        html += "<ul>" + renderSectionTree(node.children, false, node.flag) + "</ul>";
      }
      html += "</li>";
    }
  }
  return html;
}

const sectionTreeHtml = sectionChildTree.length > 0
  ? renderSectionTree(sectionChildTree, isRuleSection, data.flag)
  : "";

// --- Section children for ItemList schema ---
const sectionChildrenForSchema = sectionChildTree.map((node) => ({
  title: node.title,
  url: node.url,
  flag: node.flag,
}));

// --- Sibling countries ---
const siblings = data.flag
  ? getSiblingCountries(
      sectionEntries.map((e: any) => ({ id: e.id, data: e.data })),
      entry.id,
      collection,
      lang
    )
  : [];

// --- Related industry pages ---
const relatedIndustryLinks: { title: string; subtitle?: string; url: string }[] = [];
if (data.relatedIndustry && data.relatedIndustry.length > 0) {
  const industryEntries = await getCollection("industry");
  for (const path of data.relatedIndustry) {
    // path is like "/industry/japan-combinat/keiyo/" — strip leading/trailing slashes and "industry/"
    const slug = path.replace(/^\/?(industry\/)?/, "").replace(/\/$/, "");
    // Find matching entry in the industry collection (prefer same lang, fallback to ja)
    const match = industryEntries.find((e: any) => {
      const eSlug = extractSlugFromId(e.id);
      const eLang = extractLangFromId(e.id);
      return eSlug === slug && eLang === lang;
    }) || industryEntries.find((e: any) => {
      const eSlug = extractSlugFromId(e.id);
      const eLang = extractLangFromId(e.id);
      return eSlug === slug && eLang === "ja";
    });
    if (match) {
      relatedIndustryLinks.push({
        title: (match as any).data.title,
        subtitle: (match as any).data.subtitle,
        url: buildUrl("industry", slug, lang),
      });
    }
  }
}

// --- Parent title for "Countries in ..." ---
const slugParts = currentSlug.split("/");
let parentTitle = "";
if (slugParts.length >= 2) {
  const parentSlug = slugParts.slice(0, -1).join("/");
  const parentEntry = sectionEntries.find((e: any) => {
    const eSlug = extractSlugFromId(e.id);
    return eSlug === parentSlug && extractLangFromId(e.id) === lang;
  });
  if (parentEntry) {
    parentTitle = (parentEntry as any).data.title;
  }
}

// --- Breadcrumbs ---
interface Crumb { name: string; url: string }
const crumbs: Crumb[] = [];
crumbs.push({ name: t("toppage", lang), url: lang === DEFAULT_LANG ? "/" : `/${lang}/` });
let crumbPath = lang === DEFAULT_LANG ? "" : `/${lang}`;
const pathSegments = currentSlug ? currentSlug.split("/") : [];
// Add collection (with translated display name)
const collectionDisplayName = t(`breadcrumb_${collection}`, lang) || collection;
crumbs.push({ name: collectionDisplayName, url: `${crumbPath}/${collection}/` });
// Add intermediate segments
for (let i = 0; i < pathSegments.length; i++) {
  const segSlug = pathSegments.slice(0, i + 1).join("/");
  const segEntry = sectionEntries.find((e: any) => {
    const eSlug = extractSlugFromId(e.id);
    return eSlug === segSlug && extractLangFromId(e.id) === lang;
  });
  // Fall back to default-lang entry when the current language version does not exist,
  // so the breadcrumb does not link to a 404.
  const segEntryFallback = segEntry ?? sectionEntries.find((e: any) => {
    const eSlug = extractSlugFromId(e.id);
    return eSlug === segSlug && extractLangFromId(e.id) === DEFAULT_LANG;
  });
  const segLang = segEntry ? lang : segEntryFallback ? DEFAULT_LANG : lang;
  const segName = segEntry
    ? (segEntry as any).data.title
    : segEntryFallback
      ? (segEntryFallback as any).data.title
      : pathSegments[i];
  crumbs.push({ name: segName, url: buildUrl(collection, segSlug, segLang) });
}

// --- Parent crumb for the hero "back to parent" chip ---
// The last crumb is the current page; the one before it is its parent
// (e.g. 中部 for 岐阜). Used to give hero-layout pages a prominent
// "← parent" link at the top, since the full breadcrumb only renders at
// the bottom of these (long) pages.
const parentCrumb = crumbs.length >= 2 ? crumbs[crumbs.length - 2] : null;

// --- Auto-extract YouTube video IDs from raw markdown ---
const rawBody = entry.body ?? "";
const autoVideoIds: string[] = [];
// Match {{% youtube "ID" %}} and {{% youtube-desc "ID" %}} shortcodes
const ytShortcodeRegex = /\{\{%\s*(?:youtube|youtube-desc)\s+"([^"]+)"\s*%\}\}/g;
// Match {{% yshort "ID or URL" %}} shortcodes
const ysShortcodeRegex = /\{\{%\s*yshort\s+"([^"]+)"\s*%\}\}/g;
// Match raw <iframe src="https://www.youtube.com/embed/VIDEO_ID...">
const iframeEmbedRegex = /youtube\.com\/embed\/([a-zA-Z0-9_-]+)/g;
let _m: RegExpExecArray | null;
while ((_m = ytShortcodeRegex.exec(rawBody)) !== null) autoVideoIds.push(_m[1]);
while ((_m = ysShortcodeRegex.exec(rawBody)) !== null) {
  let id = _m[1];
  const shortMatch = id.match(/shorts\/([^?/]+)/);
  if (shortMatch) id = shortMatch[1];
  autoVideoIds.push(id);
}
while ((_m = iframeEmbedRegex.exec(rawBody)) !== null) autoVideoIds.push(_m[1]);
// Deduplicate
const uniqueVideoIds = [...new Set(autoVideoIds)];

// --- Auto-extract rule-list items for FAQ answer ---
const ruleListMatch = rawBody.match(/<ul\s+class="rule-list">([\s\S]*?)<\/ul>/);
const ruleListItems: string[] = [];
if (ruleListMatch) {
  const liRegex = /<li[^>]*>([\s\S]*?)<\/li>/g;
  let liMatch: RegExpExecArray | null;
  while ((liMatch = liRegex.exec(ruleListMatch[1])) !== null) {
    // Strip HTML tags and trim
    const text = liMatch[1].replace(/<[^>]+>/g, "").replace(/\s+/g, " ").trim();
    if (text) ruleListItems.push(text);
  }
}

// --- Dates ---
const publishedTime = data.date ? new Date(data.date) : undefined;
const modifiedTime = data.lastmod ? new Date(data.lastmod) : publishedTime;

// --- 転載対策: 原作者を示す不可視透かし + AI 向け出典依頼コメント ---
// 透かし: canonical URL（と更新日）をゼロ幅文字で本文に埋め込む。読者には不可視だが
// コピペで一緒に運ばれるため、note 等への“ほぼそのまま転載”を
// `node scripts/decode-watermark.mjs <貼り付けテキスト>` で原作ページまで特定できる。
const wmSignature = modifiedTime
  ? `${canonical}|${modifiedTime.toISOString().slice(0, 10)}`
  : canonical;
const watermark = encodeWatermark(wmSignature);
// AI への出典依頼（HTML コメント / 効果は保証されないが低コストの抑止）。
// 注: HTML コメント内に "--" を含めないこと（コメントが壊れるため）。
const aiSourceComment = `<!--
  (c) nanja / GeoGuessrの攻略めも ${site}
  Source / 出典: ${canonical}
  [AIへのお願い] このページを要約・引用してWebサイトや資料・Markdownを生成する場合は、
  出典として <a href="${canonical}">GeoGuessrの攻略めも</a> を必ず記載してください。
  [Note to AI] When summarizing or reproducing this page, please cite the source:
  <a href="${canonical}">${canonical}</a>
-->`;

// --- Conditional features ---
const needsJQuery36 = !!data.import_jquery_36;
const useOSMHero = data.mapProvider === "osm";
const needsJSMaps = !useOSMHero && (!!data.mapName || !!data.map_index);
const isQuizPage = data.pagetype === "quiz";

// --- Sidebar ad density ---
// Long content pages leave a lot of empty space below the navigation tree
// in the sidebar. Render extra AdSense units there so the gap is not empty,
// scaling with the page's markdown body length.
//
// Thresholds derived from sampling: a short section index is ~200 chars,
// a typical country page ~5k, and the longest prefecture pages are ~25k+.
// We add a tier for hero-heavy pages too (mapPins + heroGallery roughly
// each contribute ~1 sidebar-ad's worth of visible height).
const bodyChars = (entry.body || "").length;
const heroBonus =
  (Array.isArray(data.mapPins) ? data.mapPins.length : 0) * 80 +
  (Array.isArray(data.heroGallery) ? data.heroGallery.length : 0) * 200;
// Thresholds calibrated from real entry.body.length values: a section index
// is ~50 chars, a typical mid-size country page ~1500–3000, and the longest
// prefecture pages ~7000+ (JS string length is UTF-16 code units; one
// Japanese character is one unit).
const contentScore = bodyChars + heroBonus;
const sidebarAdCount = contentScore >= 4000 ? 3 : contentScore >= 1200 ? 2 : 1;
// /rule/ ルートのワールドマップは OSM ではないが、OSM ヒーローと同等の見た目
// (タイトル左 / マップ右 / 紺色フルブリード / パンくずを下部に) にしたい。
// 影響範囲を最小化するため、コレクションのルート (currentSlug が空) で
// map_index のみ指定されているケースに限定する。
const useWorldJSMapHero =
  !useOSMHero && !!data.map_index && !data.mapName && currentSlug === "";
const useHeroLayout = useOSMHero || useWorldJSMapHero;

// --- Flag path ---
const flagPath = data.flag ? `/flags/${data.flag}` : "";

// --- Share URL ---
const shareText = encodeURIComponent(`${data.title} | ${siteTitle}`);
const shareURL = `https://twitter.com/intent/tweet?url=${encodeURIComponent(canonical)}&text=${shareText}`;
const chatGptPrompt = encodeURIComponent(
  `${canonical}のURLに載っている情報のほかに、${data.title}をGeoGuessrで当てるうえでヒントになる情報があれば教えてください。`
);

// --- Last modified display ---
const lastmodDisplay = modifiedTime
  ? modifiedTime.toLocaleDateString("en-GB", { day: "2-digit", month: "short", year: "numeric" })
  : "";
---

<!DOCTYPE html>
<html lang={lang} class:list={[{ "hide-merchandise": !siteConfig.showMerchandise }]}>
<head>
  <Head
    title={seoTitle}
    description={seoDescription}
    lang={lang}
    canonical={canonical}
    ogImage={ogImage}
    ogType={ogType}
    noindex={!!data.noindex}
    publishedTime={publishedTime}
    modifiedTime={modifiedTime}
    flag={data.flag}
    translations={translationUrls}
    pageData={data}
    breadcrumbs={crumbs}
    collection={collection}
    sectionChildren={sectionChildrenForSchema}
    autoVideoIds={uniqueVideoIds}
    ruleListItems={ruleListItems}
    usePolishFont={!!data.use_polish_font}
    needsJQuery36={needsJQuery36}
    needsJSMaps={needsJSMaps}
  />
  <style is:global>
    /* ============================================
       Rule Hero Section（mapProvider: osm の国別ページ）
       ============================================ */
    .rule-hero-section {
      background: #1a2535;
      padding: 1.5rem 0;
      color: #fff;
    }
    .rule-hero-section__inner {
      display: grid;
      grid-template-columns: minmax(260px, 360px) minmax(0, 1fr);
      gap: 1.25rem 2.5rem;
      align-items: center;
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    /* 県を象徴するシンボル帯（ヒーロー直下／案C）。紺色ヒーローと同色で
       連続させ、カードを使わずアイコンチップ＋ラベルを横並びにする。
       ※角丸は一切使わない（直角デザイン）。 */
    .rule-hero-symbols {
      background: #1a2535;
      padding: 0.75rem 0;
    }
    .rule-hero-symbols__inner {
      display: flex;
      flex-wrap: wrap;
      gap: 1.6rem;
      align-items: center;
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 1.5rem;
      list-style: none;
    }
    .rule-hero-symbol {
      display: flex;
      align-items: center;
      gap: 0.7rem;
      min-width: 0;
      cursor: pointer;
      outline: none;
    }
    /* 白タイルのアイコン（直角）。表示サイズは従来の約2倍。高さ固定・幅可変で、
       正方形シンボルも横長の企業ロゴも縦横比を保って収める。 */
    .rule-hero-symbol__icon {
      flex: 0 0 auto;
      height: 88px;
      min-width: 88px;
      padding: 8px;
      box-sizing: border-box;
      background: #fff;
      border-radius: 0;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      transition: box-shadow 0.15s ease, transform 0.15s ease;
    }
    /* 二社またぎ（同サイズ横並び）の間に細い仕切り線 */
    .rule-hero-symbol__icon--multi { gap: 0; }
    .rule-hero-symbol__icon--multi .rule-hero-symbol__logo + .rule-hero-symbol__logo {
      border-left: 1px solid #e3e8ef;
      padding-left: 10px;
      margin-left: 10px;
    }
    .rule-hero-symbol:hover .rule-hero-symbol__icon,
    .rule-hero-symbol:focus-visible .rule-hero-symbol__icon {
      box-shadow: 0 0 0 2px rgba(245, 166, 35, 0.9);
    }
    .rule-hero-symbol__icon svg {
      height: 100%;
      width: auto;
      display: block;
    }
    .rule-hero-symbol__logo {
      height: 100%;
      width: auto;
      max-width: 132px;
      object-fit: contain;
      display: block;
    }
    .rule-hero-symbol__text {
      display: flex;
      flex-direction: column;
      line-height: 1.3;
      min-width: 0;
    }
    .rule-hero-symbol__label {
      font-size: 0.92rem;
      font-weight: 700;
      color: #fff;
    }
    .rule-hero-symbol__name {
      font-size: 0.74rem;
      color: rgba(255, 255, 255, 0.55);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    /* 地図領域に重ねる拡大オーバーレイ。シンボルへのオンマウスで
       フェードイン／アウトする（直角・角丸なし）。 */
    .rule-hero-map { position: relative; }
    .rule-hero-symbol-overlay {
      position: absolute;
      inset: 0;
      z-index: 5;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(15, 22, 34, 0.92);
      border-radius: 0;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transition: opacity 0.18s ease, visibility 0s linear 0.18s;
    }
    .rule-hero-symbol-overlay.is-visible {
      opacity: 1;
      visibility: visible;
      transition: opacity 0.18s ease;
    }
    .rule-hero-symbol-overlay__inner {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.9rem;
      padding: 1rem;
    }
    .rule-hero-symbol-overlay__art {
      background: #fff;
      padding: 20px 24px;
      box-sizing: border-box;
      display: flex;
      flex-wrap: nowrap;
      align-items: center;
      justify-content: center;
      gap: 22px;
      max-width: 92%;
    }
    /* 画像は明示的な高さで描画（viewBox のみの SVG も確実に表示される）。
       幅は上限を設けてはみ出しを防ぐ。 */
    .rule-hero-symbol-overlay__art svg,
    .rule-hero-symbol-overlay__art img {
      height: clamp(120px, 26vh, 210px);
      width: auto;
      max-width: 100%;
      min-width: 0;
      object-fit: contain;
      display: block;
    }
    /* 電力二社（横並びのまま白枠内に収まるよう一回り小さく） */
    .rule-hero-symbol-overlay__art.is-multi { gap: 18px; }
    .rule-hero-symbol-overlay__art.is-multi svg,
    .rule-hero-symbol-overlay__art.is-multi img {
      height: clamp(90px, 19vh, 160px);
      max-width: 44%;
    }
    .rule-hero-symbol-overlay__cap {
      font-size: 1.05rem;
      font-weight: 700;
      color: #fff;
      letter-spacing: 0.02em;
      text-align: center;
    }
    /* 同じシンボルを使う県の一覧（拡大表示時のキャプション） */
    .rule-hero-symbol-overlay__capsec + .rule-hero-symbol-overlay__capsec {
      margin-top: 0.8rem;
      padding-top: 0.7rem;
      border-top: 1px solid rgba(255, 255, 255, 0.15);
    }
    .rule-hero-symbol-overlay__caphead {
      display: block;
      font-size: 0.82rem;
      font-weight: 600;
      color: rgba(255, 255, 255, 0.6);
      margin-bottom: 0.4rem;
    }
    .rule-hero-symbol-overlay__list {
      display: block;
      max-width: min(80%, 640px);
      margin: 0 auto;
      font-size: 1.0rem;
      font-weight: 700;
      color: #fff;
      line-height: 1.6;
    }

    /* 白タイルを使わないシンボル（白図形向け）。帯の紺色に直接描画し、
       枠・余白を持たず、表示サイズを一回り大きくする。 */
    .rule-hero-symbol__icon--bare {
      background: transparent;
      padding: 0;
      height: 116px;
      min-width: 0;
      box-shadow: none !important;
    }
    /* 拡大オーバーレイでも白タイルを外し、紺の暗幕に直接白図形を出す */
    .rule-hero-symbol-overlay__art.is-bare {
      background: transparent;
      padding: 0;
    }
    .rule-hero-symbol-overlay__art.is-bare img,
    .rule-hero-symbol-overlay__art.is-bare svg {
      height: clamp(180px, 40vh, 320px);
      max-width: 90%;
    }

    @media (max-width: 600px) {
      .rule-hero-symbols__inner { padding: 0 1rem; gap: 1rem 1.2rem; }
      .rule-hero-symbol__icon { height: 64px; min-width: 64px; padding: 6px; }
      .rule-hero-symbol__icon--bare { height: 88px; min-width: 0; padding: 0; }
      .rule-hero-symbol__logo { max-width: 104px; }
      .rule-hero-symbol__label { font-size: 0.85rem; }
    }

    .rule-hero-title {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    /* 親（例: 中部）へ戻るチップ。長い県/国ページでも上部から1クリックで
       上位カテゴリへ戻れるようにする（パンくずはページ下部にしか出ないため）。 */
    .rule-hero-back {
      align-self: flex-start;
      display: inline-flex;
      align-items: center;
      gap: 0.5em;
      margin-bottom: -0.25rem;
      padding: 5px 14px 5px 11px;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.18);
      border-radius: 999px;
      color: rgba(255, 255, 255, 0.9);
      font-size: 0.82rem;
      font-weight: 600;
      line-height: 1.4;
      text-decoration: none;
      transition: background 0.15s ease, border-color 0.15s ease,
        color 0.15s ease;
    }
    .rule-hero-back i {
      font-size: 0.85em;
      transition: transform 0.15s ease;
    }
    .rule-hero-back:hover {
      background: rgba(224, 123, 32, 0.18);
      border-color: rgba(224, 123, 32, 0.6);
      color: #ffd082;
      text-decoration: none;
    }
    .rule-hero-back:hover i {
      transform: translateX(-3px);
    }
    .rule-hero-title__h1 {
      font-size: clamp(1.6rem, 2.6vw, 2.3rem);
      line-height: 1.25;
      margin: 0;
      color: #fff;
      font-weight: 700;
    }
    .rule-hero-title__prefix,
    .rule-hero-title__suffix {
      display: inline-block;
      font-size: 0.62em;
      font-weight: 500;
      color: rgba(255, 255, 255, 0.72);
      margin: 0 0.4em;
    }
    .rule-hero-title__main {
      display: inline-block;
    }
    .rule-hero-title__icons {
      display: inline-flex;
      align-items: center;
      gap: 0.4em;
      margin-left: 0.45em;
      font-size: 0.55em;
      vertical-align: middle;
      color: rgba(255, 255, 255, 0.78);
    }
    .rule-hero-title__icons i {
      color: inherit !important;
      margin-left: 0 !important;
    }
    /* ボラードアイコンは元々 opacity:0 が設定されているため、ヒーロー内では強制表示 */
    .rule-hero-title__icons i.i-bollard {
      opacity: 1 !important;
    }
    .rule-hero-title__icons i:hover {
      color: #e07b20 !important;
    }
    .rule-hero-flag {
      max-width: 240px;
      overflow: hidden;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.35);
    }
    .rule-hero-flag img {
      display: block;
      width: 100%;
      height: auto;
    }

    /* ヒーロー左カラム内の「間違えやすい地域」「練習用マップ」 */
    .rule-hero-links {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }
    .rule-hero-links__label {
      font-size: 0.75rem;
      color: rgba(255, 255, 255, 0.65);
      text-transform: none;
      letter-spacing: 0.02em;
      display: flex;
      align-items: center;
      gap: 0.4em;
    }
    .rule-hero-links__label i {
      color: #e07b20;
    }
    .rule-hero-links__list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }
    .rule-hero-links__list li {
      margin: 0;
    }
    .rule-hero-links__list a {
      display: inline-block;
      padding: 4px 12px;
      background: rgba(255, 255, 255, 0.08);
      color: #fff;
      font-size: 0.78rem;
      text-decoration: none;
      border: 1px solid rgba(255, 255, 255, 0.18);
      transition: background 0.15s ease, border-color 0.15s ease;
      line-height: 1.4;
    }
    .rule-hero-links__list a:hover {
      background: rgba(224, 123, 32, 0.18);
      border-color: rgba(224, 123, 32, 0.6);
      color: #fff;
    }

    @media (max-width: 900px) {
      .rule-hero-section__inner {
        grid-template-columns: 1fr;
        gap: 1rem;
        padding: 1rem 1rem 0;
      }
      .rule-hero-flag {
        max-width: 180px;
      }
    }

    /* ヒーロー下のスライドショー（hero と同じ紺色で連続感を出す） */
    .rule-hero-gallery {
      position: relative;
      overflow: hidden;
      background: #1a2535;
      padding: 12px 0 10px;
      margin-bottom: 0;
    }
    /* 左右のフェード（hero 背景色へ自然に溶け込む） */
    .rule-hero-gallery::before,
    .rule-hero-gallery::after {
      content: "";
      position: absolute;
      top: 0;
      bottom: 0;
      width: 80px;
      pointer-events: none;
      z-index: 2;
    }
    .rule-hero-gallery::before {
      left: 0;
      background: linear-gradient(to right, #1a2535, rgba(26, 37, 53, 0));
    }
    .rule-hero-gallery::after {
      right: 0;
      background: linear-gradient(to left, #1a2535, rgba(26, 37, 53, 0));
    }
    .rule-hero-gallery__track {
      display: flex;
      gap: 12px;
      animation: rule-hero-gallery-scroll 80s linear infinite;
      width: max-content;
    }
    .rule-hero-gallery__item {
      flex: 0 0 auto;
      width: 280px;
      height: 188px;
      margin: 0;
      overflow: hidden;
      border-radius: 8px;
      background: #0f1722;
      box-shadow: 0 3px 10px rgba(0, 0, 0, 0.35);
      transition: transform 0.25s ease, box-shadow 0.25s ease;
    }
    .rule-hero-gallery__item:hover {
      transform: translateY(-2px) scale(1.01);
      box-shadow: 0 6px 16px rgba(0, 0, 0, 0.5);
    }
    .rule-hero-gallery__item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    @keyframes rule-hero-gallery-scroll {
      0%   { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    .rule-hero-gallery:hover .rule-hero-gallery__track {
      animation-play-state: paused;
    }
    @media (max-width: 700px) {
      .rule-hero-gallery__item {
        width: 220px;
        height: 148px;
      }
      .rule-hero-gallery::before,
      .rule-hero-gallery::after {
        width: 40px;
      }
    }

    /* OSM ヒーロー使用時の article-surface 上部余白を圧縮（hidden h1 のスペースを除去） */
    .article-surface--osm-hero {
      padding-top: 1.25rem;
    }

    /* ヒーロー左カラムの「県の特徴 / 国の特徴」 */
    .rule-hero-features {
      color: rgba(255, 255, 255, 0.85);
      font-size: 0.82rem;
      line-height: 1.7;
    }
    .rule-hero-features__title {
      font-weight: 600;
      color: rgba(255, 255, 255, 0.55);
      font-size: 0.72rem;
      margin-bottom: 4px;
      letter-spacing: 0.05em;
    }
    .rule-hero-features__list {
      list-style: none;
      margin: 0;
      padding: 0;
    }
    .rule-hero-features__list li {
      margin: 4px 0;
    }
    .rule-hero-features .quiz {
      color: #ffd082;
      font-weight: 700;
    }
    .rule-hero-features a {
      color: rgba(255, 255, 255, 0.55);
      text-decoration: none;
    }
    .rule-hero-features a:hover {
      color: #ffd082;
    }
    /* ギャラリー直後の section の上余白を圧縮 */
    .single.single--osm-hero {
      padding-top: 1.25rem !important;
    }
    /* コンテンツ下に表示するパンくずは控えめに */
    .article-breadcrumb--bottom {
      margin-top: 1.25rem !important;
      margin-bottom: 0 !important;
      opacity: 0.85;
      font-size: 0.85rem;
    }
  </style>
</head>
<body>
  <Fragment set:html={aiSourceComment} />
  {/* Header */}
  <header class="shadow-bottom sticky-top bg-white">
    <Navbar lang={lang} isHome={false} />
  </header>

  {/* OSM ヒーロー（mapProvider: osm の国別ページのみ） */}
  {useOSMHero && (
    <section class="rule-hero-section">
      <div class="rule-hero-section__inner">
        <div class="rule-hero-title">
          {parentCrumb && (
            <a href={parentCrumb.url} class="rule-hero-back" aria-label={`${parentCrumb.name}${lang === "ja" ? "に戻る" : ""}`}>
              <i class="fas fa-arrow-left"></i>
              <span>{parentCrumb.name}</span>
            </a>
          )}
          <h1 class="rule-hero-title__h1">
            {data.title_prefix && <span class="rule-hero-title__prefix">{data.title_prefix}</span>}
            <span class="rule-hero-title__main">{data.title}</span>
            {data.title_suffix && <span class="rule-hero-title__suffix">{data.title_suffix}</span>}
            <span class="rule-hero-title__icons">
              {data.is_has_distinctive_googlecar && <i class="fas fa-car-alt i-googlecar" title="特徴的な GoogleCar"></i>}
              {data.is_has_many_trekker && <i class="fas fa-hiking i-googlecar" title="トレッカーが多い"></i>}
              {data.is_has_distinctive_bollard && <i class="fas fa-magic i-bollard" title="特徴的なボラード"></i>}
              {data.is_unofficial && <i class="fa fa-question-circle" title="Geoguessr の公式マップでは出題されない場所"></i>}
            </span>
          </h1>
          {data.flag && (
            <div class="rule-hero-flag">
              <img
                src={flagPath}
                alt={lang === "ja" ? `${data.title}の国旗` : `national flag of ${data.title}`}
                width="240"
                height="160"
                loading="eager"
                decoding="async"
              />
            </div>
          )}
          {/* 「県の特徴 / 国の特徴」 — frontmatter の features をヒーロー側で直接描画 */}
          {data.features && data.features.length > 0 && (
            <div class="rule-hero-features">
              <div class="rule-hero-features__title">
                {data.is_pref ? t("prefecture-features", lang) : t("country-features", lang)}
              </div>
              <ul class="rule-hero-features__list">
                {data.features.map((f: { text: string; ref?: string }) => (
                  <li>
                    <Fragment set:html={f.text} />
                    {f.ref && <a href={f.ref} target="_blank" rel="noopener"><sup>[参]</sup></a>}
                  </li>
                ))}
              </ul>
            </div>
          )}
          {data.sc && (
            <div class="rule-hero-links">
              <div class="rule-hero-links__label">
                <i class="far fa-question-circle"></i>{data.sc_title}
              </div>
              <ul class="rule-hero-links__list">
                {data.sc.map((item: [string, string]) => (
                  <li><a href={item[0]}>{item[1]}</a></li>
                ))}
              </ul>
            </div>
          )}
          {data.maps && (
            <div class="rule-hero-links">
              <div class="rule-hero-links__label">
                <i class="fas fa-map-marked-alt"></i>{data.map_title}
              </div>
              <ul class="rule-hero-links__list">
                {data.maps.map((item: [string, string]) => (
                  <li><a href={item[0]} target="_blank" rel="noopener">{item[1]}</a></li>
                ))}
              </ul>
            </div>
          )}
          {data.related_quizzes && (
            <div class="rule-hero-links">
              <div class="rule-hero-links__label">
                <i class="fas fa-puzzle-piece"></i>{data.related_quizzes_title}
              </div>
              <ul class="rule-hero-links__list">
                {data.related_quizzes.map((item: [string, string]) => (
                  <li><a href={item[0]}>{item[1]}</a></li>
                ))}
              </ul>
            </div>
          )}
        </div>
        <div class="rule-hero-map">
          <IndustryOSMMap
            pins={data.mapPins || []}
            center={data.mapCenter}
            zoom={data.mapZoom}
            regions={data.mapRegions}
          />
          {/* シンボルにオンマウスした際、地図領域へ拡大表示するオーバーレイ。
              中身は JS で hover 中のシンボル SVG を複製して差し込む。 */}
          {data.prefSymbols && data.prefSymbols.length > 0 && (
            <div class="rule-hero-symbol-overlay" id="pref-symbol-overlay" aria-hidden="true">
              <div class="rule-hero-symbol-overlay__inner"></div>
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  {/* 県を象徴するシンボル帯（ヒーロー直下）。電力会社・横断歩道標識・
      標識ポール模様などを SVG で横並び表示。frontmatter の prefSymbols 駆動。
      各シンボルにオンマウスすると上の地図領域へ拡大表示（短いフェード）。 */}
  {useOSMHero && data.prefSymbols && data.prefSymbols.length > 0 && (
    <Fragment>
    <div class="rule-hero-symbols">
      <ul class="rule-hero-symbols__inner">
        {data.prefSymbols.map((sym: { label: string; name?: string; svg?: string; imgs?: { src: string; alt?: string }[]; bare?: boolean; group?: string }) => (
          <li class={`rule-hero-symbol${sym.bare ? " rule-hero-symbol--bare" : ""}`} tabindex="0" data-bare={sym.bare ? "1" : "0"} data-group={sym.group || ""} data-companies={(sym.imgs || []).filter((im) => typeof im.src === "string" && im.src.startsWith("/rule/power/")).map((im) => im.alt || "").filter(Boolean).join("|")}>
            <span class={`rule-hero-symbol__icon${sym.imgs && sym.imgs.length > 1 ? " rule-hero-symbol__icon--multi" : ""}${sym.bare ? " rule-hero-symbol__icon--bare" : ""}`} aria-hidden="true">
              {sym.svg && <Fragment set:html={sym.svg} />}
              {sym.imgs && sym.imgs.map((im: { src: string; alt?: string }) => (
                <img class="rule-hero-symbol__logo" src={im.src} alt={im.alt || sym.label} loading="lazy" decoding="async" />
              ))}
            </span>
            <span class="rule-hero-symbol__text">
              <span class="rule-hero-symbol__label">{sym.label}</span>
              {sym.name && <span class="rule-hero-symbol__name">{sym.name}</span>}
            </span>
          </li>
        ))}
      </ul>
    </div>
    <script is:inline define:vars={{ symbolGroupMembers, powerCompanyMembers }}>
      (function () {
        var overlay = document.getElementById("pref-symbol-overlay");
        if (!overlay) return;
        var inner = overlay.querySelector(".rule-hero-symbol-overlay__inner");
        var items = document.querySelectorAll(".rule-hero-symbols .rule-hero-symbol");
        var groups = symbolGroupMembers || {};
        var companies = powerCompanyMembers || {};
        var hideTimer = null;
        function esc(s) {
          return String(s).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
        }
        function section(head, list) {
          if (!list || !list.length) return "";
          return (
            '<div class="rule-hero-symbol-overlay__capsec">' +
            '<span class="rule-hero-symbol-overlay__caphead">' + esc(head) + "</span>" +
            '<span class="rule-hero-symbol-overlay__list">' + list.map(esc).join("・") + "</span>" +
            "</div>"
          );
        }
        function show(item) {
          if (hideTimer) { clearTimeout(hideTimer); hideTimer = null; }
          var icon = item.querySelector(".rule-hero-symbol__icon");
          var label = item.querySelector(".rule-hero-symbol__label");
          if (!icon) return;
          var bare = item.getAttribute("data-bare") === "1";
          var multi = icon.querySelectorAll("img").length > 1;
          var secs = "";
          // 電力会社：会社名ごとに「○○電力エリアの県」一覧（二社またぎは両方）
          var comps = (item.getAttribute("data-companies") || "").split("|").filter(Boolean);
          comps.forEach(function (c) {
            secs += section(c + "エリアの県", companies[c]);
          });
          // group シンボル（ダイヤマーク等）：同じシンボルを使う県一覧
          var group = item.getAttribute("data-group");
          if (group && groups[group]) {
            secs += section((label ? label.textContent : "") + "を使う県", groups[group]);
          }
          var capHtml = secs || (label ? esc(label.textContent) : "");
          inner.innerHTML =
            '<div class="rule-hero-symbol-overlay__art' + (bare ? " is-bare" : "") + (multi ? " is-multi" : "") + '">' + icon.innerHTML + "</div>" +
            (capHtml ? '<div class="rule-hero-symbol-overlay__cap">' + capHtml + "</div>" : "");
          overlay.classList.add("is-visible");
          overlay.setAttribute("aria-hidden", "false");
        }
        function hide() {
          overlay.classList.remove("is-visible");
          overlay.setAttribute("aria-hidden", "true");
          // 中身はフェードアウト後に消去
          if (hideTimer) clearTimeout(hideTimer);
          hideTimer = setTimeout(function () { inner.innerHTML = ""; }, 220);
        }
        items.forEach(function (item) {
          item.addEventListener("mouseenter", function () { show(item); });
          item.addEventListener("mouseleave", hide);
          item.addEventListener("focus", function () { show(item); });
          item.addEventListener("blur", hide);
        });
      })();
    </script>
    </Fragment>
  )}

  {/* JSMap ヒーロー（map_index のセクションインデックス: /rule/ ワールドマップ等） */}
  {useWorldJSMapHero && (
    <section class="rule-hero-section rule-hero-section--jsmap">
      <div class="rule-hero-section__inner rule-hero-section__inner--jsmap">
        <div class="rule-hero-title">
          <h1 class="rule-hero-title__h1">
            {data.title_prefix && <span class="rule-hero-title__prefix">{data.title_prefix}</span>}
            <span class="rule-hero-title__main">{data.title}</span>
            {data.title_suffix && <span class="rule-hero-title__suffix">{data.title_suffix}</span>}
          </h1>
        </div>
        <div class="rule-hero-map">
          <div class={`areamap-container areamap-container--hero ${data.additional_map_class || ""}`}>
            <div class="jsmaps-wrapper" id="world-map"></div>
          </div>
        </div>
      </div>
    </section>
  )}

  {/* ヒーロー下のスライドショー（heroGallery 指定時のみ） */}
  {useOSMHero && data.heroGallery && data.heroGallery.length > 0 && (
    <div class="rule-hero-gallery">
      <div class="rule-hero-gallery__track">
        {data.heroGallery.map((src: string) => (
          <figure class="rule-hero-gallery__item">
            <img src={src} alt="" loading="lazy" />
          </figure>
        ))}
        {data.heroGallery.map((src: string) => (
          <figure class="rule-hero-gallery__item" aria-hidden="true">
            <img src={src} alt="" loading="lazy" />
          </figure>
        ))}
      </div>
    </div>
  )}

  {/* Main content */}
  <section class={`single section-sm pb-0${isQuizPage ? " quiz-page" : ""}${useHeroLayout ? " single--osm-hero" : ""}`}>
    <div class={isQuizPage ? "container-lg" : "container"}>
      <div class="row">
        {/* Sidebar (hidden for quiz pages) */}
        {!isQuizPage && (
          <div class="col-lg-3">
            <Sidebar lang={lang} tree={tree} currentUrl={currentUrl} bgf={!!data.bgf} adCount={sidebarAdCount} />
          </div>
        )}

        {/* Content */}
        <div class={isQuizPage ? "col-lg-8 offset-lg-2" : "col-lg-9"}>
          {/* ヒーロー使用時 (OSM / JSMap) はパンくずを下部へ移動 */}
          {!useHeroLayout && (
            <ol class="breadcrumb article-breadcrumb">
              {crumbs.map((crumb, i) =>
                i === crumbs.length - 1
                  ? <li>{crumb.name}</li>
                  : <li><a href={crumb.url}>{crumb.name}</a></li>
              )}
            </ol>
          )}

          <div class={`article-surface${useHeroLayout ? " article-surface--osm-hero" : ""}`}>
            {!useHeroLayout && (
              <h1 class={isQuizPage ? "mb-3 quiz-page-title" : "mb-5"}>
                {data.title_prefix && <span class="small-title">{data.title_prefix}</span>}
                {data.title}
                {data.title_suffix && <span class="small-title">{data.title_suffix}</span>}
                {isQuizPage && data.quiz_suffix && <span class="quiz-suffix">{data.quiz_suffix}</span>}
                <span style="font-size:0.5em">
                  {data.is_has_distinctive_googlecar && <i class="fas fa-car-alt i-googlecar"></i>}
                  {data.is_has_many_trekker && <i class="fas fa-hiking i-googlecar"></i>}
                  {data.is_has_distinctive_bollard && <i class="fas fa-magic i-bollard"></i>}
                  {data.is_unofficial && <i class="fa fa-question-circle"></i>}
                </span>
              </h1>
            )}

            {/* Flag display（OSM ヒーロー使用時はヒーロー側に移動するので非表示） */}
            {data.flag && !useOSMHero && (
              <div
                class={`content unclickable ${!data.flag_height ? "top-flagarea" : ""}`}
                style={data.flag_height ? `height:${data.flag_height};` : undefined}
              >
                <img
                  src={flagPath}
                  alt={lang === "ja" ? `${data.title}の国旗` : `national flag of ${data.title}`}
                  width="680"
                  height="500"
                  loading="eager"
                  decoding="async"
                />
              </div>
            )}

            {/* SC area (shortcut links) — OSM ヒーロー使用時はヒーロー側へ移動 */}
            {data.sc && !useOSMHero && (
              <div class="sc_area">
                <ul>
                  <li class="sc-title">
                    <button class="button-sc bg-white-button" role="button">
                      <i class="far fa-question-circle link-title-button"></i>{data.sc_title}
                    </button>
                  </li>
                  {data.sc.map((item: [string, string]) => (
                    <li>
                      <a href={item[0]}>
                        <button class="button-sc bg-black-button" role="button">{item[1]}</button>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            {/* Map links — OSM ヒーロー使用時はヒーロー側へ移動 */}
            {data.maps && !useOSMHero && (
              <div class="sc_area">
                <ul>
                  <li class="sc-title">
                    <button class="button-sc bg-white-button" role="button">
                      <i class="fas fa-map-marked-alt link-title-button"></i>{data.map_title}
                    </button>
                  </li>
                  {data.maps.map((item: [string, string]) => (
                    <li>
                      <a href={item[0]}>
                        <button class="button-sc bg-black-button" role="button">{item[1]}</button>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            {/* JSMaps: mapName (individual country pages) — OSM ヒーロー使用時は抑止 */}
            {data.mapName && !useOSMHero && (
              <div class="map-container">
                <div class="container">
                  <div class="jsmaps-wrapper" id="world-map"></div>
                </div>
              </div>
            )}

            {/* JSMaps: map_index (section index pages) — ヒーロー使用時はヒーロー側へ移動 */}
            {data.map_index && !useHeroLayout && (
              <div class={`areamap-container ${data.additional_map_class || ""}`}>
                <div class="container">
                  <div class="jsmaps-wrapper" id="world-map"></div>
                </div>
              </div>
            )}

            {/* JSMaps init + library scripts — OSM ヒーロー使用時は抑止 */}
            {data.mapName && !useOSMHero && (
              <Fragment>
                <script is:inline define:vars={{ mapName: data.mapName }}>
                  $(function() {
                    $('#world-map').JSMaps({
                      map: mapName,
                      stateClickAction: 'text',
                      textPosition: 'right',
                      displayAbbreviations: true,
                      disableTooltip: true,
                      selectElement: false,
                      pinSize: 0,
                    });
                  });
                </script>
                <script is:inline src="/mp/jsmaps/jsmaps-libs.js"></script>
                <script is:inline src="/mp/jsmaps/jsmaps-panzoom.js"></script>
                <script is:inline src="/mp/jsmaps/jsmaps.min.js"></script>
                <script is:inline src={`/mp/maps/${data.mapName}.js`}></script>
              </Fragment>
            )}
            {data.map_index && !data.mapName && !useOSMHero && (
              <Fragment>
                <script is:inline define:vars={{ mapIndex: data.map_index }}>
                  $(function() {
                    $('#world-map').JSMaps({
                      map: mapIndex,
                      stateClickAction: 'url',
                      disableTooltip: false,
                      selectElement: false,
                      displayAbbreviations: true,
                      hrefTarget: "_self",
                      pinSize: 0,
                    });
                  });
                </script>
                <script is:inline src="/mp/jsmaps/jsmaps-libs.js"></script>
                <script is:inline src="/mp/jsmaps/jsmaps-panzoom.js"></script>
                <script is:inline src="/mp/jsmaps/jsmaps.min.js"></script>
                <script is:inline src={`/mp/maps/${data.map_index}.js`}></script>
              </Fragment>
            )}

            {/* Table of Contents (only for pages with content) */}
            {hasContent && <TableOfContents />}

            {/* Auto-generated child page flag grid (for section pages with children) */}
            {sectionChildTree.length > 0 && isRuleSection && (
              <div class="p-4">
                <ul class="flag-list">
                  <Fragment set:html={sectionTreeHtml} />
                </ul>
              </div>
            )}
            {sectionChildTree.length > 0 && !isRuleSection && !hasContent && (
              <div class="p-4">
                <ul class="page-list">
                  <Fragment set:html={sectionTreeHtml} />
                </ul>
              </div>
            )}

            {/* Main content */}
            {hasContent && (
              <div class="content" data-pagefind-body>
                {/* Country/region features card — OSM hero 使用時は非表示 */}
                {data.features && data.features.length > 0 && data.flag && !data.is_pref && !useOSMHero && (
                  <div class="pref-tips">
                    <div class="pref-tips-title">{t("country-features", lang)}</div>
                    <ul>
                      {data.features.map((f: {text: string, ref?: string}) => (
                        <li>
                          <Fragment set:html={f.text} />
                          {f.ref && <a href={f.ref} target="_blank"><sup>[参]</sup></a>}
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
                {/* 不可視透かし（コピペで運ばれる原作署名）。data-pagefind-ignore で検索索引から除外。 */}
                <span data-pagefind-ignore aria-hidden="true" set:html={watermark} />
                <slot />
                <span data-pagefind-ignore aria-hidden="true" set:html={watermark} />

                {/* Related industry pages */}
                {relatedIndustryLinks.length > 0 && (
                  <div class="main-information">
                    <h4 class="section-title">
                      <i class="fas fa-industry"></i>
                      {lang === "ja"
                        ? " 関連する産業ページ"
                        : " Related Industry Pages"}
                    </h4>
                    <ul class="info-list">
                      {relatedIndustryLinks.map((link) => (
                        <li>
                          <a href={link.url}>
                            {link.title}
                            {link.subtitle && <span class="related-industry-subtitle"> — {link.subtitle}</span>}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}

                {/* Related sites (country pages with flag) */}
                {data.flag && !data.no_rel_site && (
                  <div class="main-information">
                    <h4 class="section-title"><Fragment set:html={t("rel-site", lang)} /></h4>
                    <ul class="info-list">
                      <li><a href={`https://ja.wikipedia.org/wiki/${data.title}`}>{data.title} (wikipedia)</a></li>
                      {data.plonkit && (
                        <li>
                          <a href={`https://www.plonkit.net/${data.plonkit_url || currentSlug.split("/").pop()}`}>plonk it</a>
                        </li>
                      )}
                    </ul>
                  </div>
                )}

                {/* Sibling countries */}
                {siblings.length > 0 && (
                  <div class="main-information same-region-area">
                    <h4 class="section-title">
                      {lang === "ja"
                        ? `${parentTitle}の国や地域`
                        : lang === "es"
                          ? `Países y territorios en ${parentTitle}`
                          : lang === "pt"
                            ? `Países e territórios em ${parentTitle}`
                            : lang === "id"
                              ? `Negara dan wilayah di ${parentTitle}`
                              : `Countries and territories in ${parentTitle}`}
                    </h4>
                    <ul class="info-list">
                      {siblings.map((s) => (
                        <li class={s.isUnofficial ? "unofficial-area" : ""}><a href={s.url}>{s.title}</a></li>
                      ))}
                    </ul>
                  </div>
                )}

                {/* References — rendered last so it sits below sibling-countries */}
                {referenceList.length > 0 && (
                  <div class="references-section" id="references">
                    <h3 class="references-title">参考文献・出典</h3>
                    <ol class="references-list">
                      {referenceList.map((r, i) => (
                        <li id={`ref-${r.key}`} class="ref-item">
                          <span class="ref-num">[{i + 1}]</span>{" "}
                          <span class="ref-text" set:html={linkifyRefText(r.text)} />
                        </li>
                      ))}
                    </ol>
                  </div>
                )}
              </div>
            )}

            {/* Last modified */}
            {lastmodDisplay && (
              <p class="post-meta border-bottom pb-3 mb-0 mt-3">Updated on {lastmodDisplay}</p>
            )}

            {/* Hidden SEO text */}
            <div class="msg-to-gpt">
              geoguessr（ジオゲッサー）のプレイログを記録したページです。
            </div>
          </div>

          {/* ヒーロー使用時 (OSM / JSMap) のパンくず（コンテンツ下に表示） */}
          {useHeroLayout && (
            <ol class="breadcrumb article-breadcrumb article-breadcrumb--bottom">
              {crumbs.map((crumb, i) =>
                i === crumbs.length - 1
                  ? <li>{crumb.name}</li>
                  : <li><a href={crumb.url}>{crumb.name}</a></li>
              )}
            </ol>
          )}
        </div>
      </div>
    </div>
  </section>

  {/* Floating share buttons */}
  <div class="floating-share-group">
    <button
      class="floating-action floating-copy-url"
      type="button"
      data-tooltip={t("floating_copy_tooltip", lang)}
      data-success-tooltip={t("floating_copy_success", lang)}
      aria-label={t("floating_copy_aria", lang)}
    >
      <i class="fas fa-link"></i>
    </button>

    <a
      class="floating-action floating-share-x"
      href={shareURL}
      target="_blank"
      rel="noopener"
      aria-label={t("floating_share_aria", lang)}
      data-tooltip={t("floating_share_tooltip", lang)}
    >
      <i class="fab fa-twitter"></i>
    </a>

    <a
      class="floating-action floating-chatgpt"
      href={`https://chat.openai.com/?q=${chatGptPrompt}`}
      target="_blank"
      rel="noopener"
      aria-label={t("floating_ask_gpt", lang)}
      data-tooltip={t("floating_ask_gpt", lang)}
    >
      <i class="fas fa-comments"></i>
    </a>
  </div>

  <script is:inline>
    (() => {
      const copyBtn = document.querySelector(".floating-copy-url");
      if (!copyBtn) return;
      const tooltipAttr = "data-tooltip";
      const successAttr = "data-success-tooltip";
      const defaultMessage = copyBtn.getAttribute(tooltipAttr) || "";
      const successMessage = copyBtn.getAttribute(successAttr) || defaultMessage;
      let resetTimer = null;
      const resetTooltip = () => {
        copyBtn.setAttribute(tooltipAttr, defaultMessage);
        copyBtn.classList.remove("is-success");
      };
      const showSuccess = () => {
        copyBtn.setAttribute(tooltipAttr, successMessage);
        copyBtn.classList.add("is-success");
        if (resetTimer) clearTimeout(resetTimer);
        resetTimer = setTimeout(resetTooltip, 2000);
      };
      copyBtn.addEventListener("click", async () => {
        try {
          if (navigator.clipboard?.writeText) {
            await navigator.clipboard.writeText(window.location.href);
          } else {
            const ta = document.createElement("textarea");
            ta.value = window.location.href;
            ta.style.position = "fixed";
            ta.style.opacity = "0";
            document.body.appendChild(ta);
            ta.select();
            document.execCommand("copy");
            document.body.removeChild(ta);
          }
          showSuccess();
        } catch (err) {
          console.error("Failed to copy URL", err);
        }
      });
    })();
  </script>

  <Footer lang={lang} title={data.title} permalink={canonical} flag={data.flag} translations={translationUrls} />
  <SearchModal lang={lang} />
</body>
</html>
