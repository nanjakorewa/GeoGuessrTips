#!/bin/bash
# pre-commit hook (versioned)
#
# Layered protection against accidentally committing personal information:
#   1. Strip stray NULL bytes from staged text files.
#   2. Run scripts/hooks/check_pii.py — blocks API keys / private keys /
#      Luhn-valid credit-card numbers / well-known secret filenames.  Warns on
#      emails / phone / postal / 12-digit numbers.
#   3. Block legacy NG words listed in .ngwords (existing behaviour).
#
# To enable in this repository, run scripts/hooks/install.sh once.
set -uo pipefail

ROOT="$(git rev-parse --show-toplevel)"
PII_SCRIPT="$ROOT/scripts/hooks/check_pii.py"
NGWORDS_FILE="$ROOT/.ngwords"

# --- 1. Strip trailing NULL bytes from staged text files ----------------- #
STRIPPED=0
for f in $(git diff --cached --name-only --diff-filter=ACMR); do
  [ -f "$f" ] || continue
  if file --mime "$f" 2>/dev/null | grep -q 'charset=binary'; then
    continue
  fi
  if grep -Plc '\x00' "$f" > /dev/null 2>&1; then
    tr -d '\0' < "$f" > "${f}.tmp" && mv "${f}.tmp" "$f"
    git add "$f"
    STRIPPED=1
    echo "  Stripped NULL bytes: $f"
  fi
done
if [ $STRIPPED -eq 1 ]; then
  echo "[pre-commit] NULL bytes were removed from the above file(s)."
fi

# --- 2. PII / secrets scan ---------------------------------------------- #
if [ -f "$PII_SCRIPT" ]; then
  PYTHON_BIN=""
  for candidate in python3 python; do
    if command -v "$candidate" >/dev/null 2>&1; then
      PYTHON_BIN="$candidate"
      break
    fi
  done
  if [ -z "$PYTHON_BIN" ]; then
    echo "[pre-commit] WARNING: python not found — skipping PII scan."
  else
    if ! "$PYTHON_BIN" "$PII_SCRIPT"; then
      exit 1
    fi
  fi
fi

# --- 3. Legacy NG-words check (preserve existing behaviour) -------------- #
if [ -f "$NGWORDS_FILE" ]; then
  WORDS=()
  while IFS= read -r line; do
    line="$(echo "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
    [[ -z "$line" || "$line" == \#* ]] && continue
    WORDS+=("$line")
  done < "$NGWORDS_FILE"

  if [ ${#WORDS[@]} -gt 0 ]; then
    FOUND=0
    DIFF_OUT=$(git diff --cached --diff-filter=ACMR -U0 \
      -- ':(exclude).ngwords' ':(exclude).piiallowlist' \
         ':(exclude)public/images/industry/japan-supermarket/osakaya_shop.svg' \
      | grep -i "^+" | grep -v "^+++" \
      | sed 's/www\.sony\.com//gi')

    for word in "${WORDS[@]}"; do
      MATCHES=$(echo "$DIFF_OUT" | grep -in "$word" 2>/dev/null || true)
      if [ -n "$MATCHES" ]; then
        if [ $FOUND -eq 0 ]; then
          echo ""
          echo "!! NG word detected in staged changes !!"
          echo "-------------------------------------------"
        fi
        echo "  NG word: \"$word\""
        FOUND=1
      fi
    done

    if [ $FOUND -ne 0 ]; then
      echo "-------------------------------------------"
      echo "Commit aborted. Remove the NG words and try again."
      exit 1
    fi
  fi
fi

exit 0
